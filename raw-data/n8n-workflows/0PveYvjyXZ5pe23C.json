    {
      "parameters": {
        "operation": "executeQuery",
        "query": "-- 首先检查 printinfo_id 为 62 的记录的 status 是否为 1\nDO $$\nBEGIN\n    -- 查询 status 值\n    IF EXISTS (SELECT 1 FROM mes.printinfo WHERE printinfo_id = {{ $json.body.printinfo_id }} AND status = 1) THEN\n        -- 如果满足条件，则更新 status 为 2\n        UPDATE mes.printinfo\n        SET status = 2 \n        WHERE printinfo_id = {{ $json.body.printinfo_id }};\n    END IF;\nEND $$;\n-- 再查询更新后的状态\nSELECT printinfo_id, status\nFROM mes.printinfo\nWHERE printinfo_id = {{ $json.body.printinfo_id }};",
        "options": {}
      },
