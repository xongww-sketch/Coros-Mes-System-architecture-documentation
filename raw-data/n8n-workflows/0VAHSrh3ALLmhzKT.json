    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    p.printinfo_id,\n    p.print_name,\n    p.print_quantity,\n    p.createtime,\n    u.user_name,\n    m.product_model_name,\n    p.file_name,\n    p.product_model_id,          p.printinfo_type,\n  print_version\nFROM \n    mes.printinfo p\nJOIN \n    mes.user u ON p.user_id = u.user_id\nJOIN \n    mes.product_model m ON p.product_model_id = m.product_model_id\nwhere p.printinfo_id={{ $json.body.printinfo_id}} and p.status = 1;",
