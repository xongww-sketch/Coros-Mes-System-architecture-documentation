    {
      "parameters": {
        "jsCode": "let res = [];\nfor (const item of $input.all()) {\n    // 复制项并添加包装类型\n    let itemCopy = {...item.json};\n    if (itemCopy.printinfo_type === 1) {\n        itemCopy.packaging_type = \"彩盒包装\";\n    } else if (itemCopy.printinfo_type === 2) {\n        itemCopy.packaging_type = \"整箱包装\";\n    }\n    res.push(itemCopy);\n}\n\nreturn {\n  result: res\n};\n"
      },
