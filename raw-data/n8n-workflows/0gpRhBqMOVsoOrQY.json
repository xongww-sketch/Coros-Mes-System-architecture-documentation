    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const { shop_name, customer_name } = item.json;\n  \n  // 检查customer_name是否有效：非空且非纯空格\n  const isValidCustomer = customer_name?.trim?.()?.length > 0;\n  \n  // 判断条件：有效客户名 + 指定店铺 + 非纯数字字符串\n  if (isValidCustomer && \n      (shop_name === \"COROS 高驰订货商城\") &&\n      !isNaN(Number(customer_name))) {\n    item.json.code = 1;\n  } else {\n    item.json.code = 2;\n  }\n}\n\nreturn $input.all();"
      },
