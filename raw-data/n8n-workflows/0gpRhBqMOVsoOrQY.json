    {
      "parameters": {
        "jsCode": "let shop = $input.all()[0].json.shop_name;\nlet customerName = $input.all()[0].json.customer_name;\nlet Channelid;\n\nswitch (shop) {\n  case \"高驰官方旗舰店(抖音)\":\n    Channelid = 10851;\n    break;\n  case \"COROS天猫旗舰店\":\n    Channelid = 10587;\n    break;\n  case \"COROS京东旗舰店\":\n    Channelid = 10760;\n    break;\n  case \"COROS小红书店\":\n    Channelid = 10920;\n    break;\n  case \"有赞商城\":\n    Channelid = 10764;\n    break;\n  case \"COROS高驰微信小店\":\n    Channelid = 11049;\n    break;\n  case \"COROS高驰得物店\":\n    Channelid = 11048;\n    break;\n  case \"COROS高驰京东（供销平台）\":\n    Channelid = 10760;\n    break;\n  case \"COROS 高驰订货商城\":\n    Channelid = 11064;\n    break;\n  case \"COROS高驰智能手表旗舰店\":\n    Channelid = 11064;\n    break;\n  case \"COROS线下渠道\":\n    switch (customerName) {\n      case \"飞亚达销售有限公司\":\n        Channelid = 11066;\n        break;\n      case \"上海蔚景商贸有限公司\":\n        Channelid = 11055;\n        break;\n      case \"北京京东世纪贸易有限公司\":\n        Channelid = 10931;\n        break;\n      case \"云南九机电子产品有限公司\":\n        Channelid = 11054;\n        break;\n      case \"门店经销-迪脉（上海）企业管理有限公司\":\n        Channelid = 10866;\n        break;\n      case \"深圳市顺电连锁股份有限公司\":\n        Channelid = 11090;\n        break;\n      case \"京东闪送\":\n        Channelid = 11075;\n        break;\n      default:\n        Channelid = 10470;\n    }\n    break;\n  default:\n    Channelid = null; // 其他未匹配的情况可以设置为null或者其他默认值\n}\n\nreturn { Channel: Channelid };\n"
      },
