        "jsCode": "// Add a new field called 'myNewField' to the JSON of the item\n$input.item.json.myNewField = 1;\n\n\nlet goodsListAll=$jmespath($json.data,\"[*].goodsList[*].snList[][]\")\n\nconst goodsList = [...new Set(goodsListAll)];\n//.map(item => `\"${item.replace(/\"/g, '\"\"')}\"`) // 转义双引号\n//    .join(',');\nconst goodsListStr=`(${goodsList.map(item => `'${item.replace(/\"/g, '\"\"')}'`).join(',')})`\n\n\nlet goodsCount=goodsList?.length || 0\n\nreturn {goodsCount,goodsListStr,goodsList};"
      },
