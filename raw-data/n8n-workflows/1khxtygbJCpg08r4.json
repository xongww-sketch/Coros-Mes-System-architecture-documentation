      "parameters": {
        "jsCode": "const result = [];\nfor (const item of $input.all()) {\n  const snList = item.json.snList;\n  const length = snList.length;\n\n  // 每 100 项分为一组\n  for (let j = 0; j < length; j += 100) {\n    // slice 方法用于获取子数组\n    let temp = snList.slice(j, j + 100);\n    result.push(temp);\n  }\n}\n\nreturn {\n  snList:result\n};"
      },
