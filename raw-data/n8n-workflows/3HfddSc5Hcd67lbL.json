    {
      "parameters": {
        "jsCode": "const inputData = $input.all();\nconst integratedData = $(\"整合数据\").all();\n\n// 使用 map 返回匹配结果\nconst results = inputData.map((inputItem) => {\n  const retroid = inputItem.json.retroid;\n\n  // 在整合数据中寻找匹配的项\n  const matchedItem = integratedData.find((dataItem) => dataItem.json.sn === retroid);\n\n  if (matchedItem) {\n    // 提取jobnumber的前四位作为product_model_name\n    const productModelName = inputItem.json.jobnumber.substring(0, 4);\n    \n    // 返回匹配的数据\n    return {\n      json: {\n        sn: matchedItem.json.sn,\n        serial_id: matchedItem.json.serial_id,\n        cplc: matchedItem.json.cplc,\n        product_model_name: productModelName\n      }\n    };\n  } else {\n    // 返回未匹配到的情况\n    return {\n      json: {\n        message: `未找到匹配项: Retroid: ${retroid}`,\n        retroid: retroid\n      }\n    };\n  }\n});\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -560,
        -144
      ],
      "id": "4cf9f8cc-889d-4510-ba0d-d37b92976656",
      "name": "Code1"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    r.retroid AS sn,\n    pm.product_model_name,\n    c.serial_id,\n    c.cplc\nFROM \n    mes.retroid r \nJOIN \n    mes.joborder jo ON r.joborder_id = jo.joborder_id\nJOIN \n    mes.product_info pi ON jo.product_id = pi.product_id\nJOIN \n    mes.product_model pm ON pi.product_model_id = pm.product_model_id\nJOIN \n    mes.cplc c ON r.retroid = c.sn\nWHERE\n    c.serial_id = '{{ $json.serial_id }}'\nLIMIT 1;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -720,
        96
      ],
