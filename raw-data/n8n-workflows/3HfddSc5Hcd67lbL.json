    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH LatestCplc AS (\n    SELECT \n        serial_id, sn, cplc, create_time, status,\n        ROW_NUMBER() OVER (PARTITION BY sn, cplc ORDER BY create_time DESC) AS rn\n    FROM\n        mes.cplc\n)\nSELECT \n    serial_id,\n    sn,\n    cplc\nFROM \n    LatestCplc\nWHERE\n    rn = 1\n    AND status = '1' \n    and sn is not null\nORDER BY \n    create_time ASC\nLIMIT 500;\n",
        "options": {}
      },
