    {
      "parameters": {
        "jsCode": "const inputData = $input.all();\nconst integratedData = $('Merge').all();\n\n// 使用 map 返回每个输入数据的匹配结果\nconst results = inputData.map((inputItem) => {\n  const inputCplc = inputItem.json.respData[0].cplc;\n\n  // 寻找整合数据中匹配的项\n  const matchedItem = integratedData.find((dataItem) => dataItem.json.cplc.toLowerCase() === inputCplc.toLowerCase());\n\n  if (matchedItem) {\n    return {\n      json: {\n        sn: matchedItem.json.sn,\n        product_model_name: matchedItem.json.product_model_name,\n        serial_id: matchedItem.json.serial_id,\n        cplc: inputCplc\n      }\n    };\n  } else {\n    return {\n      json: {\n        message: `未找到匹配项: CPLT: ${inputCplc}`,\n        cplc: inputCplc\n      }\n    };\n  }\n});\n\nreturn results;\n"
      },
