    {
      "parameters": {
        "jsCode": "\n\n// 假设 $input.all() 是获取所有输入数据的方法\nconst inputData = $input.all().map(item => {\n  const sn=$(\"Webhook\").all()[0].json.body.sn;\n  return {\n    retroid:item.json.sn??sn,\n    retroid_id:item.json.retroid_id,\n    procedure_detail_id:item.json.procedure_detail_id,\n    create_time:item.json.createtime,\n    data:item.json.data\n    \n  }\n}); // 在实际使用中获取数据\nconst response = {\n  code:200,\n  data:inputData\n};\n\n// 返回处理后的结果\nreturn response;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        440
      ],
      "id": "6d6b34a5-8064-42e2-836b-afe6c4ac0869",
      "name": "转换格式",
      "alwaysOutputData": true,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "id": "b47e1693-6d06-4556-a037-607025b8f6b1",
              "leftValue": "={{ $json.code }}",
              "rightValue": 2,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -980,
        360
      ],
      "id": "c4472cbe-d19c-4330-a5af-7f75dcc76ea7",
      "name": "If1"
    },
    {
      "parameters": {
        "jsCode": "// 遍历输入项并处理每条数据\nlet result = {\n    code: 0,\n    message: '处理成功'\n};\n\nfor (const item of $input.all()) {\n    const requestData = item.json.body;\n    \n    // 校验工序ID必填\n    if (!requestData.procedure_detail_id) {\n        return {\n            code: 1,\n            message: '请选择工序！',\n            data: null\n        };\n    }\n    \n    // 判断SN和工单号哪个存在\n    if (requestData.sn) {\n        result = {\n            code: 2,\n            sn: requestData.sn,\n            procedure_id: requestData.procedure_id  // 保留工序ID\n        };\n    } else if (requestData.jobNumber) {  // 修正了原代码中的拼写错误\n        result = {\n            code: 3,\n            jobNumber: requestData.jobNumber,\n            procedure_id: requestData.procedure_id  // 保留工序ID\n        };\n    } else {\n        return {\n            code: 4,\n            message: '必须提供SN或工单号',\n            data: null\n        };\n    }\n    \n    // 如果只需要处理第一条有效数据就跳出循环\n    break;\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1460,
        400
      ],
      "id": "51c42830-8f84-4a8c-98b2-cedf2e210eeb",
      "name": "判断查询整个工单号还是查询单独的SN"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "\nselect  m.retroid_id,r.retroid as sn,m.data,m.createtime,m.procedure_detail_id \nFROM mes.mes.machine_data m JOIN mes.mes.retroid as r on m.retroid_id=r.retroid_id\nWHERE \n  m.data->>'jobNumber' = '{{ $json.jobNumber }}' \n  AND m.procedure_detail_id = {{ $('Webhook').all()[0].json.body.procedure_detail_id }}\n  -- 修正：移除子查询中的 procedure_detail_id 限制，确保检测所有删除标记\n  AND not EXISTS (\n      SELECT * \n    FROM mes.mes.machine_data m2 \n    WHERE \n      m2.retroid_id=m.retroid_id and\n      (m2.data::jsonb) ? 'machine_data_id_old'  -- 删除标记识别条件\n      and (m2.data->>'procedure_detail_id_old')::integer = {{ Number($('Webhook').all()[0].json.body.procedure_detail_id) }}\n      and m2.createtime>m.createtime\n  )\n  ORDER BY m.createtime ASC \n  \n ",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
