        "query": "SELECT package_id, package_name, package_version, package_remarks, package_path, create_time,COUNT(*) OVER() AS total_count FROM mes.installation_package where is_delete=0 {{ $json.sqlStr }} order by create_time DESC limit {{$json.pageSize}} OFFSET {{ $json.offset }};",
