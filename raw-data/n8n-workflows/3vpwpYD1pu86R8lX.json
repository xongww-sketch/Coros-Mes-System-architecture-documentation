    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n//判断查询的条件是否存在\n//构建查询的SQL语句\nconst sqlParams={};\nfor (const item of $input.all()) {\n  const packageName = item.json.query.packageName;\nconst packageVersion = item.json.query.packageVersion;\nlet conditions = [];\n\nif (packageName) {\n  conditions.push(`package_name ='${packageName}'`);\n}\nif (packageVersion) {\n  conditions.push(`package_version='${packageVersion}'`);\n}\n\nsqlParams.sqlStr = conditions.length ? `and ${conditions.join(' and ')}` : '';\nconst offset=(item.json.query.pageNo-1)*item.json.query.pageSize;\nsqlParams.offset=offset;\nsqlParams.pageSize=item.json.query.pageSize;\n}\n\nreturn sqlParams;"
      },
