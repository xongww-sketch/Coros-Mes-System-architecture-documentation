      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n\n//使用set进行数组去重\nfor (const item of $input.all()) {\n  const pkNameList=item.json.pkNameList;\n  const pkVersionList=item.json.pkVersionList;\n  const newPkNameList=[...new Set(pkNameList)].map((item,index)=>{\n    return {\n      code:index,\n      name:item\n    }\n  });\n  const newVerList=[...new Set(pkVersionList)].map((item,index)=>{\n    return {\n      code:index,\n      name:item\n    }\n  });\n  item.json.pkNameList=newPkNameList;\n  item.json.pkVersionList=newVerList;\n}\n\nreturn $input.all();"
      },
