    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select data::JSONB->'sn' as sn,data::JSONB->'uuid' as uuid, data ->>'uuid_unique' as uuid_unique FROM mes.mes.machine_data WHERE procedure_detail_id={{ $json.procedure_detail_id }}\n    AND LOWER(data::JSONB->>'uuid') = LOWER('{{ $('Webhook').all()[0].json.body.uuid }}') OR LOWER(data ->>'uuid_unique') = LOWER('{{ $('Webhook').all()[0].json.body.uuid.slice(0, 16) + $('Webhook').all()[0].json.body.uuid.slice(18) }}') order BY createtime DESC limit 1;",
