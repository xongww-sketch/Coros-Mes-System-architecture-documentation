    {
      "parameters": {
        "jsCode": "function formatDate(date) {\n  const y = date.getFullYear();\n  const m = String(date.getMonth() + 1).padStart(2, '0');\n  const d = String(date.getDate()).padStart(2, '0');\n  return `${y}${m}${d}`;\n}\n\nfunction addMonths(date, n) {\n  const newDate = new Date(date);\n  newDate.setMonth(newDate.getMonth() + n);\n  // 防止跨月产生日期溢出\n  if (newDate.getDate() !== date.getDate()) {\n    newDate.setDate(0);\n  }\n  return newDate;\n}\n\nconst startDateStr = '20250425';\nconst startDate = new Date(\n  Number(startDateStr.substring(0, 4)),\n  Number(startDateStr.substring(4, 6)) - 1,\n  Number(startDateStr.substring(6, 8))\n);\n\nconst today = new Date();\nconst arr = [];\n\nlet currentBegin = startDate;\n\nwhile (currentBegin < today) {\n  let currentEnd = addMonths(currentBegin, 1);\n  \n  // 如果 currentEnd 超过今天，则用今天作为结束日期\n  if (currentEnd > today) {\n    currentEnd = today;\n  }\n  \n  arr.push({\n    beginTime: formatDate(currentBegin),\n    endTime: formatDate(currentEnd),\n  });\n  \n  currentBegin = currentEnd;\n}\n\nreturn {\n  timeArr: arr\n};"
      },
