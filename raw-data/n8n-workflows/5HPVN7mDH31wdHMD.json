    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n//规则数组\nlet ruleArr=[13000,13001,13002,13003,13004]\nlet res=[];\nfor (const item of $input.all()) {\n  const children = [...item.json.children].sort((a, b) => \n  b.ERDAT.localeCompare(a.ERDAT)\n)[0];\n  \n  if(ruleArr.includes(Number(children.MATNR.substring(0,5)))){\n    item.json.material_description=children.IDNKX;\n    res.push(item);\n  }\n}\nreturn res"
      },
