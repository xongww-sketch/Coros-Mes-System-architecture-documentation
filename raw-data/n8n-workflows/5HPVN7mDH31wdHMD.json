    {
      "parameters": {
        "jsCode": "// 使用流式处理替代全量合并\nlet allSuccess = true;\nlet errorMessages = [];\nlet processedCount = 0;\nlet batchSize = 100; // 每批处理100条记录\nlet outputBatches = [];\n\ntry {\n    // 分批次处理数据\n    for (let i = 0; i < items.length; i += batchSize) {\n        const batch = items.slice(i, i + batchSize);\n        let batchResults = [];\n        \n        for (const item of batch) {\n            processedCount++;\n            \n            // 检查数据有效性\n            if (!item?.json?.ET_OUTPUT) {\n                allSuccess = false;\n                errorMessages.push(`Item ${processedCount} missing ET_OUTPUT`);\n                continue;\n            }\n            \n            if (item.json.E_TYPE !== \"S\") {\n                allSuccess = false;\n                errorMessages.push(`Item ${processedCount} has E_TYPE=${item.json.E_TYPE}`);\n                continue;\n            }\n            \n            // 添加有效数据到批次\n            batchResults.push(...item.json.ET_OUTPUT);\n        }\n        \n        // 存储当前批次结果\n        if (batchResults.length > 0) {\n            outputBatches.push({\n                batchIndex: Math.floor(i / batchSize) + 1,\n                data: batchResults\n            });\n        }\n        \n        // 可选: 每处理完一批就释放内存\n        batchResults = null;\n    }\n\n    // 准备最终输出\n    if (allSuccess) {\n        // 返回成功和所有批次数据\n        return [{\n            json: {\n                tag: 0,\n                batchCount: outputBatches.length,\n                batches: outputBatches,\n                totalProcessed: processedCount\n            }\n        }];\n    } else {\n        // 返回失败和错误详情\n        return [{\n            json: {\n                tag: 1,\n                errorCount: errorMessages.length,\n                errors: errorMessages.slice(0, 10), // 只返回前10个错误\n                batchesProcessed: outputBatches.length,\n                totalProcessed: processedCount\n            }\n        }];\n    }\n} catch (error) {\n    return [{\n        json: {\n            tag: 2,\n            error: error.message,\n            processedUpTo: processedCount\n        }\n    }];\n}"
      },
