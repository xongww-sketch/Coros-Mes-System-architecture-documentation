    {
      "parameters": {
        "jsCode": "// Initial data\nlet timestap = [\n  {\"ERDAT_B\":\"20250201\",\"ERDAT_E\": \"20250801\"},\n  // {\"ERDAT_B\":\"20250401\",\"ERDAT_E\": \"20250601\"},\n];\n\n// Get current date (YYYYMMDD)\nconst today = new Date();\nconst year = today.getFullYear();\nconst month = String(today.getMonth() + 1).padStart(2, '0');\nconst day = String(today.getDate()).padStart(2, '0');\nconst currentDate = `${year}${month}${day}`;\n\n// Check if we need to add new ranges\nconst lastEntry = timestap[timestap.length - 1];\nconst lastDate = lastEntry.ERDAT_E;\n\nif (currentDate > lastDate) {\n  // Parse the last end date\n  const lastYear = parseInt(lastDate.slice(0, 4));\n  const lastMonth = parseInt(lastDate.slice(4, 6));\n  const lastDay = parseInt(lastDate.slice(6, 8));\n  \n  // Calculate 2 months after the last end date\n  let nextMonth = lastMonth + 2;\n  let nextYear = lastYear;\n  \n  if (nextMonth > 12) {\n    nextMonth -= 12;\n    nextYear += 1;\n  }\n  \n  const nextMonthStr = String(nextMonth).padStart(2, '0');\n  const nextDate = `${nextYear}${nextMonthStr}01`;\n  \n  if (currentDate > nextDate) {\n    // Add the 2-month interval first\n    timestap.push({\n      \"ERDAT_B\": lastDate,\n      \"ERDAT_E\": nextDate\n    });\n    \n    // Then add the interval from nextDate to currentDate\n    timestap.push({\n      \"ERDAT_B\": nextDate,\n      \"ERDAT_E\": currentDate\n    });\n  } else {\n    // Just add from lastDate to currentDate\n    timestap.push({\n      \"ERDAT_B\": lastDate,\n      \"ERDAT_E\": currentDate\n    });\n  }\n}\n\n// Return the final result\nreturn timestap;"
      },
