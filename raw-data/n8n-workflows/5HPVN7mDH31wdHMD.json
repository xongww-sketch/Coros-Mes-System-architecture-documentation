      "id": "902a11ba-67ce-4b9f-b194-73628e98c99a",
      "name": "拆分所有包含镭雕字段物料描述的数组1"
    },
    {
      "parameters": {
        "jsCode": "// 性能优化版本\nconst sapData = $('判断SAP是否成功返回数据1').first().json.batches[0].data;\n\n// 1. 使用Map建立索引（性能关键点）\nconst materialCodeMap = new Map();\nif (Array.isArray(sapData)) {\n  sapData.forEach(item => {\n    if (item?.PLNBEZ) {\n      const code = item.PLNBEZ;\n      if (!materialCodeMap.has(code)) {\n        materialCodeMap.set(code, []);\n      }\n      materialCodeMap.get(code).push(item);\n    }\n  });\n}\n\n// 2. 批量处理输入数据\nreturn $input.all().map(item => {\n  const children = materialCodeMap.get(item.json.material_code) || [];\n  return {\n    json: {\n      ...item.json,\n      children: children.slice(0, 1000) // 限制最大数量防止内存爆炸\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -48,
        4096
      ],
      "id": "fdbbaef7-9af3-4b51-a24b-9d1c1c91daa7",
