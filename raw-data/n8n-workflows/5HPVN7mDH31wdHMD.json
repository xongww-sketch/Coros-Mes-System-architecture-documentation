    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst res={};\nfor (const item of $input.all()) {\n  const arr=item.json.others;\n  var newArr=arr.filter(e=>e.material_description.includes('镭雕'))\n}\nres.arr=newArr;\nreturn res;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -560,
        4096
