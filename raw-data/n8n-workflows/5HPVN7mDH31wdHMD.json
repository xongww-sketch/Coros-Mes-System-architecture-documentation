    {
      "parameters": {
        "jsCode": "// 数据源\nconst orderList = $(\"Aggregate3\").all()[0]?.json?.orderList ?? [];\nconst inputItems = $input.all() ?? [];\n\nconst toNum = (v) => {\n  const n = Number(v ?? 0);\n  return Number.isNaN(n) ? 0 : n;\n};\n\nconst hasInput = inputItems.length > 0;\nconst result = hasInput ? [...inputItems] : [];\n\n\nconst getJson = (it) => it?.json ?? {};\n\nconst orderMap = new Map(orderList.map(o => [o.order_number, o]));\nconst inputMap = {};\nfor (const it of inputItems) {\n  const w = it?.json?.work_order_number;\n  if (w) inputMap[w] = it;\n}\n\n// 处理现有数据并更新/标记\nfor (const it of inputItems) {\n  const json = it?.json;\n  if (!json) continue;\n\n  const order = orderMap.get(json.work_order_number);\n\n  if (order) {\n    const isSame =\n      order.material_description === json.material_description &&\n      toNum(order.production_quantity) === toNum(json.production_quantity) &&\n      order.production_date === json.production_date &&\n      order.base_bom_code === json.base_bom_code &&\n      order.production_end_date === json.production_end_date &&\n      String(order.zecnl4 ?? '') === String(json.zecnl4 ?? '');\n\n    if (isSame) {\n      const complete = toNum(order.production_quantity) === toNum(order.receive_sum);\n      if (complete&&json.order_status!==0) {\n        json.is_update = 1;\n        json.order_status = 0;\n      } else {\n        json.is_update = 0; // 无变化\n      }\n    } else {\n      // 用后端订单数据覆盖输入数据（包括 zecnl4），保持一致性\n      Object.assign(json, {\n        material_description: order.material_description,\n        production_quantity: order.production_quantity,\n        base_bom_code: order.base_bom_code,\n        production_date: order.production_date,\n        production_end_date: order.production_end_date,\n        zecnl4: order.zecnl4,\n        is_update: 1\n      });\n    }\n  } else {\n    // 未在 orderList 中找到的项\n    json.is_update = 1;\n    json.order_status = 0;\n  }\n}\n\n// 添加新数据（orderList 中存在、但 input 中不存在的项）\nfor (const order of orderList) {\n  if (!inputMap[order.order_number]) {\n    result.push({\n      json: {\n        material_code: order.material_code,\n        material_description: order.material_description,\n        base_bom_code: order.base_bom_code,\n        type: order.type,\n        order_status: order.order_status,\n        work_order_number: order.order_number,\n        order_create_time: order.order_create_time,\n        production_quantity: order.production_quantity,\n        production_date: order.production_date,\n        production_end_date: order.production_end_date,\n        zecnl4: order.zecnl4,\n        is_update: 1\n      }\n    });\n  }\n}\n\nreturn result;"
      },
