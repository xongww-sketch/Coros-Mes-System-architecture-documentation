    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH latest_history AS (\n    -- 已选择最新的记录并展开数组\n    SELECT json_array_elements_text(procedure_detail_id->'procedure_detail_id')::int AS detail_id\n    FROM mes.history_procedure_list\n    WHERE history_procedure_list_id = (\n        -- 获取最新记录的 id\n        SELECT history_procedure_list_id\n        FROM mes.history_procedure_list\n        WHERE history_procedure_list_id = '{{ $json.history_procedure_list_id }}' \n        ORDER BY createtime DESC\n        LIMIT 1\n    )\n)\n-- 使用 DISTINCT ON 获取每个 detail_id 的最新记录\nSELECT DISTINCT ON (hpd.procedure_detail_id) hpd.*\nFROM mes.history_procedure_detail hpd\nWHERE hpd.procedure_detail_id IN (\n    SELECT detail_id FROM latest_history\n)\nAND hpd.procedure_dataupload = 2\nORDER BY hpd.procedure_detail_id, hpd.createtime DESC;",
        "options": {}
      },
