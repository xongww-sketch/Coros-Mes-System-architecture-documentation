    {
      "parameters": {
        "jsCode": "function generateResponse(inputData) {\n  const procedure_detail_id = $input.first().json.procedure_detail_id;\n  let status = '绑定'; // 最新绑定数据\n  \n  const bindingHistory = inputData.map(item => {\n    if (procedure_detail_id == 62) {\n      status = '解绑';//已经解绑\n    }\n    \n    return {\n      \"SN\": $input.first().json.data.sn||$input.first().json.data.retroid|| $input.first().json.data.data_old.sn ||$input.first().json.data.data_old.retroid,\n      \"procedure_name\": $input.first().json.data.procedure_name|| $input.first().json.data.data_old.procedure_name,\n      \"createtime\": $input.first().json.createtime,\n      \"status\": status // 返回最终的 status 值\n    };\n  });\n\n  return {\n    \"code\": \"200\",\n    \"msg\": \"ok\",\n    \"binding_history\": bindingHistory\n  };\n}\n\nconst inputData = $input.all().filter(item => item.json.machine_data_id);\nconst response = generateResponse(inputData);\n\nreturn response;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        -120
      ],
      "id": "e3d4acad-a3b2-4b58-a689-b15a3b13fb25",
      "name": "Code"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": " SELECT * FROM mes.machine_data md \nWHERE ((md.data ->> 'bind_id')::text = '{{ $('去除所有换行符').item.json.body.bind_id }}' OR (md.data  ->> 'unbind_id')::text = '{{ $('去除所有换行符').item.json.body.bind_id }}')\nAND md.procedure_detail_id IN ('{{ $('获取工序id').item.json.data[0].procedure_detail_id }}','62')\nAND retroid_id = '{{ $('查绑定的SN').item.json.retroid_id }}'\norder by md.createtime desc\nlimit 1",
        "options": {}
      },
