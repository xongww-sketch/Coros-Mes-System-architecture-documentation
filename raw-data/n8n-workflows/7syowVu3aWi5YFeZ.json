      "id": "3c3fa90e-d052-4692-bf81-22e199433b5f",
      "name": "提取表格内容"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.all();\nconst list = input?.[0]?.json?.retroid_list ?? [];\n\n// 提取SN并去重\nconst sns = [...new Set(\n  list\n    .map(x => (x?.sn ?? '').trim())\n    .filter(Boolean)\n)];\n\n// 生成SQL IN (...) 字符串，注意单引号转义\nconst snInSql = sns\n  .map(sn => `'${sn.replace(/'/g, \"''\")}'`)\n  .join(', ');\n\n// 没有SN时兜底\nif (!snInSql) {\n  return [{\n    json: {\n      sql: `-- no SN provided\nselect null where false;`\n    }\n  }];\n}\n\n// 生成最终SQL\nconst sql = `\nwith r as (\n  select retroid_id, retroid\n  from mes.retroid\n  where status in (1,2)\n    and retroid in (${snInSql})\n),\nmd as (\n  select\n    m.machine_data_id,\n    m.retroid_id,\n    m.procedure_detail_id,\n    m.history_procedure_id,\n    m.data,\n    m.createtime,\n    row_number() over (partition by m.retroid_id order by m.createtime desc) as rn\n  from mes.machine_data m\n  join r on r.retroid_id = m.retroid_id\n  where m.procedure_detail_id = 59\n)\nselect\n  r.retroid as sn,\n  r.retroid_id,\n  md.machine_data_id,\n  md.history_procedure_id,\n  md.procedure_detail_id,\n  md.createtime,\n  md.data\nfrom r\nleft join md on md.retroid_id = r.retroid_id and md.rn = 1\norder by r.retroid;\n`.trim();\n\nreturn [{\n  json: {\n    sns,\n    sql\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        -64
      ],
      "id": "e6b78855-e98a-4a85-ace7-c2a7a23a209f",
