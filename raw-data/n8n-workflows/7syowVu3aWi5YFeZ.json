        "resumeUnit": "minutes",
        "options": {
          "formTitle": "请输入新的备注信息",
          "formDescription": "=本次一共修改{{$json.founded}}个SN。其中原来的备注为{{$('Merge').first().json.data.remark}},其中{{$json.unfounded}}个sn不存在，分别为：\"{{$json.unfoundedSnList}}\",因此无法新增备注。\n请确认无误后，点击提交按钮。",
          "buttonLabel": "提交"
        }
      },
