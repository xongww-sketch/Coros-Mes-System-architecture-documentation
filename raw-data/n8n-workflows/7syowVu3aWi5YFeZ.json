    {
      "parameters": {
        "jsCode": "// n8n Code 节点（JavaScript）\n// 输出 1 条结果：数量统计 + unfounded 的 sn 列表\n\nlet unfounded = 0;\nlet founded = 0;\nconst unfoundedSnList = [];\n\nfor (const item of items) {\n  const obj = item.json || {};\n  const keys = Object.keys(obj);\n\n  const onlySn =\n    keys.length === 1 &&\n    keys[0] === \"sn\" &&\n    obj.sn !== undefined &&\n    obj.sn !== null &&\n    obj.sn !== \"\";\n\n  if (onlySn) {\n    unfounded++;\n    unfoundedSnList.push(obj.sn);\n  } else {\n    founded++;\n  }\n}\n\nreturn [\n  {\n    json: {\n      unfounded,\n      founded,\n      total: unfounded + founded,\n      unfoundedSnList,\n    },\n  },\n];"
      },
