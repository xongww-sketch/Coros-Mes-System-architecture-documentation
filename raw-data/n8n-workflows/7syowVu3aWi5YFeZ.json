        896,
        48
      ],
      "id": "9558a938-b642-494b-89af-3f386d9d6751",
      "name": "确认更改",
      "webhookId": "c1878372-db21-4428-aa8e-9055878345e1"
    },
    {
      "parameters": {
        "jsCode": "// 1) 取入参\nconst input = $input.all();\nconst newRemark = input?.[0]?.json?.[\"新的备注信息\"];\n\nif (!newRemark) {\n  throw new Error('入参缺少字段：\"新的备注信息\"');\n}\n\n// 2) 取“查询原有绑定记录”节点数据\nconst oldItems = $(\"查询原有绑定记录\").all();\n\n// 3) 更新 remark / bind_id\nreturn oldItems.map(item => {\n  // 深拷贝（兼容）\n  const j = JSON.parse(JSON.stringify(item.json));\n\n  if (!j.data) j.data = {};\n\n  j.data.remark = newRemark;\n  j.data.bind_id = newRemark;\n\n  return { json: j };\n});"
      },
