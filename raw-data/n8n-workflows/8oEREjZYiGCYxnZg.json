    {
      "parameters": {
        "jsCode": "// 获取“查找retroid_id并校验sn是否正确”节点的retroid_id\nconst retroidIdData = $('查找retroid_id并校验sn是否正确1').all();\nconst retroidId = retroidIdData[0].json.retroid_id;\n\n// 获取“查询工序id”节点的数据\nconst procedureData = $('查询工序id1').all();\nconst procedureDetailId = procedureData[0].json.data[0].procedure_detail_id;\nconst historyProcedureId = procedureData[0].json.data[0].history_procedure_id;\n\n// 获取“Webhook”节点中query的数据，并将\"bind_id\"加入\nconst webhookData = $('Webhook').all();\nconst queryData = webhookData[0].json.body;\nqueryData.bind_id = $('将结果内空格、换行去除1').all()[0].json.body.battery_id;\n\n// 组织数据为一个对象\nconst result = {\n  retroid_id: retroidId,\n  procedure_detail_id: procedureDetailId,\n  history_procedure_id: historyProcedureId,\n  ...queryData\n};\n\nreturn result;\n"
      },
