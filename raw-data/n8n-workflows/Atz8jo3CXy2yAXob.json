    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n\nlet validationResult={};\nfor (const item of $input.all()) {\n  validationResult = validateParams(item.json.body);\n}\nfunction validateParams(params) {\n  const errors = [];\n\n  // 校验 retroid\n  if (!params.hasOwnProperty('retroid')) {\n    errors.push('缺少必要字段: retroid');\n  } else {\n    if (typeof params.retroid !== 'string') {\n      errors.push('retroid 必须为字符串类型');\n    } else if (![10, 16].includes(params.retroid.length)) {\n      errors.push('retroid 必须是16位字符串或者10位字符串');\n    } \n  }\n\n  // 校验 procedure_id\n  if (!params.hasOwnProperty('procedure_id')) {\n    errors.push('缺少必要字段: procedure_id');\n  } else {\n    if (!Number.isInteger(params.procedure_id)) {\n      errors.push('procedure_id 必须为整数');\n    } else if (params.procedure_id < 1) {\n      errors.push('procedure_id 必须大于0');\n    }\n  }\n\n  // 校验 type\n  if (!params.hasOwnProperty('type')) {\n    errors.push('缺少必要字段: type');\n  } else {\n    if (!Number.isInteger(params.type)) {\n      errors.push('type 必须为整数');\n    } else if (![1, 2, 3].includes(params.type)) { // 假设合法类型为1,2,3\n      errors.push('type 必须是1,2,3中的一个');\n    }\n  }\n\n  return {\n    isValid: errors.length === 0,\n    errors: errors\n  };\n}\n\n\nreturn validationResult;"
      },
