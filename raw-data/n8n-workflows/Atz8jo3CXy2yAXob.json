        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n  const dateObj = parseDateString(item.json.name);\n  item.json.timestamp=Math.floor(dateObj.getTime()/1000);\n}\n// 辅助函数：将 YYYYMMDDHHMMSS 字符串解析为 Date 对象\nfunction parseDateString(dateString) {\n    const year = parseInt(dateString.substring(0, 4), 10);       // 年份\n    const month = parseInt(dateString.substring(4, 6), 10) - 1;  // 月份（0-11），所以减 1\n    const day = parseInt(dateString.substring(6, 8), 10);        // 日期\n    const hour = parseInt(dateString.substring(8, 10), 10);      // 小时\n    const minute = parseInt(dateString.substring(10, 12), 10);   // 分钟\n    const second = parseInt(dateString.substring(12, 14), 10);   // 秒\n\n    // 创建 Date 对象（本地时间）\n    return new Date(year, month, day, hour, minute, second);\n}\nreturn $input.all();"
      },
