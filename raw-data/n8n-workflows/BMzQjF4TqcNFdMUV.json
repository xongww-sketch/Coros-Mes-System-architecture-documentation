    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  v.id, \n  v.retroid,\n  v.procedure,\n  v.path,\n  v.create_time,\n  v.uuid_unique,\n  COUNT(*) OVER() AS total_count \nFROM \n  mes.video_info v \nWHERE \n  v.is_delete = 0 {{ $json.sqlStr }} order by v.create_time DESC limit {{$json.pageSize}} OFFSET {{ $json.offset }};",
        "options": {}
      },
      "id": "badc193a-1eb3-4627-aa71-9f3eaff0e0b8",
