      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n//判断查询的条件是否存在\n//构建查询的SQL语句\nconst sqlParams={};\nfor (const item of $input.all()) {\n  const retroid = item.json.query.retroid; //序列号\n  const procedure = item.json.query.procedure; //工序\n  const beginTime = item.json.query.beginTime; //开始时间\n  const endTime=item.json.query.endTime;\n   const ID=item.json.query.ID;\n  // 结束时间\nlet conditions = [];\n\nif (procedure) {\n  conditions.push(`v.procedure='${procedure}'`);\n}\n   if (ID) {\n  conditions.push(`v.uuid_unique like '${ID}%'`);\n}\nif (retroid) {\n  conditions.push(`v.retroid like '%${retroid}%'`);\n}\n  if (beginTime) {\n  conditions.push(`v.create_time>=${beginTime}`);\n}\n  if (endTime) {\n  conditions.push(`v.create_time<=${endTime}`);\n}\n\nsqlParams.sqlStr = conditions.length ? `and ${conditions.join(' and ')}` : '';\nconst offset=(item.json.query.pageNo-1)*item.json.query.pageSize;\nsqlParams.offset=offset;\nsqlParams.pageSize=item.json.query.pageSize;\n}\n\nreturn sqlParams;"
      },
