      "parameters": {
        "operation": "executeQuery",
        "query": "BEGIN TRANSACTION;\n\nBEGIN TRY\n    -- 插入第一条语句\n    INSERT INTO mes2024.dbo.consm_deviceweight(jobnumber,ordernumber,productcode,barcode,objweight,objuplimitweight,objlowlimitweight,isusercheck,createtime)\n    VALUES ('{{ $json.jobnumber }}', '{{ $json.ordernumber }}','{{ $json.productcode }}','{{ $json.barcode }}','{{ $json.objweight }}','{{ $json.objuplimitweight }}','{{ $json.objlowlimitweight }}','{{ $json.isusercheck }}','{{ $json.createtime }}');\n\n    -- 插入第二条语句\n    INSERT INTO mes2024.dbo.consm_barcodeprocedure (jobnumber, ordernumber, productcode, barcode, clientprocedure, clientcode, isstateok, createtime) VALUES('{{ $json.jobnumber }}', '{{ $json.ordernumber }}', '{{ $json.productcode }}', '{{ $json.barcode }}',{{ $json.clientprocedure }}, '{{ $json.clientcode }}', {{ $json.isstateok }}, '{{ $json.createtime }}');\n\n    -- 如果两条插入语句都成功，提交事务\n    COMMIT TRANSACTION;\nEND TRY\n  BEGIN CATCH\n    -- 捕获并立即回滚事务\n    IF @@TRANCOUNT > 0\n    BEGIN\n        ROLLBACK TRANSACTION;\n        PRINT '事务回滚成功';\n    END\n\n    -- 捕获并打印错误信息\n    SELECT \n        ERROR_NUMBER() AS ErrorNumber,\n        ERROR_SEVERITY() AS ErrorSeverity,\n        ERROR_STATE() AS ErrorState,\n        ERROR_PROCEDURE() AS ErrorProcedure,\n        ERROR_LINE() AS ErrorLine,\n        ERROR_MESSAGE() AS ErrorMessage;\nEND CATCH;\n\n\n \n"
