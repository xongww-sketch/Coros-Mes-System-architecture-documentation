  "nodes": [
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst item=$input.all()[0].json.body;\n//声明异常返回对象\nlet errMsg=null;\nconst options = {\n    year: 'numeric',\n    month: '2-digit',\n    day: '2-digit',\n    hour: '2-digit',\n    minute: '2-digit',\n    second: '2-digit',\n    timeZone: 'Asia/Shanghai'\n  };\n\n//机型与SN前3位对应关系\nvar prefixToModelMap = {\n  \"B13\": \"B13\",\n  \"B15\": \"B15\",\n  \"V16\": \"B16\",\n  \"B17\": \"B17\",\n  \"M18\": \"B18\",\n  \"V19\": \"B19\",\n  \"V09\": \"B19S\",\n  \"M04\": \"M1D\",\n  \"B05\": \"B15D\",\n  \"H31\": \"HR31\",\n  \"F05\": \"FD05\",\n  \"P05\": \"FD05充电盒\",\n  \"C01\": \"BY01\",\n  \"B20\": \"B20\",\n  \"B21\": \"B21\",\n  \"M02\": \"M1S\",\n  \"W31\": \"W331\",\n  \"BY0\": \"BY01\",\n  \"W32\":\"W332\",\n  \"F02\":\"FD02\",\n \"F03\":\"FD03\",}\n//1.检查重量是否在上下限范围内\nif ((item.weight > item.config.limitMax || item.weight < item.config.limitMin) && !item.force) {\n  errMsg = '重量超过设置重量上下限！';\n}\n\n//2.检查sn是否是当前工单\nif(item.sn.length===16){\n  if(item.sn.slice(0,10)!==item.config.ticketNo){\n    errMsg='该SN不属于当前工单！';\n  }\n}else{\n  //3.检查这个sn是否属于这个机型\nconst type=prefixToModelMap[item.sn.slice(0,3)];\nconst orderType=item.config.orderNumber.slice(0,-4);\nif (type!==orderType&&orderType.slice(0,2)!=='SH'&&orderType!=='TYYJ') {\n  errMsg='该SN不属于当前订单！'\n}\n}\n\nif(errMsg!=null){\n  return {\n    errMsg:errMsg\n  }\n}else{\n  return {\n    objweight:item.weight+'g',\n    barcode:item.sn,\n    productcode:item.config.type,\n    ordernumber:item.config.orderNumber,\n    ticketNo:item.config.ticketNo,\n    objuplimitweight:item.config.limitMax+'g',\n    objlowlimitweight:item.config.limitMin+'g',\n    createtime:new Date().toLocaleString('zh-CN', options),\n    isusercheck:0,\n    isstateok:1,\n    clientcode:'CasketWeightClient',\n    clientprocedure:1\n  }\n}"
      },
