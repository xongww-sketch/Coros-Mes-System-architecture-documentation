    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    j.product_quantity AS target_quantity, -- 工单目标数量\n    (\n        SELECT count(DISTINCT m1.retroid_id) \n        FROM mes.machine_data m1\n        WHERE \n            -- 关联条件：使用外层工单号匹配 machine_data 中的 ticketNo\n            m1.data->>'ticketNo' = j.joborder_number\n            -- 传入的工序ID参数\n            AND m1.procedure_detail_id = 79\n            -- 排除旧数据标记\n            AND NOT (m1.data::jsonb) ? 'data_old'\n            -- 排除被标记为删除(retroactive delete)的数据\n            AND NOT EXISTS (\n                SELECT 1 \n                FROM mes.machine_data m2 \n                WHERE \n                    m2.retroid_id = m1.retroid_id \n                    AND m2.procedure_detail_id = 91\n                    AND m2.data->>'procedure_detail_id_old' = '79'\n                    AND m2.createtime > m1.createtime\n            )\n    ) AS current_count -- 实际计算出的数量\nFROM \n    mes.joborder j\nWHERE \n    j.joborder_number = '{{ $json.body.data.ticketNo }}' \n    AND j.status = 1;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        752,
        544
      ],
      "id": "25aa18e1-4c09-432b-82c0-8f1d1f1805d1",
