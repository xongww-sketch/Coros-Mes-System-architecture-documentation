    {
      "parameters": {
        "jsCode": "// 获取所有输入项\nconst inputItems = $input.all();\n\n// 检查是否有输入项\nif (inputItems.length === 0) {\n  // 如果没有输入项，返回空或错误信息\n  return [{ json: { error: \"No input items received\" } }];\n}\n\n// 获取第一个item的retroid_id\nconst firstItem = inputItems[0];\nconst retroidId = firstItem.json.retroid_id;\n\n// 返回结果\nreturn [{ \n  json: {\n    first_retroid_id: retroidId,\n    // 可选：包含一些原始数据用于调试\n    original_first_item: firstItem.json\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        224
      ],
      "id": "2a490a9e-0c89-45e3-9725-511509c99e88",
      "name": "Code3"
    },
    {
      "parameters": {
        "jsCode": "// 从 Execute Workflow 节点中提取所有数据。假设这里只有一个执行输出，且数据符合描述\nconst executeWorkflowData = $('查工序id通用接口').all().reduce((acc, item) => {\n  if (Array.isArray(item.json.data)) {\n    acc.push(...item.json.data);\n  }\n  return acc;\n}, []);\n\n// 从所有输入获得数据\nconst inputData = $input.all();\n\n// 假定 executeWorkflowData 中的数据是可以映射到 inputData 的\nconst enhancedResults = inputData.map(inputItem => {\n  const inputJson = inputItem.json;\n\n  // 获取 Execute Workflow 数据中的第一个 entry 的 procedure_detail_id 和 history_procedure_id\n  // 这是基于你给定的结构，确保这是你想要的对应关系。\n  const procedureData = executeWorkflowData.find(item => item.procedure_detail_id !== undefined);\n\n  if (procedureData) {\n    // 将需要的字段合并到输入的元素中\n    return {\n      json: {\n        ...inputJson,\n        procedure_detail_id: procedureData.procedure_detail_id,\n        history_procedure_id: procedureData.history_procedure_id\n      }\n    };\n  }\n\n  // 如果没有找到匹配的，返回未修改的 item\n  return { json: inputJson };\n});\n\n// 输出最终合并的结果\nreturn enhancedResults;\n"
      },
