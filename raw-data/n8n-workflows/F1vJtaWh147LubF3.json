    {
      "parameters": {
        "jsCode": "// 从PostgreSQL节点获取所有现有区间数据（兼容混合结构）\nconst existingIntervals = items.map(item => {\n  // 兼容两种数据结构：优先取data内的值，没有则取顶层值\n  const data = item.json.data || item.json;\n  return {\n    start: parseInt(data.beginseries, 10),  // 转换为数字\n    end: parseInt(data.endseries, 10)      // 转换为数字\n  };\n});\n\n// 获取输入的区间（兼容字符串转数字）\nconst inputData = $('Webhook').first().json.body\nconst newInterval = {\n  start: parseInt(inputData.beginseries, 10),\n  end: parseInt(inputData.endseries, 10)\n};\n\n// 优化后的重叠检测函数\nconst findOverlaps = (existing, newInt) => {\n  const overlaps = [];\n  \n  // 验证输入区间有效性\n  if (isNaN(newInt.start) || isNaN(newInt.end)) {\n    throw new Error(\"区间值必须是数字\");\n  }\n  if (newInt.start > newInt.end) {\n    throw new Error(`非法区间：起始值(${newInt.start})不能大于结束值(${newInt.end})`);\n  }\n\n  existing.forEach(item => {\n    const overlapStart = Math.max(item.start, newInt.start);\n    const overlapEnd = Math.min(item.end, newInt.end);\n    \n    if (overlapStart <= overlapEnd) {\n      overlaps.push({\n        existingInterval: `${item.start}-${item.end}`,\n        overlapPart: `${overlapStart}-${overlapEnd}`,\n        conflict: true,\n        overlapLength: overlapEnd - overlapStart + 1\n      });\n    }\n  });\n\n  return overlaps.length > 0 ? overlaps : [{ \n    conflict: false,\n    message: \"新区间与现有区间无冲突\" \n  }];\n};\n\n// 执行检测\nconst result = findOverlaps(existingIntervals, newInterval);\n\n// 构建返回结果\nreturn [{\n  json: {\n    newInterval: `${newInterval.start}-${newInterval.end}`,\n    overlaps: result,\n    hasConflict: result[0].conflict,\n    checkedIntervalCount: existingIntervals.length,\n    // 调试信息（可选）\n    _debug: {\n      receivedData: items.map(item => item.json),\n      normalizedIntervals: existingIntervals\n    }\n  },\n  pairedItem: items.map(item => item.pairedItem)\n}];"
      },
