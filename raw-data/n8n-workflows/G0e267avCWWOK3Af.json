        "query": "SELECT \n    jo.joborder_id,\n    jo.joborder_number,\n    jo.product_id,\n    jo.procedure_list_id\nFROM \n    mes.joborder jo\nLEFT JOIN \n    mes.user u ON jo.user_id = u.user_id\nLEFT JOIN \n    mes.printinfo p1 ON jo.printinfo_id = p1.printinfo_id\nLEFT JOIN \n    mes.printinfo p2 ON jo.printinfobox_id = p2.printinfo_id\nLEFT JOIN \n    mes.product_info pinfo2 ON jo.product_id = pinfo2.product_id\nLEFT JOIN \n    mes.procedure_list pl ON jo.procedure_list_id = pl.procedure_list_id\nWHERE \n    jo.status = '1'\nand jo.joborder_number ='{{ $json.body.value }}';\n",
