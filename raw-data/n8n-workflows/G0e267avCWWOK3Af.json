        "jsCode": "let res = [];\nfor (const item of $input.all()) {\n    let itemJson = item.json;\n    let translatedType = '';  // 新增变量保存翻译后的类型\n    switch (itemJson.joborder_type) {\n        case 'ASSY':\n            translatedType = \"组装\";\n            break;\n        case 'PACK':\n            translatedType = \"包装\";\n            break;\n        case 'AfterSale':\n            translatedType = \"售后\";\n            break;\n        case 'Repair':\n            translatedType = \"维修\";\n            break;\n    }\n    itemJson.joborder_type_translated = translatedType;  // 新增列\n    res.push(itemJson);\n}\n\nreturn {\n    result: res\n};\n\n\n\n"
