    {
      "parameters": {
        "jsCode": "let inputArray = $input.all();\nlet result = null;\n\n// Check if input is a non-empty array\nif (Array.isArray(inputArray) && inputArray.length > 0) {\n    let firstItem = inputArray[0];\n\n    if (firstItem?.json?.body) {\n        let body = firstItem.json.body;\n\n        if (body.uuid) {\n            let uuid_original = body.uuid.trim();\n            let uuid_original2 = body.uuid;\n          \n\n            // Process based on UUID format\n            if (uuid_original.length === 30) {\n                // Handle 30-character UUID format\n                body.uuid = uuid_original;\n                // Remove characters at positions 16-17 (17th and 18th characters)\n                body.uuid_unique = body.uuid.slice(0, 16) + body.uuid.slice(18);\n                body.uuid_original=uuid_original;\n            } else {\n                // Handle URL format\n                const regex = /a=[\\w\\s]+?([A-Fa-f\\d]+)&b=([A-Fa-f\\d]+)&c=([A-Fa-f\\d]+)/;\n                const match = uuid_original2.match(regex);\n\n                if (match && match.length === 4) {\n                    const parts = [match[1], match[2], match[3]].map(s => s.toLowerCase());\n                    body.uuid = parts.join('');\n                    body.uuid_unique = body.uuid.slice(0, 16) + body.uuid.slice(18);\n                    body.uuid_original=uuid_original;\n                }\n            }\n\n            result = body;\n            console.log(\"Processed UUID:\", { uuid: body.uuid, uuid_unique: body.uuid_unique });\n\n            \n        } else {\n            console.log(\"UUID not found in body.\");\n        }\n    } else {\n        console.log(\"Body not found in first item.\");\n    }\n} else {\n    console.log(\"Input array is empty or not an array.\");\n}\n\nreturn result;"
      },
