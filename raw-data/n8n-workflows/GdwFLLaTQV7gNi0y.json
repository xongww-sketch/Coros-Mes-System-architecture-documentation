        "operation": "executeQuery",
        "query": "SELECT * FROM mes.machine_data md\njoin mes.retroid r on r.retroid_id = md.retroid_id\nwhere (LOWER(md.data ->>'bind_id')=LOWER('{{ $('切割uuid').item.json.uuid }}') or (LOWER(md.data ->>'unbind_id')=LOWER('{{ $('切割uuid').item.json.uuid_original }}'))) and md.procedure_detail_id in (select pd.procedure_detail_id from mes.procedure_detail pd \nwhere pd.procedure_name in('物料解除绑定','SN与UUID绑定') )\nand r.status in('1','2')\norder by createtime DESC\nlimit 1",
