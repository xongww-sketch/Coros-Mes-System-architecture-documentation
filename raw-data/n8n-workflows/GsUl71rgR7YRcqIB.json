    {
      "parameters": {
        "jsCode": "// 1. 提取 material\nconst materials = items.map(item => item.json.data.material);\n\n// 2. 去重、过滤空值、去除首尾空格\nconst uniqueMaterials = [...new Set(materials.filter(m => m))].map(m => m.toString().trim());\n\n// 3. 【核心修改】拼接成带单引号的 SQL 格式\n// 结果长这样: 'PPW5100492','PPW5100491','PPW5100198'\nconst sqlReadyString = \"'\" + uniqueMaterials.join(\"','\") + \"'\";\n\nreturn [\n  {\n    json: {\n      sql_filter: sqlReadyString, // 这个字段直接给 SQL 用\n      debug_count: uniqueMaterials.length\n    }\n  }\n];"
      },
