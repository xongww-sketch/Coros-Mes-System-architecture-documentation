    {
      "parameters": {
        "jsCode": "// 1. 获取所有输入 items (不仅仅是第一个)\nconst allItems = $input.all();\n\n// 2. 遍历所有数据，整理格式\n// 我们把 data 里面的内容(sn, bind_id) 和外面的 createtime1 合并在一起\n// 这样每一条历史记录都带有时间\nconst historyList = allItems.map(item => {\n    return {\n        // 将 data 对象里的字段 (sn, bind_id, procedure_name) 展开\n        ...item.json.data,\n        // 把外面的时间字段也放进来，方便查看\n        createtime1: item.json.createtime1\n    };\n});\n\n// 3. 返回结果\n// 返回一个单独的对象，因为这时候我们要把多行数据整合成一个 Response\nreturn {\n    \"code\": \"200\",\n    \"binding_history\": historyList, // 这里现在是一个包含所有数据的数组\n    \n    // 取第一条数据的时间作为整个包的时间（或者你可以留空）\n    \"creatime1\": allItems.length > 0 ? allItems[0].json.createtime1 : null,\n    // 防错处理：如果原始数据里没有 createtime，给个 null\n    \"creatime\": allItems.length > 0 ? (allItems[0].json.createtime || null) : null\n};"
      },
      "type": "n8n-nodes-base.code",
