    {
      "parameters": {
        "jsCode": "// 1. 获取输入项 (因为你的 Input 是一个包含 huge array 的单对象)\nconst inputItem = $input.first();\n\n// 防御性检查：如果没数据\nif (!inputItem || !inputItem.json) {\n  return {\n    json: {\n      code: 200,\n      data: { list: [] }\n    }\n  };\n}\n\n// 2. 提取核心数组 binding_history\n// 注意：这里不再是 $input.all()，而是取 json 里面的特定字段\nconst rootJson = inputItem.json;\nconst sourceArray = Array.isArray(rootJson.binding_history) ? rootJson.binding_history : [];\n\n// 3. 遍历数组进行格式化\nconst formattedList = sourceArray.map(item => {\n  // 逻辑：sn 优先 -> retroid -> bind_id (兜底) -> \"\"\n  const sn = item.sn || item.retroid || item.bind_id || \"\";\n\n  return {\n    procedure_name: item.procedure_name ? item.procedure_name.toString() : \" \",\n    sn: sn,\n    material: item.material || \"\",\n    bind_id: item.bind_id || \"\",\n    // 时间逻辑：优先取 item 自己的 createtime1，如果没有则取外层公共的\n    creatime1: item.createtime1 || rootJson.creatime1 || \"\",\n    creatime: item.createtime || rootJson.creatime || \"\"\n  };\n});\n\n// 4. 返回最终结构\nreturn {\n  json: {\n    code: 200,\n    data: {\n      list: formattedList\n    }\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
