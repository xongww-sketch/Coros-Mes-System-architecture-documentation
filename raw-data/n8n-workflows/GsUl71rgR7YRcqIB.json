      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT md.data,\n       md.createtime AS createtime1\nFROM mes.machine_data md\n-- 直接使用 IN 语法\n-- 注意：括号里面直接放 n8n 的变量，不要再加额外的引号，因为我们在 Code Node 里拼好了\nWHERE (md.data ->> 'bind_id')::text IN ( {{ $json.sql_filter }} )\nORDER BY md.createtime DESC;",
