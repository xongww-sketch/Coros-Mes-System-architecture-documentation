      "typeVersion": 1.1,
      "position": [
        660,
        240
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DECLARE @CPUID VARCHAR(100);\nSET @CPUID = SUBSTRING('{{ $json.query.CPUID }}', 1, 6) + SUBSTRING('{{ $json.query.CPUID }}', 19, 12);\n\nWITH Baselines AS (\n    SELECT *\n    FROM consm_barcodebindinfo\n    WHERE uuid_unique = @CPUID\n)\nSELECT \n    b.*, \n    p.barcode\nFROM \n    Baselines AS b\nLEFT JOIN \n    YFConsumer.dbo.consm_deviceweight AS p ON p.barcode = b.baseline;\n\n\n"
      },
