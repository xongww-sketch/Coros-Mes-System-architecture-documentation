    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT TOP 40000 b.*, \n        (SELECT TOP 1 p.barcode\n         FROM YFConsumer.dbo.consm_deviceweight AS p\n         WHERE b.baseline = p.barcode\n         ORDER BY p.barcode DESC) AS barcode\nFROM consm_barcodebindinfo AS b\nWHERE b.baseline LIKE '%{{ $json.query.baseline||\"\" }}%'\n\n\n\n"
      },
      "id": "c0c863a3-52fe-4e9a-b334-3237604a68f1",
      "name": "Microsoft SQL1",
