      "parameters": {
        "jsCode": "function generateResponse(inputData) {\n    const bindingHistory = inputData.map(item => ({\n        \"procedure_name\": item.json.procedure_name,\n        \"createtime\": item.json.createtime,\n        \"machine_data_id\": item.json.machine_data_id,\n        \"binding_data\": item.json.binding_data,\n        \"binding_action\": item.json.binding_action\n    }));\n\n    return {\n        \"code\": \"200\",\n        \"binding_history\": bindingHistory\n    };\n}\n\n// 假设 $input.all() 是获取所有输入数据的方法\nconst inputData = $input.all().filter(item => item.json.machine_data_id); // 在实际使用中获取数据\nconst response = generateResponse(inputData);\n\n// 返回处理后的结果\nreturn response;\n"
