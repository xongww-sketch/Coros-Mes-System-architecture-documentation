        "jsCode": "function processData() {\n  // 获取输入数据\n  const inputArray = $input.all().filter(item => item.json);\n\n  // 使用map函数处理每个元素\n  const outputArray = inputArray.map(entry => {\n    const item = entry.json; // 提取json字段中的内容\n\n    let bindingData = null;\n\n    const procedureName = item.data.procedure_name;\n    const data = item.data;\n\n    // 构造输出对象\n    return {\n      procedure_name: procedureName, // 自动替换绑定为解绑\n      createtime: item.createtime,\n      machine_data_id: item.machine_data_id.toString(),\n      binding_action: \"1\",\n      binding_data: data.bind_id || ''\n    };\n  });\n\n  // 返回最终的输出数组\n  return outputArray;\n}\n\n// 调用并获取结果\nconst result = processData();\nconsole.log(\"Processed Output:\", JSON.stringify(result, null, 2));\n\n// 返回结果\nreturn result;\n"
