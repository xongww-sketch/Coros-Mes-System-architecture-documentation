    {
      "parameters": {
        "jsCode": "function processData() {\n  // 获取输入数据\n  const inputArray = $input.all().filter(item => item.json);\n\n  // 使用 map 函数处理每个元素\n  const outputArray = inputArray.map(entry => {\n    const item = entry.json; // 从 json 提取数据\n    const data = item.data; // 获取 data 对象\n\n    let procedureName = data.unblind_name; // 提取 unblind_name\n\n    // 确保 machine_data_id 存在并转换为字符串\n    const machineDataId = item.machine_data_id != null ? String(item.machine_data_id) : \"未知\";\n\n    // 构造并返回输出对象\n    return {\n      procedure_name: procedureName,\n      createtime: item.createtime,\n      machine_data_id: machineDataId,\n      binding_action: \"2\", // 假设 2 表示解绑\n      binding_data: data.data_old.bind_id || ''\n    };\n  });\n\n  // 返回最终的输出数组\n  return outputArray;\n}\n\n// 调用并获取结果\nconst result = processData();\nconsole.log(\"Processed Output:\", JSON.stringify(result, null, 2));\n\n// 返回结果\nreturn result;\n"
      },
