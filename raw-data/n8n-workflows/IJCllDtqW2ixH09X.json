    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT md.retroid_id, md.createtime, md.machine_data_id,md.procedure_detail_id,\n  (md.data ->> 'Station')::text AS station,\n  (md.data ->> 'Result')::text  AS result,\n  (md.data ->> 'Model')::text   AS model,\n  (md.data ->> 'uuid')::text   AS uuid,\n  md.data ->> 'Machine_id'      AS machine_id,\n    (md.data ->> 'file')::text   AS file,\n  (md.data ->> 'file')::text   AS file_name,\n  r.retroid,        \n  r.retroid_id\nFROM mes.machine_data md \n  JOIN mes.retroid r\n  ON r.retroid_id = md.retroid_id\nWHERE md.retroid_id = $1\n  {{ $('Webhook').item.json.body.procedure_name ? `AND md.procedure_detail_id IN (\n        SELECT procedure_detail_id\n        FROM mes.procedure_detail\n        WHERE procedure_name = $2)` : 'AND md.procedure_detail_id IN (96,95,94,93,97,125,134,135,136,148,149,155,156,140,141)'}}\n  {{ $('Webhook').item.json.body.bgtime ? `AND md.createtime >= $3::timestamp` : '' }}\n  {{ $('Webhook').item.json.body.edtime ? `AND md.createtime <= $4::timestamp` : '' }}\n  {{ $('Webhook').item.json.body.machine_id ? `AND (md.data ->> 'Machine_id') = $5` : ''}}\n  {{ $('Webhook').item.json.body.result ? `AND (md.data ->> 'Result') = $6` : ''}}",
        "options": {
          "queryReplacement": "={{ $json.retroid_id || null }},{{ $('Webhook').item.json.body.procedure_name || null }},{{ $('Webhook').item.json.body.bgtime || null }},{{ $('Webhook').item.json.body.edtime || null }},{{ $('Webhook').item.json.body.machine_id || null }},{{ $('Webhook').item.json.body.result || null }}",
          "replaceEmptyStrings": false
        }
