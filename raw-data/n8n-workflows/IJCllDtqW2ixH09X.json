      "parameters": {
        "jsCode": "const sn = $('Webhook').first().json.body.sn;\nconst uuid = $('Webhook').first().json.body.uuid;\nconst procedure_name = $('Webhook').first().json.body.procedure_name;\nconst model = $('Webhook').first().json.body.product_model;\nconst bgtime = $('Webhook').first().json.body.bgtime;\nconst edtime = $('Webhook').first().json.body.edtime;\nconst macid = $('Webhook').first().json.body.macid;\nconst result = $('Webhook').first().json.body.result;\n\nconst cleanSn =sn.replace(/\\s|\\/n/g, '')\nconst cleanUid =uuid.replace(/\\s|\\/n/g, '')\n// const cleanMacid =macid.replace(/\\s|\\/n/g, '')\n\nreturn{json:{\n        body:{\n          sn:cleanSn,\n          uuid:cleanUid,\n          procedure_name:procedure_name,\n          model:model,\n          bgtime:bgtime,\n          edtime:edtime,\n          mac_id:macid,\n          result:result\n}\n}\n}"
