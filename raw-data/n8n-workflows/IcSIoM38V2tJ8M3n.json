    {
      "parameters": {
        "jsCode": "// 假设输入数据存储在变量 inputData 中\nconst inputData = $input.all()\n// 解析输入数据\nconst data = inputData[0].json;\nconst firmwareTypes = JSON.parse(data.query.firmware_type);\nconst countries = JSON.parse(data.query.Country);\nconst activeDateStart = data.query.ActiveDate_Start;\nconst activeDateEnd = data.query.ActiveDate_End;\n\nconst outputData = [];\n\nif (firmwareTypes.length > 0 && countries.length > 0) {\n  // 如果两者都有值，按照原来的逻辑生成 ITEM\n  for (const country of countries) {\n    for (const firmwareType of firmwareTypes) {\n      const item = {\n        firmware_type: firmwareType,\n        Country: country,\n        ActiveDate_Start: activeDateStart,\n        ActiveDate_End: activeDateEnd\n      };\n      outputData.push(item);\n    }\n  }\n} else if (firmwareTypes.length > 0) {\n  // 如果只有 firmware_type 有值，按照 firmware_type 生成 ITEM\n  for (const firmwareType of firmwareTypes) {\n    const item = {\n      firmware_type: firmwareType,\n      ActiveDate_Start: activeDateStart,\n      ActiveDate_End: activeDateEnd\n    };\n    outputData.push(item);\n  }\n} else if (countries.length > 0) {\n  // 如果只有 Country 有值，按照 Country 生成 ITEM\n  for (const country of countries) {\n    const item = {\n      Country: country,\n      ActiveDate_Start: activeDateStart,\n      ActiveDate_End: activeDateEnd\n    };\n    outputData.push(item);\n  }\n} else {\n  // 如果两者都没有值，只生成包含时间的 ITEM\n  const item = {\n    ActiveDate_Start: activeDateStart,\n    ActiveDate_End: activeDateEnd\n  };\n  outputData.push(item);\n}\n\nreturn outputData;\n\n\n"
      },
      "id": "9217b015-9c75-4e37-8004-8a03fdbb4c54",
      "name": "Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -320,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const inputData = $input.all();\nlet sqlQueries = [];\n\n// 遍历inputData数组\nfor (const item of inputData) {\n  let whereConditions = [];\n\n  // 获取item的json属性\n  const queryParams = item.json;\n\n  // 遍历queryParams对象的键值对\n  for (const [key, value] of Object.entries(queryParams)) {\n    if (value && value !== \"0\") {\n      if (key == 'ActiveDate_Start') {\n        whereConditions.push(`ar.activatetime >= '${value}'`);\n      } else if (key == 'ActiveDate_End') {\n        whereConditions.push(`ar.activatetime <= '${value}'`);\n      } else if (key == 'firmware_type') {\n        whereConditions.push(`ar.${key} = '${value}'`);\n      } else if (key == 'Country') {\n        whereConditions.push(`ar.country_code = '${value}'`);\n      }\n    }\n  }\n\n  // 构建SQL查询语句\n  const sqlQuery = `SELECT dr.*, ar.firmware_type, ar.country_code, ar.activatetime FROM public.defective_records dr JOIN public.activation_records ar ON dr.active_id = ar.id ${whereConditions.length > 0 ? 'WHERE ' + whereConditions.join(' AND ') : ''}`;\n\n  // 将生成的SQL查询语句添加到sqlQueries数组中\n  sqlQueries.push({ sqlQuery: sqlQuery });\n}\n\n// 返回sqlQueries数组\nreturn sqlQueries;\n\n\n"
      },
      "id": "f596cd11-8bea-4d34-a30d-fbefced4a3da",
      "name": "构建查询语句",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -140,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.all();\n\n// Helper function to calculate the difference in days between two dates\nfunction calculateDaysDifference(isoString, timestamp) {\n    const defectiveDate = new Date(isoString);\n    const activationDate = new Date(Number(timestamp) * 1000); // Convert timestamp to milliseconds\n    const differenceInTime = defectiveDate.getTime() - activationDate.getTime(); // Calculate time difference in milliseconds\n    const differenceInDays = differenceInTime / (1000 * 60 * 60 * 24); // Convert time difference to days without rounding\n    return Math.round(differenceInDays); // Return the rounded difference in days\n}\n\n// Modified input array with added 'activateterm' attribute\nconst modifiedInput = input.map(entry => {\n    // Calculate activateterm and add to the entry object\n    entry.json.activateterm = calculateDaysDifference(entry.json.defective_date, entry.json.activatetime);\n    return entry;\n});\n\nreturn modifiedInput;\n\n\n\n\n\n\n"
      },
