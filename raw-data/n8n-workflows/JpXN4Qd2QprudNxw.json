    {
      "parameters": {
        "jsCode": "// 从JSON中获取username和password\nconst username = $input.all()[0].json.username;\nconst password = $input.all()[0].json.password;\nconst id = $input.all()[0].json.id;\n\nfunction generateToken() {\n  // 生成随机token\n  const token = Math.random().toString(36).substr(2);\n  \n\n\n  return {\n    id: id,\n    username: username,\n    password: password,\n    token: token,\n  };\n}\n\n// 调用函数并输出结果\nconst result = generateToken();\nreturn result;\n"
      },
