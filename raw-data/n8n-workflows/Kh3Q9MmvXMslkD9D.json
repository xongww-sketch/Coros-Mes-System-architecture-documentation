    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst res={};\nfor (const item of $input.all()) {\n  //判断jobNumber非空，且长度是10位的数字\n  if(validateField(item.json.body.jobNumber)){\n    res.code=1;\n    res.jobNumber=item.json.body.jobNumber;\n  }else{\n    res.code=2;\n    res.message=\"工单号不正确，请重新输入工单号！\"\n  };\n  \n}\nfunction validateField(input) {\n  const str = String(input).trim();\n  return str.length === 10 && /^\\d{10}$/.test(str);\n}\n\nreturn res;"
      },
