    {
      "parameters": {
        "jsCode": "// 创建月份映射表（0-based index）\nconst monthMap = new Map(\n  [\"J\", \"F\", \"M\", \"A\", \"M\", \"J\", \"J\", \"A\", \"S\", \"O\", \"N\", \"D\"]\n    .map((monthAbbr, index) => [index, monthAbbr])\n);\nlet snList=[];\n// 处理所有输入项\nfor (const item of $input.all()) {\n  const joborderNumber = item.json.joborder_number;\n  const quantity=item.json.product_quantity;\n  // 生成序列号组件\n  const currentMonth = new Date().getMonth(); // 自动获取当前月份（0-11）\n  const monthAbbr = monthMap.get(currentMonth) || 'X'; // 添加默认值防止undefined\n  for(let i=0;i<quantity;i++){\n    const fiveDigitRandom = Math.floor(Math.random() * 90000) + 10000; // 生成5位随机数\n     // 构建完整序列号\n    const devicePartsSN = `${joborderNumber}${monthAbbr}${fiveDigitRandom}`;\n    snList.push(devicePartsSN)\n  }\n\n  \n  // 添加新字段到当前项\n  item.json.snList = snList;\n\n  \n}\n\nreturn $input.all();"
      },
