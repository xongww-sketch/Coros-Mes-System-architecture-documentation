    {
      "parameters": {
        "jsCode": "let inputArray = $input.all();\nlet result = null;\n\nconsole.log(\"Received Input Array:\", inputArray);\n\n// 检查输入是否为非空数组且至少有一个元素\nif (Array.isArray(inputArray) && inputArray.length > 0) {\n    console.log(\"Input array is valid.\");\n\n    let json = inputArray[0].json; // 获取json对象\n\n    if (json.body) {\n        console.log(\"Body found:\", json.body);\n        \n        const body = json.body;\n        \n        if (body.uuid) {\n            console.log(\"UUID found:\", body.uuid);\n\n            let url = body.uuid;\n\n            // 使用正则表达式捕获需要的部分\n            const regex = /a=.*?([\\dA-Fa-f]+)&b=([\\dA-Fa-f]+)&c=([\\dA-Fa-f]+)/;\n            const match = url.match(regex);\n\n            if (match && match.length === 4) { // 如果成功匹配\n                console.log(\"Matched:\", match);\n\n                // 用 a 参数末尾、b 和 c 生成 uuidId\n                body.uuidId = [match[1], match[2], match[3]].join('');\n\n                // 用 a 参数末尾和 c 生成 uuid_unique\n                body.uuid_unique = [match[1], match[3]].join('');\n            } else {\n                console.log(\"No match found.\");\n            }\n\n            result = body; // 设置最终结果体\n        } else {\n            console.log(\"UUID not found in body.\");\n        }\n    } else {\n        console.log(\"Body not found.\");\n    }\n} else {\n    console.log(\"Input array is empty or not an array.\");\n}\n\n// 返回最终处理的 JSON 对象\nconsole.log(\"Result:\", result);\nreturn result;\n"
      },
