    {
      "parameters": {
        "jsCode": "// 遍历所有输入项\nfor (const item of $input.all()) {\n  \n  // 1. 获取 data 数组 (假设数据在 json 节点下)\n  // 如果你的数据结构仅仅是 array 并没有包裹在 json 中，请去掉 .json\n  const dataList = item.json.data;\n\n  // 2. 确保它是一个数组，防止报错\n  if (Array.isArray(dataList)) {\n    \n    // 3. 使用 filter 过滤\n    // Object.keys(obj).length 用于获取对象属性的个数\n    // 如果个数 > 0，说明不是空对象，予以保留\n    item.json.data = dataList.filter(obj => {\n      return obj && typeof obj === 'object' && Object.keys(obj).length > 0;\n    });\n  }\n}\n\nreturn $input.all();"
      },
