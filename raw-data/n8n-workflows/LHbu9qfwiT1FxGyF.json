      "parameters": {
        "jsCode": "const newItems = [];\n\n// 定义需要校验的必填字段\nconst requiredFields = ['sn', 'data',  'user_id','machine_id'];\n\nfor (const item of $input.all()) {\n  // 1. 安全获取 body 中的参数，如果 body 不存在则给一个空对象防止报错\n  const params = item.json.body || {};\n\n  let isValid = true;\n  let missingFields = []; // 用于记录哪个字段没填（可选）\n\n  // 2. 循环校验字段\n  for (const field of requiredFields) {\n    const val = params[field];\n    \n    // 判断逻辑：未定义、Null、或者去除空格后为空字符串\n    if (val === undefined || val === null || String(val).trim() === '') {\n      isValid = false;\n      missingFields.push(field);\n    }\n  }\n\n  // 3. 构建返回对象\n  // 使用 ...params 将参数展开（扁平化），去掉 'body' 外壳\n  const outputData = {\n    ...params,        // 包含 sn, procedure_name 等原始数据\n    isValid: isValid  // 只有 true 或 false\n  };\n\n  // 如果你需要知道具体是哪个参数错了，可以取消下面这行的注释\n  // if (!isValid) outputData.errorMsg = `缺少参数: ${missingFields.join(', ')}`;\n\n  // n8n 标准返回格式需包裹在 json 属性中\n  newItems.push({ json: outputData });\n}\n\nreturn newItems;"
      },
