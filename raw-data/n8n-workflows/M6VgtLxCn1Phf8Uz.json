      "id": "86603300-558c-484b-ae9f-3f1db920b213",
      "name": "判断是否有数据"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    r.retroid AS sn,\n    pm.product_model_name,\n    c.serial_id,\n    c.cplc\nFROM \n    mes.retroid r \nJOIN \n    mes.joborder jo ON r.joborder_id = jo.joborder_id\nJOIN \n    mes.product_info pi ON jo.product_id = pi.product_id\nJOIN \n    mes.product_model pm ON pi.product_model_id = pm.product_model_id\nJOIN \n    mes.cplc c ON r.retroid = c.sn\nWHERE\n    c.status = '2'\nORDER BY \n    c.create_time ASC\nLIMIT 500;\n",
        "options": {}
      },
