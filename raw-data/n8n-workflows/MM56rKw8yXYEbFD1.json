    {
      "parameters": {
        "jsCode": "// 获取上一个节点的输出数据\nconst previousNodeData = $input.all()[0].json.body;\nconst targetProcedureDetailId = previousNodeData.procedure_detail_id;\n\n// 获取\"查找工艺流程1\"节点的输出数据\nconst processFlowData = $('查找工艺流程1').all()[0].json\nconst procedureDetailIds = processFlowData.procedure_detail_id.procedure_detail_id;\n\n// 检查目标ID是否存在\nconst isExist = procedureDetailIds.includes(targetProcedureDetailId);\n\n// 构建输出结果\nconst result = {\n  input_procedure_detail_id: targetProcedureDetailId,\n  exists_in_flow: isExist,\n  matched_flow_name: isExist ? processFlowData.procedure_list_name : null,\n  //all_procedure_detail_ids: procedureDetailIds\n};\n\n// 返回结果\nreturn [result];"
