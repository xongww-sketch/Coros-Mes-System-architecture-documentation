    },
    {
      "parameters": {
        "jsCode": "// 获取所有输入项\nconst previousNodeItems = $input.all();\n\n// 正确获取\"查找工艺流程1\"节点的输出数据\nconst processFlowData = $('查找工艺流程1').all()[0].json;\n\n// 安全地获取procedure_detail_id数组\nconst procedureDetailIds = processFlowData?.procedure_detail_id?.procedure_detail_id || [];\n\n// 检查所有输入的ID是否存在（只要有一个存在即为true）\nconst anyExist = previousNodeItems.some(item => {\n  const targetId = item.json?.procedure_detail_id || item.json?.body?.procedure_detail_id;\n  return procedureDetailIds.includes(targetId);\n});\n\n// 获取所有输入的ID\nconst inputIds = previousNodeItems.map(item => \n  item.json?.procedure_detail_id || item.json?.body?.procedure_detail_id\n);\n\n// 构建单一输出结果\nconst result = {\n  input_procedure_detail_ids: inputIds,\n  exists_in_flow: anyExist,\n  matched_flow_name: anyExist ? processFlowData.procedure_list_name : null,\n  checked_ids_count: inputIds.length,\n  existing_ids_count: anyExist ? \"至少1个\" : 0\n};\n\n// 返回单一结果\nreturn [result];"
