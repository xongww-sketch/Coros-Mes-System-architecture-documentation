        "responseBody": "={\n  \"code\": \"200\",\n  \"message\":\"条码已成功绑定\",\n  \"uuid\":\"{{$('判断转换后UUID长度是否正确').all()[0].json.body.uuidId}}\",\n  \"sn\":\"{{$('判断转换后UUID长度是否正确').all()[0].json.body.retroid}}\"\n}\n",
