    {
      "parameters": {
        "jsCode": "let result = [];\nlet isValid = true;\n\nfor (const item of $input.all()) {\n  const { \n    resourceName,\n    resourceId,\n    packageId,\n    resourceType,\n    productionLine,\n  } = item.json.body;\n\n  // 添加新字段 [[10]]\n  const resource = {\n    resourceName,\n    resourceId,\n    packageId,\n    resourceType,\n    productionLine\n  };\n\n  // 参数验证逻辑 [[2]][[6]][[8]]\n  if (resourceType === 1) {\n    if (![resourceName, packageId].every(v => v != null)) {\n      isValid = false;\n      break;\n    }\n  } else {\n    if (![resourceName].every(v => v != null)) {\n      isValid = false;\n      break;\n    }\n  }\n\n  result.push(resource);\n}\n\nif (!isValid) {\n  return { code: 201, message: \"请求参数不能为空！\" };\n}\n\nreturn result;"
      },
