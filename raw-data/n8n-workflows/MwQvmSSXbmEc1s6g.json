    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst SQLstr = {};\n\nfor (const item of $input.all()) {\n  const resource = item.json.body;\n  let sql = `update mes.resources \nset resource_name='${resource.resourceName}', \nprocedure_id='${resource.procedureId}',  production_line='${resource.productionLine}'`;\n\n\n  if (resource.packageId !== \"null\") {\n    sql += `, package_id='${resource.packageId}',resource_status=1`;\n  }\n\n  //  if (resource.deviceType !== \"null\") {\n  //   sql +=`, resource_info = jsonb_set(resource_info, '{deviceType}', '${resource.deviceType}'::jsonb)`\n  // }\n\n  sql += ` where id=${resource.resourceId}`;\n  SQLstr.sql = sql;\n}\n\nreturn SQLstr;\n"
      },
