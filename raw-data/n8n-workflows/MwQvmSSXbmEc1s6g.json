    {
      "parameters": {
        "jsCode": "const resource = $('CheckParam').all()[0].json.query;\nconst image = '/image/' + $('Webhook').all()[0].binary.image.fileName;\n\nlet SQLstr = {};\nlet sql = `update mes.resources \nset resource_name='${resource.resourceName}', purchase_time='${resource.purchaseTime}', image='${image}'`;\n\nif (resource.packageId !== \"null\") {\n  sql += `, package_id='${resource.packageId}',resource_status=1`;\n}\n\nsql += ` where id=${resource.resourceId}`;\n\nSQLstr.sql = sql;\n\nreturn SQLstr;\n"
      },
