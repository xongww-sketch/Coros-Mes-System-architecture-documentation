    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH latest_history AS (\n    SELECT json_array_elements_text((history_procedure_detail_id->>'history_procedure_detail_id')::json) AS detail_id\n    FROM mes.history_procedure_list\n    WHERE history_procedure_list_id = '{{ $json.history_procedure_list_id }}'\n)\nSELECT DISTINCT ON (hpd.procedure_detail_id) hpd.*\nFROM mes.history_procedure_detail hpd\nWHERE hpd.history_procedure_id IN (\n    SELECT detail_id::int FROM latest_history\n)\nAND hpd.procedure_dataupload = 2\nORDER BY hpd.procedure_detail_id, hpd.createtime DESC;\n",
        "options": {}
      },
