    {
      "parameters": {
        "jsCode": "// 从 Execute Workflow 节点获取数据\nconst workflowData = $('Execute Workflow').all()[0].json.data;\n\n// 从查询包装工单节点获取 retroid_id\nconst packagingData = $(\"查询包装工单\").all();\nconst retroidId = packagingData.length > 0 ? packagingData[0].json.retroid_id : null;\n\n// 假设我们从 Execute Workflow 的第一个元素中提取信息\nconst latestWorkflowData = workflowData[0]; \n\n// 返回结果\nreturn [\n  {\n    json: {\n      retroidId: retroidId,\n      history_procedure_id: latestWorkflowData.history_procedure_id,\n      procedure_detail_id: latestWorkflowData.procedure_detail_id\n    }\n  }\n];\n"
      },
