    {
      "parameters": {
        "jsCode": "const inputData = items[0].json.data;  // 获取入参中的 data 数组\n\nconst result = {\n  code: \"200\",\n  msg: inputData.map(item => {\n    return {\n      id: item.id,\n      retroid: item.retroid,\n      production_id: item.production_id,\n      delivery_id: item.delivery_id,\n      machine_type: item.machine_type,\n      job_number: item.job_number,\n      uuid: item.uuid,\n      phase: item.phase,\n      wifi_mac: item.wifi_mac,\n      battery: item.battery,\n      screen: item.screen,\n      remark: item.remark,\n      channel: item.channel, \n      createtime: item.createtime,   production_createtime:item.production_createtime,\ndelivery_createtime:item.delivery_createtime,\npacking_creatime:item.packing_createtime\n    };\n  })\n};\n\nreturn [\n  {\n    json: result\n  }\n];\n"
      },
