    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    di.*, \n    pd.createtime AS production_createtime,\n    dd.createtime AS delivery_createtime,\n    ee.createtime AS packing_createtime\nFROM \n    mes_daily_data.daily_info di\nLEFT JOIN \n    mes_daily_data.production_detail pd ON di.production_id = pd.id\nLEFT JOIN \n    mes_daily_data.pack_detail ee ON di.pack_id = ee.id\nLEFT JOIN \n    mes_daily_data.delivery_detail dd ON di.delivery_id = dd.id\nWHERE  di.retroid = '{{ $json.query.sn}}';",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        -48,
        80
      ],
