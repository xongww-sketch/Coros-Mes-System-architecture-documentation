      "parameters": {
        "jsCode": "// CRC16-CCITT-FALSE 实现\nfunction crc16Ccitt(str) {\n    let crc = 0xFFFF;\n    const poly = 0x1021;\n\n    for (let i = 0; i < str.length; i++) {\n        crc ^= (str.charCodeAt(i) << 8);\n        for (let j = 0; j < 8; j++) {\n            if (crc & 0x8000) {\n                crc = (crc << 1) ^ poly;\n            } else {\n                crc <<= 1;\n            }\n            crc &= 0xFFFF; // 保持16位\n        }\n    }\n    return crc;\n}\n\n// 处理所有输入数据\nreturn $input.all().map(item => {\n    const data = item.json;\n    const uuid = data.uuid;\n    const base64Token = data[\"Base64-encoded Token\"];\n\n    // 计算CRC16\n    const uuidCrc = crc16Ccitt(uuid);\n    const tokenCrc = crc16Ccitt(base64Token);\n\n    // 返回结果，确保CRC16值是4个字符长\n    return {\n        json: {\n            uuid: uuid,\n            base64Token: base64Token,\n            uuidCrc: uuidCrc.toString(16).padStart(4, '0').toUpperCase(),\n            tokenCrc: tokenCrc.toString(16).padStart(4, '0').toUpperCase()\n        }\n    };\n});\n"
      },
