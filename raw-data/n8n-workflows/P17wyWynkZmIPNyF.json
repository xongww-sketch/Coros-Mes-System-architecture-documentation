    {
      "parameters": {
        "jsCode": "const inputItems = $('Webhook').all(); // 获取所有输入项\n\n// 函数：根据 sn 前缀获取相应的 ppid\nfunction getPPID(sn) {\n    const snToPpidMap = {\n        \"W92\": \"828649-509327\",\n        \"W51\": \"828649-833829\",\n        \"W52\": \"828649-814264\"\n    };\n\n    const prefix = sn.substring(0, 3); // 提取前3个字符\n    return snToPpidMap.hasOwnProperty(prefix) ? snToPpidMap[prefix] : \"未找到对应的ppid\";\n}\n\nlet results = [];\n\n// 遍历每一个 input 项\ninputItems.forEach(item => {\n    if (item.json && item.json.body && item.json.body.sn) {\n        const sn = item.json.body.sn; // 从 json.body 中提取 sn\n        const ppid = getPPID(sn);\n\n        results.push({\n            json: {\n                sn: sn,\n                ppid: ppid\n            }\n        });\n    }\n});\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        0
      ],
      "id": "b65900a7-fc18-4944-a941-cf921fafc95d",
      "name": "Code",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// 你的输入数据节点\nconst originalDataNode = $input.all();\n\n// 检查输入数据的有效性\nif (!originalDataNode.length) {\n    throw new Error(\"No valid original data found in originalDataNode\");\n}\n\n// 创建一个对象，以token为键，UUID为值\nconst authEntitiesMapping = originalDataNode.reduce((acc, dataNode) => {\n    const token = dataNode.json.token;\n    const uuid = dataNode.json.uuid;\n    acc[token] = uuid;\n    return acc;\n}, {});\n\n// 提取 ppid（假设所有数据项的 ppid 相同，用第一个）\nconst resultPpid = originalDataNode[0].json.ppid;\n\n// 构建最终结果对象\nconst result = {\n    ppid: resultPpid,\n    auth_entities: [authEntitiesMapping] // 将对象放在数组中\n};\n\n// 返回结果\nreturn {\n    json: result\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2560,
        120
