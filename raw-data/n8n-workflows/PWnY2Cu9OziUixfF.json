    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH LatestHistoryProcedure AS (\n    SELECT\n        procedure_detail_id,\n        MAX(history_procedure_id) AS latest_history_procedure_id\n    FROM\n        mes.history_procedure_detail\n    GROUP BY\n        procedure_detail_id\n)\nSELECT \n    pd.procedure_detail_id,\n    pd.procedure_name,\n    pd.current_version,\n    pd.createtime,\n    pd.common_proocedure,\n    pd.checkrule,\n    hpd.history_procedure_id,\n    hpd.product_model_id,\n    COALESCE(pm.product_model_name, '') AS product_model_name, -- 如果product_model_name不存在，则返回空字符串\n    hpd.sop,\n    u.user_name,\n    hpd.procedure_type,\n    hpd.standard_labor,\n    hpd.standard_people,\n    hpd.cycle_time,\n    hpd.procedure_type,\n    hpd.procedure_dataupload,\n    hpd.procedure_scheduling\nFROM \n    mes.procedure_detail pd\nJOIN \n    LatestHistoryProcedure lhp\n    ON pd.procedure_detail_id = lhp.procedure_detail_id\nJOIN \n    mes.history_procedure_detail hpd \n    ON hpd.history_procedure_id = lhp.latest_history_procedure_id\nLEFT JOIN -- 使用LEFT JOIN来确保即使没有匹配的记录，也会返回空值\n    mes.product_model pm \n    ON hpd.product_model_id = pm.product_model_id\nJOIN \n    mes.sys_user u \n    ON hpd.user_id = u.user_id\nWHERE\n    pd.status = '1'\n\n",
