    {
      "parameters": {
        "jsCode": "var retroid = $input.all()[0].json.body.retroid;\nvar ProductSeries = retroid.substring(0,1);\nvar ProductModel = retroid.substring(1,3);\nvar ProductPhase = retroid.substring(3,5);\nvar Series = retroid.substring(5,10)\n \nvar snList ={\n ProductSeries:ProductSeries,\n ProductModel:ProductModel,\n ProductPhase:ProductPhase,\n  Series:Series\n}\nreturn snList;"
