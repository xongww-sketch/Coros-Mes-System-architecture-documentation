    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet body=$input.first().json.body //只接收第一个输入\n\nlet url=body.uuidId.toUpperCase();\n// 使用单个正则表达式同时匹配所有参数，并捕获所需部分\nconst regex = /a=([\\w\\s]+)\\s([A-F\\d]+)&b=([A-F\\d]+)&c=([A-F\\d]+)/i;\nconst match = url.match(regex);\n\nif (match && match.length==5) { //如果匹配上，并且结果是5个\n  body.model = match[1];\n  body.uuidId = [match[2], match[3], match[4]].join('');\n  body.uuid_unique=[ match[2], match[4]].join('');\n}\n\n//retroid校正大小写输入\n body.retroid = body.retroid.toUpperCase();\nreturn $input.all();\n\n\n"
      },
