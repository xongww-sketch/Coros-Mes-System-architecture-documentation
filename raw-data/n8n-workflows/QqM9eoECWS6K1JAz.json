      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * \nFROM YFConsumer.dbo.consm_baselinegenerate \nWHERE ProductSeries= '{{ $json.ProductSeries }}' \n  and ProductModel= '{{ $json.ProductModel }}' \n  and ProductPhase = '{{ $json.ProductPhase }}' \n  and CONVERT(INT, BeginSeries) <= CONVERT(INT, '{{ $json.Series }}')  \n  and CONVERT(INT,EndSeries) >= CONVERT(INT,'{{ $json.Series }}') ;"
