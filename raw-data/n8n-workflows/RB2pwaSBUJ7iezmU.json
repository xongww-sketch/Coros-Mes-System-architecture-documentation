    {
      "parameters": {
        "jsCode": "// Define your key-value mapping (left is key, right is value)\nconst keyValueMap = {\n  \"M1D\": \"M04\",\n  \"B20\": \"B20\",\n  \"B21\": \"B21\",\n  \"B18\": \"M18\",\n  \"B19S\": \"V09\",\n  \"W331\": \"W31\",\n  \"W332\": \"W32\",\n  \"B15D\": \"B05\",\n  \"FD05\": \"F05\",\n  \"HR31\": \"H31\",\n  \"BY01\": \"C01\",\n  \"FD02\": \"F02\",\n  \"FD03\": \"F03\",\n  \"W942\": \"W92\",\n  \"S501\": \"S51\",\n  \"W541\": \"W51\",\n  \"W542\": \"W52\",\n  \"W335\": \"W35\"\n};\n\n// Get the incoming data\nconst items = $input.all();\n\n// Process each item\nconst results = items.map(item => {\n  const snValue = item.json.body.sn;\n  \n  // Find the key that has this snValue as its value\n  const matchedKey = Object.keys(keyValueMap).find(key => keyValueMap[key] === snValue);\n  \n  // Return the matched key (or null if not found)\n  return {\n    original_sn: snValue,\n    mapped_key: matchedKey || null\n  };\n});\n\n// Return the processed results\nreturn results;"
      },
