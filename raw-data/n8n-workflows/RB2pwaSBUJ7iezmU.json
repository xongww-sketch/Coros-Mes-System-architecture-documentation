    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// 提取所有SN号并过滤掉null/undefined/空字符串\nconst allSNs = items\n  .map(item => item.json.SN)  // 注意字段名是\"SN\"不是\"sn\"\n  .filter(sn => sn != null && sn.trim() !== '');\n\n// 使用Set查重\nconst uniqueSNs = [...new Set(allSNs)];\n\n// 找出重复的SN号\nconst duplicates = allSNs.filter((sn, index) => allSNs.indexOf(sn) !== index);\nconst uniqueDuplicates = [...new Set(duplicates)];\n\n// 获取详细的重复项信息\nconst duplicateDetails = uniqueDuplicates.map(sn => {\n  const duplicateItems = items.filter(item => item.json.SN === sn);\n  return {\n    sn,\n    count: duplicateItems.length,\n    positions: duplicateItems.map(item => item.index),\n    problems: duplicateItems.map(item => item.json.bad_problem)\n  };\n});\n\nreturn {\n  json: {\n    totalItems: items.length,\n    validSNItems: allSNs.length, // 有效的SN号数量(排除空值)\n    uniqueItems: uniqueSNs.length,\n    hasDuplicates: uniqueSNs.length !== allSNs.length,\n    duplicates: uniqueDuplicates,\n    duplicateCount: duplicates.length,\n  }\n};"
      },
