    {
      "parameters": {
        "jsCode": "const input = $input.all();\nconst result = [];\n\ninput.forEach(item => {\n    const { \n        product_model_name_easy = '',  // 3位型号简写\n        beginseries,                   // 开始序列号\n        endseries,                     // 结束序列号\n        materials_code = ''         // 第4-5位材料编码\n    } = item.json || {};\n\n    // 验证输入\n    if (beginseries > endseries) {\n        console.error(\"Beginseries cannot be greater than Endseries:\", beginseries, endseries);\n        return;\n    }\n\n    // 处理product_model_name_easy，确保3位\n    const modelPrefix = String(product_model_name_easy || 'XXX')\n        .trim()\n        .substring(0, 3)\n        .padEnd(3, 'X')\n        .toUpperCase();\n\n    // 处理materials_coding，确保2位\n    const materialCode = String(materials_code || '00')\n        .trim()\n        .substring(0, 2)\n        .padEnd(2, '0')\n        .toUpperCase();\n\n    // 生成序列号\n    for (let i = beginseries; i <= endseries; i++) {\n        // 将数字部分格式化为7位（因为前5位已占用）\n        const numberPart = String(i).padStart(7, '0');\n        \n        // 组合成12位SN：3位型号 + 2位材料编码 + 7位序列号\n        const sn = `${modelPrefix}${materialCode}${numberPart}`.substring(0, 12);\n        \n        result.push({ \n            json: { \n                sn,\n                model: modelPrefix,\n                materialCode,\n                sequence: numberPart,\n                originalData: item.json\n            } \n        });\n    }\n});\n\n\nreturn result;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
