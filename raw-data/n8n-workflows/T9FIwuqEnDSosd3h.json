    {
      "parameters": {
        "jsCode": "let result = {\n    code: 200,\n    message: '验证通过',\n    errors: []\n};\n\n// 检查IP地址和mac地址非空且符合要求\nfor (const item of $input.all()) {\n    const req = item.json.query;\n    if (!isIPAddress(req.ip)) {\n        result.errors.push(`IP地址不合法: ${req.ip}`);\n    }\n}\n\n// 如果有错误，更新返回码和消息\nif (result.errors.length > 0) {\n    result.code = 201;\n    result.message = '参数验证失败';\n}\n\n// 检验是否是合法的IP地址\nfunction isIPAddress(ip) {\n    const ipv4Regex = /^(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9][0-9]|[0-9])(\\.(25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9][0-9]|[0-9])){3}$/;\n    return ipv4Regex.test(ip);\n}\n\n// 检验是否是合法的MAC地址\nfunction isValidMAC(mac) {\n    // 带统一分隔符（冒号或连字符）\n    const hasSeparator = /^([0-9A-F]{2})([:-])([0-9A-F]{2}\\2){4}[0-9A-F]{2}$/i.test(mac);\n    // 不带分隔符（12位十六进制）\n    const noSeparator = /^[0-9A-F]{12}$/i.test(mac);\n    return hasSeparator || noSeparator;\n}\n\nreturn result;"
      },
