      "name": "合并数据"
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  // 转换remark\n  item.json.remark = item.json.remark === \"0\" ? \"产线内维修\" : \"售后维修\";\n  \n  // 转换ismcu（仅在非空时转换）\n  if (item.json.ismcu != null && item.json.ismcu !== \"\") {\n    item.json.ismcu = item.json.ismcu === \"0\" ? \"是\" : \"否\";\n  }\n  \n  return item;\n});"
      },
