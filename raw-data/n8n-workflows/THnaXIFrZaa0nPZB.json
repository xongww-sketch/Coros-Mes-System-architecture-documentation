    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  md.data ->> 'product_type' AS product_type,\n  md.data ->> 'bad_message' AS bad_message,\n  md.data ->> 'repair_message' AS repair_message,\n  md.data ->> 'electric' AS electric,\n  md.data ->> 'uuid_old' AS uuid_old,\n  md.data ->> 'remark' AS remark,\n  md.data ->> 'ismcu' AS ismcu,\n  md.data ->> 'sn' AS sn,\n  md.data ->> 'employee_id' AS employee_id,\n  md.data ->> 'product_model_name' AS product_model_name,\n  md.createtime,\n  j.joborder_number\nFROM mes.machine_data md \nJOIN mes.joborder j ON j.joborder_id = (md.data->>'joborder_id')::bigint\nWHERE md.procedure_detail_id = 66\n  AND md.data ->> 'electric' IS NOT NULL\n  AND (\n    -- 当 $json.uuid_unique 为空时忽略此条件\n    '{{ $json.uuid_unique }}' = '' \n    OR \n    LOWER(md.data ->> 'uuid_unique') = LOWER('{{ $json.uuid_unique }}')\n  )\nAND (\n    -- 当 $json.sn 为空时忽略此条件\n    '{{ $json.sn }}' = '' \n    OR \n    LOWER(md.data ->> 'sn') = LOWER('{{ $json.sn }}')\n  )\n  AND (\n    -- 当 $json.employee_id 为空时忽略此条件\n    '{{ $json.employee_id }}' = '' \n    OR \n    LOWER(md.data ->> 'employee_id') = LOWER('{{ $json.employee_id }}')\n  )\nlimit 20000",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        540,
        -40
      ],
      "id": "feff3538-b48a-42d3-b282-da160513bb0b",
