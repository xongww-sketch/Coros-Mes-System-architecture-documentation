    {
      "parameters": {
        "jsCode": "// 方法 1：直接合并所有 items 的 JSON 数据\nconst mergedArray = items.map(item => item.json);\n\n// 或者方法 2：如果只需要特定字段\n// const mergedArray = items.map(item => ({ id: item.json.id, name: item.json.name }));\n\nreturn { json: { data: mergedArray } };"
