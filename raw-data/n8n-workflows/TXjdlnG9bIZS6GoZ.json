        "query": "SELECT \n    md.machine_data_id,\n    md.retroid_id,\n    md.procedure_detail_id,\n    md.history_procedure_id,\n    md.user_id AS machine_user_id,\n    md.machine_id,\n    md.data,\n    md.createtime AS machine_createtime,\n    hpd.history_procedure_id,\n    hpd.product_model_id,\n    hpd.procedure_name,\n    hpd.procedure_dataupload,\n    hpd.sop,\n    hpd.version,\n    hpd.createtime AS history_createtime,\n    hpd.common_proocedure,\n    hpd.procedure_type,\n    hpd.standard_labor,\n    hpd.standard_people,\n    hpd.cycle_time,\n    hpd.procedure_scheduling\nFROM \n    mes.machine_data md\nJOIN \n    mes.history_procedure_detail hpd\nON \n    md.history_procedure_id = hpd.history_procedure_id\nWHERE \n    md.retroid_id = '{{ $json.retroid_id }}'\nORDER BY md.createtime DESC;",
