    {
      "parameters": {
        "jsCode": "// 1. 获取输入数据\nconst inputItem = $input.first(); \n// 确保这里路径正确，看你第一条输入数据是在根目录还是在 binding_history 数组里\n// 根据你最开始提供的数据结构，应该是在 json.binding_history 里\nconst binding_history_data = inputItem.json.binding_history || [];\n\nlet resultList = [];\n\n// 基础格式化函数\nfunction prepareBindingHistoryTable(history) {\n    return history.map(item => ({\n        // 去掉名称末尾可能已存在的\"绑定\"或\"解绑\"\n        procedure_name: (item.procedure_name || \"\").replace(/(绑定|解绑)$/, ''),\n        createtime: item.createtime,\n        machine_data_id: item.machine_data_id,\n        binding_data: item.binding_data || '',\n        binding_action: item.binding_action,\n        procedure_detail_id: item.procedure_detail_id,\n        machine_data_id_old: item.machine_data_id_old,\n    }));\n}\n\nif (binding_history_data && binding_history_data.length > 0) {\n    // A. 初步处理 & 过滤掉 58工序\n    const formatted_table = prepareBindingHistoryTable(binding_history_data)\n        .filter(item => item.procedure_detail_id !== 58);\n\n    // B. 【关键步骤】找出所有“解绑动作”的目标 ID\n    // 逻辑：如果有 action='2'，它的 machine_data_id_old 指向的就是被解绑的那条记录\n    const unbindIds = formatted_table\n        .filter(item => item.binding_action === \"2\")\n        .map(item => item.machine_data_id_old);\n\n    // C. 【关键步骤】过滤有效绑定\n    // 1. 必须是绑定动作 (action='1')\n    // 2. 它的 ID 不在解绑列表中 (!unbindIds.includes)\n    const current_active_data = formatted_table.filter(item =>\n        item.binding_action === \"1\" &&\n        !unbindIds.includes(item.machine_data_id)\n    );\n\n    // D. 最终修饰（统一改成中文“绑定”显示）\n    resultList = current_active_data.map(item => ({\n        ...item,\n        procedure_name: item.procedure_name + \"绑定\",\n        binding_action: \"绑定\", // 既然只剩有效的，那状态肯定是绑定\n    }));\n}\n\n// 3. 返回 n8n 格式\nreturn resultList.map(item => ({\n    json: item\n}));"
      },
