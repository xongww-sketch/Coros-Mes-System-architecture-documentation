        "jsCode": "// 遍历所有输入数据\nreturn $input.all().map(item => {\n  return {\n    json: {\n      body: {\n        sn: item.json.retroid,  // 取出 retroid 的值\n        type: \"0\"               // 固定 type 为 \"0\"\n      }\n    }\n  };\n});"
