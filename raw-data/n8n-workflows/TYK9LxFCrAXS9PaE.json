      "parameters": {
        "jsCode": "// 获取 Execute Workflow 节点的数据\nconst executeWorkflowData = $('查询工序').first().json.data[0];\n\n// 获取 Webhook 节点的数据\nconst webhookData = $('Webhook').first().json;\n\n// 获取 input 数据\nconst inputData = $input.all();\n\n// 提取需要的信息\nconst procedureDetailId = executeWorkflowData.procedure_detail_id;\nconst historyProcedureId = executeWorkflowData.history_procedure_id;\nconst webhookBody = webhookData.body;\n\n// 构建最终输出结果，每个 inputData 的元素都将包含额外的数据\nconst resultArray = inputData.map(item => ({\n  retroid_id: item.json.retroid_id,\n  procedure_detail_id: procedureDetailId,\n  history_procedure_id: historyProcedureId,\n  data: webhookBody\n}));\n\nreturn resultArray;\n"
      },
