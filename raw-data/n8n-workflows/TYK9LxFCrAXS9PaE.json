        "jsCode": "// 获取上一个节点的所有数据\nconst items = $input.all();\n\n// 处理每个 item，封装成 { body: { sn: retroid } }\nconst result = items.map(item => {\n  return {\n    json: {\n      body: {\n        sn: item.json.retroid // 假设 retroid 是 item.json 里的字段\n      }\n    }\n  };\n});\n\n// 返回结果\nreturn result;"
