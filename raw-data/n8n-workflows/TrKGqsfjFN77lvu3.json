      "parameters": {
        "jsCode": "const res = {};\n// 将 snList 字符串转为数组，并去掉每个元素的单引号\nconst snList = $('入参判断和提取').first().json.snList.split(',').map(sn => sn.replace(/'/g, ''));\n\n// 收集所有输入的 retroid\nconst tempSnList = [];\nfor (const item of $input.all()) {\n  const retroid = item.json.retroid;\n  tempSnList.push(retroid);\n}\n\n// 使用 Set 获取到不存在工单信息的 snList\nconst snSet = new Set(tempSnList);\nconst noFindWoSnList = snList.filter(e => !snSet.has(e)); // 找不到对应工单的 sn 数组\n\nif (noFindWoSnList.length > 0) {\n  res.code = 1; // 表示异常，有 sn 找不到工单信息\n  res.snList = noFindWoSnList;\n} else {\n  res.code = 2; // 所有 sn 都存在工单信息\n  res.snList = $input.all().map(e => e.json);\n}\n\nreturn res;\n"
