      "parameters": {
        "operation": "executeQuery",
        "query": "WITH RecentMachineData AS (\n    SELECT\n        md.machine_data_id,\n        md.retroid_id,\n        md.procedure_detail_id,\n        md.data,\n        ROW_NUMBER() OVER (PARTITION BY md.retroid_id ORDER BY md.createtime DESC) as rn\n    FROM\n        mes.machine_data md\n    WHERE\n        md.procedure_detail_id = '79'\n)\n\nSELECT DISTINCT\n    j.joborder_number,\n    r.retroid\nFROM\n    mes.retroid r\nJOIN\n    RecentMachineData rmd ON r.retroid_id = rmd.retroid_id AND rmd.rn = 1\nJOIN \n    mes.joborder j \n    ON COALESCE(rmd.data->>'ticketNo', rmd.data->>'jobNumber') = j.joborder_number\nWHERE\n    r.retroid IN ({{ $json.snList }})\n  AND\n    j.status = '1'\n  AND \n    r.status IN ('1','2')",
        "options": {}
