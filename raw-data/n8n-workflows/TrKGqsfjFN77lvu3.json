    {
      "parameters": {
        "jsCode": "const res = {\n  code: null,\n  snList: [],\n};\n\n// 将 snList 字符串转为数组，并去掉每个元素的单引号\nconst snList = $('入参判断和提取').first().json.snList.split(',').map(sn => sn.replace(/'/g, ''));\n\n// 收集所有输入的 retroid 及其对应的工单号\nconst inputData = {};\nfor (const item of $input.all()) {\n  const retroid = item.json.retroid;\n  const jobnumber = item.json.jobnumber; \n  inputData[retroid] = jobnumber;\n}\n\n// 收集有工单信息的 SN 及其工单号\nconst findWoSnList = snList.filter(retroid => inputData.hasOwnProperty(retroid)).map(retroid => ({\n  retroid,\n  jobnumber: inputData[retroid]\n}));\n\nif (findWoSnList.length > 0) {\n  res.code = 2; // 表示找到有工单信息的 SN 列表\n  res.snList = findWoSnList; // 返回包含 SN 和对应工单号的对象列表\n} else {\n  res.code = 1; // 表示异常，所有 SN 都没有找到工单信息\n  res.snList = [];\n}\n\nreturn [res]; // 返回一个数组，其中包含结果对象\n"
