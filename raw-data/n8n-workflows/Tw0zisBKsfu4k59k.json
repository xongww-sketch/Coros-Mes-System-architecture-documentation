    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst linestage2 = {\n  ASSY: '组装',\n  PACK: '包装',\n  null: '空',\n};\n\nconst productcode = {\n  handloop: '穿戴式手环',\n  watch: '穿戴式手表',\n  pnd: '便携式导航',\n  deviceparts: '配件',\n  coros: '智能头盔',\n  null: '空',\n};\n\n\nfor (const item of $input.all()) {\n  item.json.productcode = productcode[item.json.productcode] ||    \n  item.json.productcode;\n  item.json.linestage2 = linestage2[item.json.linestage2] ||    \n  item.json.linestage2;  \n\n}\n\nreturn $input.all();\n  \n\n"
      },
      "id": "796b9c5e-8c21-4312-87be-e94a2f9c72a3",
      "name": "Code1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        260
      ]
    },
    {
      "parameters": {
        "jsCode": "// 从输入的第一项的数据获取 query 参数\nconst input = $input.all()[0] || {};\nconst query = input.json.query || {};\n\n// 如果没有传入参数，则初始化为空字符串\nconst filters = {\n  uuid: query.uuid || '',\n  jobnumber2: query.jobnumber2 || '',\n  ordernumber2: query.ordernumber2 || '',\n  boxid: query.boxid || ''\n};\n\n// 函数来创建LIKE语句部分\nfunction buildLikeClause(field, value) {\n  return value ? `${field} LIKE '%${value}%'` : null; // 仅在有值时生成条件\n}\n\n// 构建WHERE子句\nconst whereClauses = [\n  buildLikeClause('consm_barcodeinfo.uuid', filters.uuid),\n  buildLikeClause('consm_barcodeinfo.jobnumber2', filters.jobnumber2),\n  buildLikeClause('consm_barcodeinfo.ordernumber2', filters.ordernumber2),\n  buildLikeClause('consm_barcodeinfo.boxid', filters.boxid),\n].filter(Boolean); // 移除所有为null的条件\n\n// 如果没有WHERE条件，则使用1=1\nconst whereClauseString = whereClauses.length > 0 ? whereClauses.join(' AND ') : '1=1';\n\n// 拼接完整SQL查询\nconst sql = `\n  SELECT \n    consm_barcodeinfo.jobnumber2,\n    consm_barcodeinfo.uuid,\n    consm_barcodeinfo.productcode,\n    consm_barcodeinfo.linestage2,\n    consm_barcodeinfo.ordernumber2,\n    consm_barcodeinfo.boxid,\n    consm_barcodeinfo.createtime2,\n    consm_barcodeinfo.extrainfo,\n    consm_barcodeinfo.modifytime2,\n    consm_deviceweight.objweight\n  FROM consm_barcodeinfo\n  LEFT JOIN consm_deviceweight ON consm_barcodeinfo.uuid = consm_deviceweight.barcode\n  WHERE ${whereClauseString}\n`;\n\n// 返回SQL查询字符串\nreturn [\n  {\n    json: {\n      sql: sql.trim(),\n    }\n  }\n];\n"
      },
