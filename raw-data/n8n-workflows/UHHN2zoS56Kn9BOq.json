    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH latest_binding AS (\n  SELECT md.*\n  FROM mes.machine_data md\n  JOIN (\n    SELECT retroid_id, procedure_detail_id, MAX(machine_data_id) AS max_id\n    FROM mes.machine_data\n    WHERE procedure_detail_id = 79\n      AND retroid_id = '{{ $json.retroid_id }}'\n    GROUP BY retroid_id, procedure_detail_id\n  ) latest\n    ON md.retroid_id = latest.retroid_id\n   AND md.procedure_detail_id = latest.procedure_detail_id\n   AND md.machine_data_id = latest.max_id\n),\nall_unbinding AS (\n  SELECT ub.*\n  FROM mes.machine_data ub\n  WHERE ub.procedure_detail_id = 91\n    AND ub.retroid_id = '{{ $json.retroid_id }}'\n),\nmerged AS (\n  SELECT * FROM latest_binding\n  UNION ALL\n  SELECT * FROM all_unbinding\n)\nSELECT *\nFROM merged\nORDER BY machine_data_id DESC\nLIMIT 1;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        816,
        -16
      ],
