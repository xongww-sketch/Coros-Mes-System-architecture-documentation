    {
      "parameters": {
        "jsCode": "const batchNode = $('生成批量INSERT-出库').first();\nconst retroids = batchNode.json.retroids || [];\n\nif (retroids.length === 0) {\n  return [{ json: { query: 'SELECT 1 WHERE false', retroids: [] } }];\n}\n\nconst esc = (v) => \"'\" + String(v).replace(/'/g, \"''\") + \"'\";\nconst inList = retroids.map(esc).join(', ');\n\nconst query = `SELECT DISTINCT ON (retroid) *\nFROM mes_daily_data.production_detail\nWHERE retroid IN (${inList})\nORDER BY retroid, id DESC;`;\n\nreturn [{ json: { query, retroids } }];"
      },
      "id": "0c7c7240-d3d0-444e-98f5-ebac8914ac87",
