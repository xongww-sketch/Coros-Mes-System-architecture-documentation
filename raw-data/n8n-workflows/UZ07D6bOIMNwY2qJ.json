    {
      "parameters": {
        "jsCode": "const retryKey = 'delivery_retry_count';\nconst maxRetries = 3;\nconst staticData = $getWorkflowStaticData('global');\nconst currentCount = (staticData[retryKey] || 0) + 1;\nstaticData[retryKey] = currentCount;\n\nif (currentCount >= maxRetries) {\n  staticData[retryKey] = 0;\n  return [{ json: { action: 'skip', retries: currentCount, error: 'delivery批次写入失败已达最大重试次数' } }];\n}\n\nawait new Promise(resolve => setTimeout(resolve, 5000));\nreturn [{ json: { action: 'retry', retries: currentCount } }];"
      },
