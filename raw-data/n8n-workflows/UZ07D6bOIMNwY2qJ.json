    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) {\n  return [{ json: { query: null, count: 0, retroids: [] } }];\n}\n\nconst esc = (v) => v == null ? 'NULL' : \"'\" + String(v).replace(/'/g, \"''\") + \"'\";\n\nconst values = items.map(item => {\n  const j = item.json;\n  return '(' + esc(j.retroid) + ', ' + esc(j.channel) + ', ' + esc(j.delivery_time) + ')';\n}).join(',\\n  ');\n\nconst query = `INSERT INTO mes_daily_data.delivery_detail (retroid, channel, createtime)\nVALUES\n  ${values}\nON CONFLICT (retroid) DO NOTHING\nRETURNING id, retroid, channel, createtime;`;\n\nconst retroids = items.map(item => item.json.retroid);\nreturn [{ json: { query, count: items.length, retroids } }];"
      },
