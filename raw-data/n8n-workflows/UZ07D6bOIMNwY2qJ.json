    {
      "parameters": {
        "jsCode": "const input = $input.all();\nconst parseDate = (dateString) => {\n  const [date, time] = dateString.split(' ');\n  const [year, month, day] = date.split('-').map(Number);\n  const [hours, minutes, seconds] = time.split(':').map((v, i) => i === 2 ? parseFloat(v) : Number(v));\n  return new Date(Date.UTC(year, month - 1, day, hours, minutes, seconds));\n};\nconst startdate = parseDate(input[0].json.startdate);\nconst enddate = parseDate(input[0].json.enddate);\nreturn [{ json: { startdate: startdate.toISOString(), enddate: enddate.toISOString() } }];"
      },
