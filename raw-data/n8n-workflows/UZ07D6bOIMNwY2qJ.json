    {
      "parameters": {
        "jsCode": "// 从delivery_detail插入结果获取出库数据\nconst deliveryItems = $('批量写入delivery_detail').all();\nconst productionItems = $input.all();\n\n// production lookup by retroid\nconst prodMap = {};\nfor (const item of productionItems) {\n  if (item.json.retroid) {\n    prodMap[item.json.retroid] = item.json;\n  }\n}\n\nconst results = [];\nfor (const d of deliveryItems) {\n  const retroid = d.json.retroid;\n  if (!retroid) continue;\n  const prod = prodMap[retroid] || {};\n  \n  results.push({\n    json: {\n      retroid,\n      delivery_id: d.json.id || null,\n      channel: d.json.channel || null,\n      production_id: prod.id || null,\n      machine_type: prod.machine_type || null,\n      job_number: prod.job_number || null,\n      uuid: prod.uuid || null,\n      phase: prod.phase || null,\n      wifi_mac: prod.wifi_mac ? prod.wifi_mac.replace(/\\n/g, '') : null,\n      battery: prod.battery ? prod.battery.replace(/\\n/g, '') : null,\n      screen: prod.screen ? prod.screen.replace(/\\n/g, '') : null,\n      remark: prod.remark || null,\n      country: prod.country || null\n    }\n  });\n}\n\nif (results.length === 0) {\n  return [{ json: { _empty: true } }];\n}\nreturn results;"
      },
      "id": "b5bf1007-fdec-45ec-b09a-dbdc990b5596",
      "name": "合并出库+生产数据",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2816,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().filter(i => !i.json._empty);\n\nif (items.length === 0) {\n  return [{ json: { query: null, count: 0 } }];\n}\n\nconst esc = (v) => v == null ? 'NULL' : \"'\" + String(v).replace(/'/g, \"''\") + \"'\";\nconst now = new Date().toISOString();\n\nconst values = items.map(item => {\n  const j = item.json;\n  return '(' + [\n    esc(j.retroid), j.production_id || 'NULL', j.delivery_id || 'NULL',\n    esc(j.machine_type), esc(j.job_number), esc(j.uuid), esc(j.phase),\n    esc(j.wifi_mac), esc(j.battery), esc(j.screen), esc(j.remark),\n    esc(now), esc(j.channel), esc(j.country)\n  ].join(', ') + ')';\n}).join(',\\n  ');\n\nconst query = `INSERT INTO mes_daily_data.daily_info\n  (retroid, production_id, delivery_id, machine_type, job_number, uuid, phase, wifi_mac, battery, screen, remark, createtime, channel, country)\nVALUES\n  ${values}\nON CONFLICT (retroid) DO NOTHING;`;\n\nreturn [{ json: { query, count: items.length } }];"
      },
