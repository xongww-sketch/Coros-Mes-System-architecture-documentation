        "jsCode": "// 获取 n8n 的所有输入\nconst input = $input.all();\n\nlet output = [];\n\ntry {\n  // 遍历每个输入项\n  input.forEach(item => {\n    const jsonData = item.json;\n\n    // 确保输入中包含了我们需要的字段\n    if (jsonData && typeof jsonData.procedure_detail_id === 'string') {\n      // 解析 procedure_detail_id 中的 JSON 数据\n      const procedureDetails = JSON.parse(jsonData.procedure_detail_id).procedure_detail_id;\n\n      // 为每个 procedure_detail_id 创建一个新的对象，并保留其他属性\n      procedureDetails.forEach(detailId => {\n        output.push({\n          \"procedure_list_name\": jsonData.procedure_list_name,\n          \"product_model_id\": jsonData.product_model_id,\n          \"procedure_detail_id\": detailId.toString(),\n          \"procedure_list_id\": jsonData.procedure_list_id,\n          \"change_reason\": jsonData.change_reason,\n          \"version\": jsonData.version,\n          \"user_id\": jsonData.user_id\n        });\n      });\n    } else {\n      throw new Error('输入数据不符合预期格式');\n    }\n  });\n} catch (error) {\n  throw new Error('解析 procedure_detail_id 出错: ' + error.message);\n}\n\n// 将结果赋值给 n8n 的输出\nreturn output;\n"
      },
