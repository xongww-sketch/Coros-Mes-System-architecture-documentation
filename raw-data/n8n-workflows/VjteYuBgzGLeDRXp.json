    {
      "parameters": {
        "jsCode": "// 获取从当前节点输入的所有数据\nconst historyProcedureIds = $input.all().map(item => {\n  return parseInt(item.json.history_procedure_id, 10);\n});\n\n// 构建需要的输出格式\nconst historyProcedureData = {\n  \"history_procedure_id\": {\n    \"history_procedure_detail_id\": historyProcedureIds\n  }\n};\n\n// 获取'整理数据'节点的所有数据\nconst Outputs = $('整理数据').all();\n\nconst procedure_list_id = $(\"插入工序表\").first().json.procedure_list_id;\n\n// 将历史过程ID和整理数据组合\nconst combinedResult = Outputs.map(item => {\n  return {\n    ...item.json, // 导入'整理数据'中的所有字段\n    ...historyProcedureData, // 添加历史过程ID的数据\n    procedure_list_id:procedure_list_id\n  };\n});\n\nreturn combinedResult;\n"
      },
