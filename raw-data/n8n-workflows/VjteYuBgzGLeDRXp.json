    {
      "parameters": {
        "jsCode": "// 获取从当前节点输入的所有数据作为数组\nconst historyProcedureIds = $input.all().map(item => item.json.history_procedure_id);\n\n// 构建需要的输出格式，并使用 JSON.stringify 保持一致格式\nconst historyProcedureData = {\n  \"history_procedure_detail_id\": JSON.stringify({\n    \"history_procedure_detail_id\": historyProcedureIds.flat()\n  })\n};\n\n// 获取'整理数据'节点的所有数据\nconst Outputs = $('整理数据1').all();\n\n// 将历史过程ID和整理数据组合\nconst combinedResult = Outputs.map(item => {\n  return {\n    ...item.json,                // 导入'整理数据'中的所有字段\n    ...historyProcedureData  // 添加历史过程ID的数据\n  };\n});\n\nreturn combinedResult;\n"
      },
