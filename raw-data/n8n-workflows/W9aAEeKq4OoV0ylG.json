    {
      "parameters": {
        "jsCode": "const webhookData = $(\"整合数据1\").all();\nconst material = webhookData[0].json.body.material;\nconst bind_id =webhookData[0].json.body.bind_id;\nconst  procedure_detail_id=$('工序查询通用接口').first().json.data[0].procedure_detail_id\n\n\n  // 返回结果\n  return [\n    {\n      json: {\n        procedure_detail_id: procedure_detail_id,\n        material: material,\n        bind_id:bind_id\n      }\n    }\n  ];\n\n"
      },
