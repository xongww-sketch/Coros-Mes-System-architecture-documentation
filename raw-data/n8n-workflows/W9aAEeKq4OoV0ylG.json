    {
      "parameters": {
        "jsCode": "// 获取原始 body\nconst body = $('Webhook').first().json.body;\n\n// 构造新的 bind_id\nconst bind_id = body.bind_id2 !== undefined\n  ? `${body.bind_id1};${body.bind_id2}`\n  : body.bind_id1;\n\n// 构造新的 body\nconst newBody = {\n  ...body,\n  bind_id\n};\n\n// 删除旧的字段\ndelete newBody.bind_id1;\ndelete newBody.bind_id2;\n\n// 返回\nreturn [{\n  json: {\n    body: newBody\n  }\n}];"
