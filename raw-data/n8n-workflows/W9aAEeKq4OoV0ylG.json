    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT result.*\nFROM (VALUES (19), (62)) AS procs(proc_id)\nCROSS JOIN LATERAL (\n    SELECT md.*\n    FROM mes.machine_data md\n    WHERE md.procedure_detail_id = procs.proc_id\n      AND (md.data ->>'bind_id' = '{{ $json.material }}' \n           OR md.data ->>'unbind_id' = '{{ $json.material }}')\n    ORDER BY md.createtime DESC\n    LIMIT 1\n) AS result\nORDER BY result.createtime DESC\nLIMIT 1;\n",
        "options": {}
      },
