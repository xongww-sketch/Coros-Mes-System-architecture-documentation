    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    p.package_id, \n    p.package_name, \n    p.package_path, \n    r.resource_info \nFROM \n    mes.installation_package p \nJOIN \n    mes.resources r \nON \n    p.package_id = r.package_id \nWHERE \n    p.package_id = {{ $json.query.package_id }} and r.resource_mac= '{{ $json.query.mac }}'; \n",
        "options": {}
      },
