    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet packageList = {};\nfor (const item of $input.all()) {\n  const { package_name, package_id, application_name, package_path } = item.json.data[0];\n  \n  const resource_info_list = item.json.data.map(e => e.resource_info);\n\n  packageList = {\n    package_name,\n    resource_info_list,\n    package_id,\n    application_name,\n    package_path\n  };\n  console.log(package_name);\n}\n\nreturn packageList;"
      },
