    {
      "parameters": {
        "jsCode": "// 获取body中的参数值\nconst materials_code=$input.first().json.body.materials_code;\n\n// 使用正则表达式检查是否只包含英文字母\nconst isEnglish = /^[A-Za-z]+$/.test(materials_code);\n\n\n// 如果是英文，继续流程\nreturn { isValid: isEnglish, materials_code: materials_code };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1880,
        200
      ],
      "id": "5107c343-08b1-4bb7-8bef-e1366bc3f47b",
      "name": "验证编码格式是否正确",
      "alwaysOutputData": true,
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const materials_name = $input.first().json.body.materials_name\nconst materials_code = $input.first().json.body.materials_code\n\n//正则去除所有换行符\nconst cleanMaterials_name = materials_name.replace(/\\s|\\/n/g, '');\nconst cleanMaterials_code = materials_code.replace(/\\s|\\/n/g, '');\n\n// 返回清理后的数据\nreturn {\n  json: {\n    body: {\n      materials_name:     cleanMaterials_name,\n     materials_code: cleanMaterials_code\n    }\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2040,
        200
      ],
      "id": "71c491bf-d318-48eb-9a49-9325df2dcb56",
      "name": "去除空格"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select * from mes.vmaterial_code vc \nwhere vc.materials_name = '{{ $('去除空格').item.json.body.materials_name }}' and vc.productname ='{{ $('Webhook').item.json.body.productname }}'",
        "options": {}
