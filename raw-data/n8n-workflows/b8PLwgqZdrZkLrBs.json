    {
      "parameters": {
        "jsCode": "let res = [];\nfor (const item of $input.all()) {\n  let itemJson = item.json;\n  switch (itemJson.product_type) {\n    case 1:\n      itemJson.product_type = \"整机\";\n      break;\n    case 2:\n      itemJson.product_type = \"机头\";\n      break;\n    case 3:\n      itemJson.product_type = \"表带\";\n      break;\n    case 4:\n      itemJson.product_type = \"屏组件\";\n      break;\n    default:\n      itemJson.product_type = \"未知\";\n  }\n  res.push(itemJson);\n}\n\nreturn {\n  result: res,\n};\n"
      },
      "id": "c8b51f7f-d729-457b-be6c-6d044e2ac91d",
