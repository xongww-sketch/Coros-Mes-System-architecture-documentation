    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    p.product_id,\n    p.product_code,\n    p.product_color,\n    p.createtime,\n    p.product_type,\n    u.user_name,\n    m.product_model_name,\n    p.product_type\nFROM \n    mes.product_info p\nJOIN \n    mes.sys_user u ON p.user_id = u.user_id\nJOIN \n    mes.product_model m ON p.product_model_id = m.product_model_id\nWHERE \n    (CASE WHEN '{{ $json[\"body\"][\"product_model_id\"] }}' = '' THEN true ELSE p.product_model_id = {{ $json[\"body\"][\"product_model_id\"] | int }} END)\nAND \n    p.status = 1;\n\n\n\n\n\n",
