    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    p.product_id,\n    p.product_code,\n    p.product_color,\n    p.createtime,\n    p.product_type,\n    u.user_name,\n    p.product_type,\n    m.product_model_name\nFROM \n    mes.product_info p\nJOIN \n    mes.sys_user u ON p.user_id = u.user_id\nJOIN \n    mes.product_model m ON p.product_model_id = m.product_model_id\nwhere p.product_id= {{ $json.body.product_id}} and p.status = '1';",
        "options": {}
      },
