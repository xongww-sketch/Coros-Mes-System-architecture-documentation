    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst noExistData=[];\nconst deviceList=$('generated database records').all().map(e=>{\n  return e.json;\n});\nlet res=[];\nlet newDevice=true;\nfor (const item of $input.all()) {\n  //数据库中存在的数据\n  const existData=item.json.data;\n  let items=deviceList.filter(e=>{\n    //返回不在sql查询出来的设备记录，即是新设备，需要生成新设备记录\n     return !existData.some(pair => pair.resource_info.pid === e.pid && pair.resource_info.vid === e.vid)\n  })\n  existData.forEach(e=>{\n    if(e.resource_type==1){\n      noExistData.push(e);\n      newDevice=false;\n    }\n  })\n  res=[...noExistData,...items]\n}\n\nreturn {\n  newDeviceList:res,\n  newDevice:newDevice\n};"
      },
      "id": "cbcb3f4f-8018-4334-a10d-6eb11209850b",
      "name": "Code1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2880,
        100
      ]
    },
    {
      "parameters": {
        "fieldToSplitOut": "newDeviceList",
        "options": {}
      },
      "id": "15f8a50e-69e6-4e77-a19f-eb55d0af6d14",
      "name": "Split Out",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        3080,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst record={};\nlet deviceDetails=null;\nfor (const item of $input.all()) {\n  record.resource_mac=$('check result').all()[0].json.mac;\n  record.resource_type=1;\n  record.ip=$('check result').all()[0].json.ip;\n  deviceDetails=$('check result').all()[0].json.deviceDetails;\n}\nif(deviceDetails&&deviceDetails.length!==0){\n\n let records=deviceDetails.map(e=>{\n   const pid=e.idProduct.slice(2);\n   const vid=e.idVendor.slice(2);\n   const deviceName=e.productDescription;\n    return {\n      pid:pid,\n      vid:vid,\n      deviceName:deviceName,\n      resource_type:2\n    }\n  });\n  records.push(record);\n  return records;\n}else{\n  return record;\n}"
      },
      "id": "29ecaf97-a70b-405c-90ad-16fd90993e81",
      "name": "generated database records",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1900,
