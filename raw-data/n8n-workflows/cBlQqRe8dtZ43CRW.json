    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst result={};\nfor (const item of $input.all()){ \nconst ip=item.json.body.ip;\nconst mac=item.json.body.mac;\nconst deviceDetails=item.json.body.deviceDetails;\n  if(isValidIP(ip)&&isValidMAC(mac)){\n    result.ip=ip;\n    result.mac=mac;\n  }else if (isValidIP(ip)) {\n    result.code='201';\n    result.msg=`MAC:${mac}地址错误！`\n  }else if (isValidIP(mac)){\n     result.code='201';\n    result.msg=`IP:${ip}地址错误！`\n  }\n  if(deviceDetails.length!==0){\n    result.deviceDetails=deviceDetails;\n  }\n}\n//校验IP地址是否合法\nfunction isValidIP(ip) {\n  const ipv4Pattern = /^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$/;\n  return ipv4Pattern.test(ip);\n}\n//校验mac地址是否合法\nfunction isValidMAC(mac) {\n  const macPattern = /^([0-9A-Fa-f]{2}[:-]){5}([0-9A-Fa-f]{2})$/;\n  return macPattern.test(mac);\n}\n\nreturn result;"
      },
