      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT *\nFROM mes.resources r\nWHERE ($1=1 and r.resource_mac='{{ $json.resource_mac??'' }}') or ($1=2 and EXISTS (\n    SELECT 1\n    FROM mes.resources r_sub\n    WHERE r_sub.resource_info @> jsonb_build_object('pid', '{{ $json.pid }}', 'vid', '{{ $json.vid }}')::jsonb\n    AND r_sub.id = r.id\n))\n",
        "options": {
          "queryReplacement": "={{ $json.resource_type }}"
        }
      },
