    {
      "parameters": {
        "jsCode": "/**\n * 根据 processId 校验数据字段\n * @param {Object} data - 需要校验的数据对象\n * @returns {Object} - 校验结果，包括是否有效和错误信息\n */\nlet res = {};\nfunction validateData(data) {\n    // 初始化验证结果\n    const result = {\n        isValid: true,\n        errors: []\n    };\n\n    // 获取 processId\n    const processId = data.processId;\n\n    // 定义不同 processId 对应的必填字段\n    const requiredFieldsMap = {\n        '6': ['sn', 'componentId', 'orderNumber', 'issue', 'technician', 'repairTime'],\n    };\n\n    // 检查 processId 是否有效\n    if (!processId || !requiredFieldsMap.hasOwnProperty(processId.toString())) {\n        result.isValid = false;\n        result.errors.push('无效的 processId，必须是维修段的processId！');\n        return result;\n    }\n\n    // 获取对应的必填字段列表\n    const requiredFields = requiredFieldsMap[processId.toString()];\n\n    // 遍历必填字段，检查对应的字段是否存在且不为空\n    requiredFields.forEach(field => {\n        if (data[field] === undefined || data[field] === null || data[field] === '') {\n            result.isValid = false;\n            result.errors.push(`字段 '${field}' 对于 processId ${processId} 是必填项，且不能为空`);\n        }\n    });\n\n    // 在 validateData 函数中添加以下代码\n    // 定义需要是日期时间格式的字段\n    const dateTimeFields = ['testTime', 'repairTime'];\n\n    // 定义取值范围限定的字段\n    const valueConstraints = {\n        testResult: [1, 0]\n    };\n\n    // 定义日期时间格式的正则表达式 (YYYY-MM-DD HH:mm:ss)\n    const dateTimeRegex = /^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$/;\n\n    // 校验日期时间格式\n    requiredFields.forEach(field => {\n        if (dateTimeFields.includes(field)) {\n            // 使用正则表达式检查日期时间格式\n            if (!dateTimeRegex.test(data[field])) {\n                result.isValid = false;\n                result.errors.push(`字段 '${field}' 必须符合日期时间格式 YYYY-MM-DD HH:mm:ss`);\n            } else {\n                // 进一步检查日期的有效性\n                const date = new Date(data[field]);\n                if (isNaN(date.getTime())) {\n                    result.isValid = false;\n                    result.errors.push(`字段 '${field}' 包含无效的日期时间值`);\n                }\n            }\n        }\n    });\n\n    // 校验取值范围\n    Object.keys(valueConstraints).forEach(field => {\n        if (requiredFields.includes(field) && data[field]) {\n            if (!valueConstraints[field].includes(data[field])) {\n                result.isValid = false;\n                result.errors.push(`字段 '${field}' 的值必须是 ${valueConstraints[field].join(' 或 ')}`);\n            }\n        }\n    });\n\n    return result;\n}\n\nfor (const item of $input.all()) {\n    res = validateData(item.json.body);\n}\n\nreturn res;"
      },
