        "jsCode": "let inputData = $input.all();\nlet res = [];\nfor (const item of inputData) {\n    let itemJson = item.json;\n\n    // 直接处理 status 作为数字类型\n    switch (itemJson.status) {\n        case 1:\n            itemJson.status_description = \"已上传本地数据库\";\n            break;\n        case 2:\n            itemJson.status_description = \"已上传雪球平台\";\n            break;\n        case 3:\n            itemJson.status_description = \"已获取密匙\";\n            break;\n        default:\n            itemJson.status_description = \"未知类型\";\n            break;\n    }\n\n    res.push(itemJson);\n}\n\nreturn {\n    result: res\n};\n"
