    {
      "parameters": {
        "jsCode": "// 获取 PostgreSQL 查询结果\nconst dbResults = $input.all();\n\n// 处理结果为空的情况\nif (!dbResults || dbResults.length === 0) {\n  return {\n    json: {\n      code: 200,\n      data: {\n        list: []  // 明确返回空数组\n      }\n    }\n  };\n}\n\n// 映射数据到所需格式\nconst formattedList = dbResults.map(item => ({\n  retroid_generate_id: item.json.retroid_generate_id,  // 确保转换为字符串\n  joborder_number: item.json.joborder_number || \"\",\n  product_series: item.json.product_series || \"\",\n  product_model: item.json.product_model || \"\",\n  product_phase: item.json.product_phase || \"\",\n  beginseries: item.json.beginseries,  \n  endseries: item.json.endseries,\n  createtime:\n  item.json.createtime\n}));\n\n// 返回标准格式响应\nreturn {\n  json: {\n    code: 200,\n    data: {\n      list: formattedList\n    }\n  }\n};"
      },
