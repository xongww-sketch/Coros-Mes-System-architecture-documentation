      "parameters": {
        "operation": "executeQuery",
        "query": "select rg.retroid_generate_id,j.joborder_number, rg.product_series, rg.product_model, rg.product_phase\n, rg.beginseries, rg.endseries,\nrg.createtime\nfrom mes.joborder j \njoin mes.retroid_generate rg on rg.joborder_id = j.joborder_id\nwhere j.joborder_number ='{{ $('去除空格和换行字符').item.json.query.joborder }}' and rg.status = 0\nlimit 20000",
        "options": {}
      },
