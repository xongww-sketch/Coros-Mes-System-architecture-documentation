      "parameters": {
        "jsCode": "// 获取 PostgreSQL 查询结果\nconst dbResults = $input.all();\n\n// 处理结果为空的情况\nif (!dbResults || dbResults.length === 0) {\n  return {\n    json: {\n      code: 200,\n      data: {\n        list: []  // 明确返回空数组\n      }\n    }\n  };\n}\n\nconst formattedList = dbResults.map(item => {\n  const dataOld = item?.json?.data?.data_old || {};\n  const unbindData = item?.json?.data || {};\n\n  // 兼容 sn / retroid\n  const snValue =\n    (dataOld.sn ?? \"\").toString().trim() ||\n    (dataOld.retroid ?? \"\").toString().trim();\n\n  return {\n    proceduer_name: (dataOld.procedure_name ?? \" \").toString(),\n    sn: snValue,  // <= 改这里\n    createtime: item?.json?.createtime || \"\",\n    machine_data_id: item?.json?.machine_data_id || \"\",\n    unbind_id: (unbindData.unbind_id ?? \"\").toString().trim(),\n    remark: unbindData.remark || \"\"\n  };\n});\n\n// 返回标准格式响应\nreturn {\n  json: {\n    code: 200,\n    data: {\n      list: formattedList\n    }\n  }\n};"
      },
