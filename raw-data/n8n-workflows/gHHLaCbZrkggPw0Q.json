  "nodes": [
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet data={};\nfunction isEmpty(val) {\n  if(val==null) return true; //检查null或者undefined\n  if(typeof val=='string'&& val.trim() === '') return true;\n  if(Array.isArray(val)&&val.length===0) return true;\n  if(typeof val==='object'){\n    for (let key in val) {\n            if (val.hasOwnProperty(key)) {\n                if (!isEmpty(val[key])) {\n                    return false;\n                }\n            }\n  }\n    return true;\n  }\n  return false;\n  \n}\nfor (const item of $input.all()) {\n  const req=item.json.body;\n  let temp=[];\n  //遍历对象，判断对象的属性是否为空\n  Object.keys(req).forEach(key => {\n    if (isEmpty(req[key])) {\n       temp.push(key);\n    }\n});\n  if(temp.length===0){\n    data.code=0;\n    data.req=req;\n  }else{\n    data.code=1;\n    data.message=temp.map(e=>`属性 ${e} 为空！`).join('');\n  }\n}\n\nreturn data;"
      },
