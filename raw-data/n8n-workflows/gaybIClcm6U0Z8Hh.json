    {
      "parameters": {
        "jsCode": "// 获取项目数据\nconst items = $input.all();  // 获取所有传入的数据\n\n// 遍历所有项目并处理每个项目的数据\nitems.forEach(item => {\n  // 提取数字并转换成整数，然后放入数组中\n  const extractedNumber = parseInt(item.json.procedure_type.match(/\\d+/)[0]);\n  item.json.procedure_type = [extractedNumber];\n\n  // 转换其他相关字段到整数\n  item.json.procedure_detail_id = parseInt(item.json.procedure_detail_id);\n  item.json.history_procedure_id = parseInt(item.json.history_procedure_id);\n  item.json.user_id = parseInt(item.json.user_id);\n  item.json.procedure_scheduling = parseInt(item.json.procedure_scheduling);\n  item.json.procedure_upload = parseInt(item.json.procedure_upload);\n  item.json.cycle_time = parseInt(item.json.cycle_time);\n  item.json.standard_labour = parseInt(item.json.standard_labour);\n  item.json.standard_people = parseInt(item.json.standard_people);\n});\n\n// 返回处理后的项目\nreturn items;\n"
      },
