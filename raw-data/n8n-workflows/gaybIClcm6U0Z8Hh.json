    {
      "parameters": {
        "jsCode": "// 假设 inputData 是您希望处理的输入数据\nlet inputData = $input.all();\nconsole.log(\"Input Data:\", inputData); // 打印整个输入，检查其格式和内容\n\nlet res = [];\nfor (const item of inputData) {\n    let itemJson = item.json;\n\n    // 确保 procedure_type 是一个有效的数组并替换为中文描述\n    if (Array.isArray(itemJson.procedure_type) && itemJson.procedure_type.length > 0) {\n        itemJson.procedure_type_description = itemJson.procedure_type.map(type => {\n            switch (type) {\n                case 1:\n                    return \"加工\";\n                case 2:\n                    return \"搬运\";\n                case 3:\n                    return \"存储\";\n                case 4:\n                    return \"检验\";\n                default:\n                    return \"未知类型\";\n            }\n        }).join(\"，\"); // 使用逗号连接多个过程类型描述\n    } else {\n        itemJson.procedure_type_description = \"未知过程类型\";\n    }\n\n    // 处理 procedure_dataupload 字段并设置中文描述\n    if (itemJson.hasOwnProperty('procedure_dataupload')) {\n        switch (itemJson.procedure_dataupload) {\n            case 1:\n                itemJson.procedure_dataupload_description = \"无需上传数据\";\n                break;\n            case 2:\n                itemJson.procedure_dataupload_description = \"需要上传数据\";\n                break;\n            default:\n                itemJson.procedure_dataupload_description = \"未知状态\";\n                break;\n        }\n    } else {\n        itemJson.procedure_dataupload_description = \"未知状态\";\n    }\n\n    // 新增处理 procedure_scheduling 字段并设置中文描述\n    if (itemJson.hasOwnProperty('procedure_scheduling')) {\n        switch (itemJson.procedure_scheduling) {\n            case 1:\n                itemJson.procedure_scheduling_description = \"前加工\";\n                break;\n            case 2:\n                itemJson.procedure_scheduling_description = \"组装测试\";\n                break;\n            case 3:\n                itemJson.procedure_scheduling_description = \"成品测试\";\n                break;\n            case 4:\n                itemJson.procedure_scheduling_description = \"包装\";\n                break;\n            default:\n                itemJson.procedure_scheduling_description = \"未知阶段\";\n                break;\n        }\n    } else {\n        itemJson.procedure_scheduling_description = \"未知阶段\";\n    }\n\n    res.push(itemJson);\n}\n\n\nreturn {\n    result: res\n};\n"
      },
