    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH LatestHistoryProcedure AS (\n    SELECT\n        procedure_detail_id,\n        MAX(history_procedure_id) AS latest_history_procedure_id\n    FROM\n        mes.history_procedure_detail\n    GROUP BY\n        procedure_detail_id\n)\nSELECT \n    pd.procedure_detail_id,\n    pd.procedure_name,\n    pd.current_version,\n    pd.createtime,\n    pd.common_proocedure,\n    pd.checkrule,\n    hpd.history_procedure_id,\n    hpd.product_model_id,\n    hpd.sop,\n    u.user_name,\n    hpd.procedure_type,\n    pm.product_model_name, -- 从产品模型表中获取product_model_name\n    hpd.standard_labor,\n    hpd.standard_people,\n    hpd.cycle_time,\n    hpd.procedure_type,\n    hpd.procedure_dataupload\nFROM \n    mes.procedure_detail pd\nJOIN \n    LatestHistoryProcedure lhp\n    ON pd.procedure_detail_id = lhp.procedure_detail_id\nJOIN \n    mes.history_procedure_detail hpd \n    ON hpd.history_procedure_id = lhp.latest_history_procedure_id\nJOIN \n    mes.user u \n    ON hpd.user_id = u.user_id\nLEFT JOIN \n    mes.product_model pm \n    ON hpd.product_model_id = pm.product_model_id -- 通过product_model_id连接到产品模型表\nWHERE\n    pd.procedure_name = '{{ $('整理数据').item.json.procedure_name }}'\n    AND pd.status = '1'\n    AND pd.common_proocedure = 'false';\n\n\n",
        "options": {}
      },
      "id": "09026324-1269-41f3-845f-f9032cd50696",
