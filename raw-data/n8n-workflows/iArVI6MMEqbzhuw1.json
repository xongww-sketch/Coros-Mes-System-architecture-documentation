        "operation": "executeQuery",
        "query": "SELECT \n    \"data\"->>'joborder' AS joborder,\n    COUNT(*) AS occurrences\nFROM \n    mes.machine_data\nWHERE\n    retroid_id = '{{ $json.retroid_id }}'\n    AND procedure_detail_id = '{{ $json.procedure_detail_id }}'\n    AND \"data\"->>'joborder' = '{{ $json.jobnumber }}'\nGROUP BY \n    \"data\"->>'joborder'\nHAVING \n    COUNT(*) > 0;\n",
