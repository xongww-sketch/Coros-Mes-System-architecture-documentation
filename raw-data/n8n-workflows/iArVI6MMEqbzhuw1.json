    {
      "parameters": {
        "jsCode": "// 从 Execute Workflow 节点获取数据\nconst workflowData = $('查询工序').all()[0].json.data;\n\n// 从查询包装工单节点获取 retroid_id 和 jobnumber\nconst packagingData = $input.all();\nlet retroidId = null;\nlet jobnumber = null;\n\nif (packagingData.length > 0) {\n    // 直接从第一个数据元素中获取属性\n    retroidId = packagingData[0].json.retroid_id;\n    jobnumber = packagingData[0].json.jobnumber;\n}\n\n// 假设我们从 Execute Workflow 的第一个元素中提取信息\nconst latestWorkflowData = workflowData[0];\n\n// 返回结果\nreturn [\n  {\n    json: {\n      retroid_id: retroidId,\n      history_procedure_id: latestWorkflowData.history_procedure_id,\n      procedure_detail_id: latestWorkflowData.procedure_detail_id,\n      jobnumber: jobnumber\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
