    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    md.retroid_id,\n    md.machine_data_id,\n    md.data->>'ticketNo' AS jobNumber,\n    jo.joborder_id\nFROM \n    mes.machine_data md\nJOIN \n    mes.joborder jo ON md.data->>'ticketNo' = jo.joborder_number\n\nWHERE\n    retroid_id = '{{ $json.retroid_id }}' \nand\n  procedure_detail_id = '79'\n  and jo.status!='2';",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
