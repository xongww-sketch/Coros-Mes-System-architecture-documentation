      "parameters": {
        "jsCode": "// 获取输入数据\nconst items = $input.all();\n\n// 函数转换日期为时间戳\nfunction convertToTimestamp(data) {\n    return data.map(item => {\n        const unbindTimestamp = item.json.unbind_createtime \n            ? Math.floor(new Date(item.json.unbind_createtime).getTime() / 1000) \n            : 0;\n        \n        const latestBindTimestamp = item.json.latest_bind_createtime \n            ? Math.floor(new Date(item.json.latest_bind_createtime).getTime() / 1000) \n            : 0;\n\n        return {\n            json: {\n                unbind_createtime: unbindTimestamp,\n                latest_bind_createtime: latestBindTimestamp\n            }\n        };\n    });\n}\n\n// 返回处理后的数据\nreturn convertToTimestamp(items);\n"
      },
