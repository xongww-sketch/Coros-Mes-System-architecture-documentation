      "parameters": {
        "jsCode": "// 从 Webhook 获取 webhook 数据\nconst webhookData = $(\"Webhook\").all();\n\n// 获取 screen 数据，并立即使用 .trim() 去除 \\n 和空格\n// 为了防止数据为空导致报错，加了一个简单的判断 '?'\nconst rawScreen = webhookData[0].json.query.screen;\nconst screen1 = rawScreen ? rawScreen.trim() : null;\n\n// 从 Edit Fields 节点获取 retroid_id 数据\nconst editFieldsData = $(\"查询相关信息\").all();\nconst retroidId = editFieldsData.length > 0 ? editFieldsData[0].json.retroid_id : null;\n\n// 返回结果\nreturn [\n  {\n    json: {\n      retroidId: retroidId,\n      screen: screen1\n    }\n  }\n];"
