      "parameters": {
        "operation": "executeQuery",
        "query": "WITH material_unbind AS (\n  SELECT createtime\n  FROM mes.machine_data\n  WHERE \n    retroid_id = '{{ $json.data[0].retroid_id }}'\n    AND \"data\"->>'unbind_id' = '{{ $json.data[0].data.bind_id }}'\n  ORDER BY createtime DESC\n  LIMIT 1\n),\nlatest_sn_bind AS (\n  SELECT createtime\n  FROM mes.machine_data\n  WHERE \n    retroid_id = '{{ $json.data[0].retroid_id }}'\n    AND \"data\"->>'procedure_name' = 'SN与屏批次号绑定'\n  ORDER BY createtime DESC\n  LIMIT 1\n)\nSELECT \n  (SELECT createtime FROM material_unbind) AS unbind_createtime,\n  (SELECT createtime FROM latest_sn_bind) AS latest_bind_createtime;\n",
        "options": {}
