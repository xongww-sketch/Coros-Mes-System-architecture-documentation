    {
      "parameters": {
        "jsCode": "// 取出唯一参数\nconst modelName = $json.product_model_name;\n\n// 5 层 CTE，占位符用 $1\nconst sql = `\nWITH\nstep1 AS (\n    SELECT product_model.product_model_id\n    FROM mes.product_model\n    WHERE product_model.product_model_name = $1      -- ← 这里写成 $1\n),\nstep2 AS (\n    SELECT product_info.product_id\n    FROM mes.product_info\n    WHERE product_info.product_model_id IN (SELECT product_model_id FROM step1)\n),\nstep3 AS (\n    SELECT joborder.joborder_id\n    FROM mes.joborder\n    WHERE joborder.product_id IN (SELECT product_id FROM step2)\n),\nstep4 AS (\n    SELECT retroid.retroid_id\n    FROM mes.retroid\n    WHERE retroid.joborder_id IN (SELECT joborder_id FROM step3)\n),\nstep5 AS (\n    SELECT machine_data.machine_data_id,\n           machine_data.retroid_id,\n           machine_data.procedure_detail_id,\n           machine_data.history_procedure_id,\n           machine_data.user_id,\n           machine_data.machine_id,\n           machine_data.data,\n           machine_data.createtime,\n           machine_data.data_type\n    FROM mes.machine_data\n    WHERE machine_data.retroid_id IN (SELECT retroid_id FROM step4)\n    AND machine_data.procedure_detail_id IN (96,95,94,93)\n)\nSELECT * FROM step5;\n`;\n\nreturn {\n  query: sql,\n  values: [modelName]\n};\n\n// const sql = `SELECT 1 AS test_col`;\n// return { query: sql, values: [] };"
      },
