    {
      "parameters": {
        "jsCode": "const sn = $('Webhook').first().json.body.sn;\nconst uuid = $('Webhook').first().json.body.uuid;\nconst Procedure_name = $('Webhook').first().json.body.Procedure_name;\nconst Model = $('Webhook').first().json.body.Model;\nconst bgtime = $('Webhook').first().json.body.bgtime;\nconst edtime = $('Webhook').first().json.body.edtime;\nconst Machine_id = $('Webhook').first().json.body.Machine_id;\n\n\nconst cleanSn =sn.replace(/\\s|\\/n/g, '')\n\n\nreturn{json:{\n        body:{\n          sn:cleanSn,\n          uuid:uuid,\n          Procedure_name:Procedure_name,\n          Model:Model,\n          bgtime:bgtime,\n          edtime:edtime,\n          Machine_id:Machine_id\n}\n}\n}"
      },
