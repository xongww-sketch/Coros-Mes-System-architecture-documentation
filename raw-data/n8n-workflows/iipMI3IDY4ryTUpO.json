    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    md.retroid_id,\n    md.data->>'ticketNo' AS joborder_number,\n    jo.procedure_list_id,\n    jo.history_procedure_list_id\nFROM \n    mes.machine_data md\nJOIN \n    mes.joborder jo ON md.data->>'ticketNo' = jo.joborder_number\nJOIN\n    mes.retroid r ON md.retroid_id =\n  r.retroid_id\nWHERE\n   r.retroid = '{{ $json.query.retroid }}'\nand\n  md.procedure_detail_id = '79'\nand r.status !='3'\nand jo.status!='2';",
        "options": {}
      },
