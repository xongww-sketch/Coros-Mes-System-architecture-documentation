    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH latest_history AS (\n    SELECT json_array_elements_text((history_procedure_detail_id->>'history_procedure_detail_id')::json) AS detail_id\n    FROM mes.history_procedure_list\n    -- 这里做了修改：\n    -- 1. || \"\" 保证如果是 null 变成空字符串，防止模板报错\n    -- 2. NULLIF(..., '') 将空字符串变回 SQL 的 NULL\n    -- 3. ::int 将数字字符串转为整数，如果是 NULL 则保持 NULL\n    WHERE history_procedure_list_id = NULLIF('{{ $json.history_procedure_list_id || \"\"}}', '')::int\n)\nSELECT DISTINCT ON (hpd.procedure_detail_id) hpd.*\nFROM mes.history_procedure_detail hpd\nWHERE hpd.history_procedure_id IN (\n    SELECT detail_id::int FROM latest_history\n)\nAND hpd.procedure_dataupload = 2\nORDER BY hpd.procedure_detail_id, hpd.createtime DESC;",
        "options": {}
      },
