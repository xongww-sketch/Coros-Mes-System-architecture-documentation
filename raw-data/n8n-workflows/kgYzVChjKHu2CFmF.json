    {
      "parameters": {
        "jsCode": "const orderList = $(\"Aggregate1\").all()[0].json.orderList;\nconst inputItems = $input.all();\n\n// 创建物料代码映射用于快速查找\nconst inputMaterialMap = {};\nfor (const item of inputItems) {\n    inputMaterialMap[item.json.work_order_number] = item; // 存储整个对象以便引用\n}\n\n// 处理现有数据并添加新数据\nconst result = [...inputItems]; // 复制原始输入\n\nfor (const item of inputItems) {\n    const order = orderList.find(e => e.order_number === item.json.work_order_number);\n    \n    if (order) {\n        // 使用严格比较并处理可能的null/undefined\n        const isSameDesc = order.material_description === item.json.material_description;\n        const isSameQty = Number(order.production_quantity) === Number(item.json.production_quantity);\n        const isSameStart = order.production_date === item.json.production_date;\n        const isSameEnd = order.production_end_date === item.json.production_end_date;\n        const isSameZecnl4 = String(order.zecnl4 || '') === String(item.json.zecnl4 || '');\n        \n        if (isSameDesc && isSameQty && isSameStart && isSameEnd && isSameZecnl4) {\n            item.json.is_update = 0; // 没有变化\n        } else {\n            // 用新数据覆盖旧数据（包括zecnl4）\n            item.json.material_description = order.material_description;\n            item.json.production_quantity = order.production_quantity;\n            item.json.production_date = order.production_date;\n            item.json.production_end_date = order.production_end_date;\n            item.json.zecnl4 = order.zecnl4; // 确保更新这个字段\n            item.json.is_update = 1; // 标记为已更新\n            \n            console.log('更新记录:', {\n                work_order: order.order_number,\n                old_zecnl4: inputMaterialMap[order.order_number].json.zecnl4,\n                new_zecnl4: order.zecnl4\n            });\n        }\n    } else {\n        item.json.is_update = 0;\n    }\n}\n\n// 添加新数据（存在于orderList但不存在于input）\nfor (const order of orderList) {\n    if (!inputMaterialMap[order.order_number]) {\n        result.push({\n            json: {\n                material_code: order.material_code,\n                material_description: order.material_description,\n                base_bom_code: order.base_bom_code,\n                type: order.type,\n                order_status: order.order_status,\n                work_order_number: order.order_number,\n                order_create_time: order.order_create_time,\n                production_quantity: order.production_quantity,\n                production_date: order.production_date,\n                production_end_date: order.production_end_date,\n                zecnl4: order.zecnl4, // 确保包含此字段\n                is_update: 1 // 新数据标记为需要更新\n            }\n        });\n    }\n}\n\nreturn result;"
      },
