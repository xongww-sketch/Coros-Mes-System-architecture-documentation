      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst sapArr=$(\"判断SAP是否成功返回数据\").all()[0].json['ET_OUTPUT'];\nfor (const item of $input.all()) {\n  let childerns=[];\n  sapArr.forEach(e=>{\n    if (e['PLNBEZ']==item.json.material_code) {\n       childerns.push(e);\n    }\n  })\n  item.json.childerns=childerns;\n}\n\nreturn $input.all();"
