    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH temp_resources AS (\n  SELECT id, resource_name \n  FROM mes.resources \n  WHERE resource_name IS NOT NULL AND is_delete = 0\n)\nSELECT \n  a.application_id,\n  a.application_name, \n  a.application_version,\n  a.device_ids,\n  a.package_id,\n   STRING_AGG(r.resource_name, ',') AS resource_names, \n  p.package_name,\n  COUNT(*) OVER() AS total_count\nFROM \n  mes.application a\nJOIN \n  mes.installation_package p \n  ON a.package_id = p.package_id\nleft join \n  temp_resources r\n  on r.id=ANY(a.device_ids)\nWHERE \n  a.is_delete = 0 AND \n  p.is_delete = 0 {{ $json.sqlStr }}\n  GROUP BY\n    a.application_id,\n    a.application_name, \n    a.application_version,\n    a.device_ids,\n    a.package_id,\n    p.package_name\nLIMIT {{ $json.pageSize }} OFFSET {{ $json.offset }}",
        "options": {}
      },
