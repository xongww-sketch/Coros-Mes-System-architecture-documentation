    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COUNT(DISTINCT md.retroid_id) AS count\nFROM mes.machine_data AS md\nWHERE \n    -- 确保这里与创建的索引表达式完全一致\n    md.data->>'orderNumber' = $1 \n    AND md.procedure_detail_id = 79\n    AND NOT EXISTS (\n        SELECT 1 \n        FROM mes.machine_data AS md2 \n        WHERE md2.retroid_id = md.retroid_id\n          AND md2.procedure_detail_id = 91 \n          AND md2.createtime > md.createtime\n          -- 只有在其他条件都满足时才检查这个JSON，利用数据库短路特性\n          AND md2.data->>'procedure_detail_id_old' = '79'\n    );",
        "options": {
          "queryReplacement": "={{ $json.body }}"
        }
      },
