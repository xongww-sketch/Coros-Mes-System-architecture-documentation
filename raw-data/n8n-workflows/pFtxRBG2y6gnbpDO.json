      "parameters": {
        "jsCode": "function generateSQL(printType, ticketNo, printSecond) {\n    // 1. 基础字段选择\n    // 为了防止字段名冲突，我们明确指定表别名\n    let selectFields = `\n        j.joborder_number,\n        pi.product_code,\n        pi.product_color,\n        hpl.procedure_detail_id,\n        hpl.user_id,\n        p1.file_name AS file_name_main \n    `;\n\n    // 2. 基础表连接\n    let fromClause = `\n        FROM mes.joborder AS j\n        LEFT JOIN mes.product_info AS pi ON pi.product_id = j.product_id\n        -- 优化：只取需要的字段进行子查询，提高性能\n        LEFT JOIN (\n            SELECT procedure_list_id, procedure_detail_id, user_id,\n                   ROW_NUMBER() OVER (PARTITION BY procedure_list_id ORDER BY createtime DESC) AS rn \n            FROM mes.history_procedure_list\n        ) hpl ON j.procedure_list_id = hpl.procedure_list_id AND hpl.rn = 1\n    `;\n\n    // 3. 处理打印模版逻辑\n    let joinClause = \"\";\n    \n    // 强制类型转换，确保比较准确\n    printType = Number(printType);\n    printSecond = Number(printSecond);\n\n    // 确定主模版连接的字段 (printType 1=ID, 2=BoxID)\n    let mainJoinField = (printType === 2) ? \"j.printinfobox_id\" : \"j.printinfo_id\";\n\n    // 连接主打印模版表 (p1)\n    joinClause += ` LEFT JOIN mes.printinfo AS p1 ON ${mainJoinField} = p1.printinfo_id `;\n\n    // 4. 判断是否需要获取第二个模版\n    if (printSecond === 1) {\n        // 增加第二个文件名字段\n        selectFields += `, p2.file_name AS file_name_second `;\n        // 连接副打印模版表 (p2)，假设副ID字段仅在 printType=1 时有效，或者通用\n        // 如果 printType=2 也就是外箱也需要两个模版，逻辑同理\n        joinClause += ` LEFT JOIN mes.printinfo AS p2 ON j.printinfo_second_id = p2.printinfo_id `;\n    } else {\n        // 如果不需要，可以置空或者不需要处理，SQL保持清爽\n        selectFields += `, NULL AS file_name_second `; \n    }\n\n    // 5. 组装 SQL\n    // 简单的防注入处理 (如果 ticketNo 可能包含单引号)\n    let safeTicketNo = ticketNo.replace(/'/g, \"''\");\n    \n    let sql = `SELECT ${selectFields} ${fromClause} ${joinClause} WHERE j.joborder_number = '${safeTicketNo}' AND j.status = 1`;\n\n    return sql;\n}\n\n// 结果数组\nlet results = [];\n\nfor (const item of $input.all()) {\n    // 获取参数并生成SQL\n    let sqlStr = generateSQL(\n        item.json.printType, \n        item.json.ticketNo, \n        item.json.printSecond\n    );\n    \n    // 将结果存入数组，保留对应的 ticketNo 以便区分\n    results.push({\n        ticketNo: item.json.ticketNo,\n        sqlStr: sqlStr\n    });\n}\n\n// 返回处理后的数组\nreturn results;"
      },
