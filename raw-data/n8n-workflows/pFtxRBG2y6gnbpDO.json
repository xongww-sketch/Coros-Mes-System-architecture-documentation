    {
      "parameters": {
        "jsCode": "const res = {};\n// 提前缓存需要重复访问的数据\nconst returnData = $(\"返回数据\").all()[0]?.json || {};\nconst { printType } = $('Webhook').all()[0]?.json?.query || {};\n\n// 当不存在 printType 时直接返回\nif (typeof printType === 'undefined') return res;\n\n// 使用解构赋值和逻辑映射优化条件判断\nconst CONDITION_MAP = {\n  '制箱、扫描、装箱、封箱': 2,\n  '彩盒打印、贴贴纸、对号': 1\n};\n\nfor (const item of $input.all()) {\n  const { procedure_name, procedure_detail_id } = item.json;\n  // 通过映射表进行条件匹配\n  if (CONDITION_MAP[procedure_name] == printType) {\n    Object.assign(res, {\n      procedure_id: procedure_detail_id,\n      ticketNo: returnData.ticketNo,\n      path: returnData.path,\n      second_path:returnData.second_path,\n      product_code:returnData.product_code,\n      product_color:returnData.product_color,\n      user_id: returnData.user_id\n    });\n    // 如需优先取第一个匹配项可在此处 break\n  }\n}\n\nreturn res;"
      },
