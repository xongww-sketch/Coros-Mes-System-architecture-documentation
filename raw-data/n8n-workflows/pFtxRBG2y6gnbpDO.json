      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet res={};\nfor (const item of $input.all()) {\n  if(item.json.query.ticketNo){\n    res.ticketNo=item.json.query.ticketNo;\n    res.printType=item.json.query.printType;\n    res.printSecond=item.json.query.printSecond;\n    res.code=1;\n  }else{\n    res.code=2;\n    res.message='订单号不能为空！'\n  }\n  \n}\n\nreturn res;"
