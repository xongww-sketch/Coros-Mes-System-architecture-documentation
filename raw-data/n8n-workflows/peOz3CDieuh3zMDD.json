        "jsCode": "const data = $input.all(); // 确保从输入正确获取数据\n\n\n// 确保数据是一个数组\nif (!Array.isArray(data)) {\n  throw new Error('Data is not an array');\n}\n\nconst transformedData = data.map((item, index) => {\n  if (!item.json || typeof item.json !== 'object') {\n    throw new Error('Invalid json object');\n  }\n\n  const r = item.json;\n  // 计算 seqId，从1到50重复\n  const seqId = (index % 50) + 1;\n\n  return {\n    seqId: seqId.toString(),\n    mfrInfo: \"广东高驰运动科技有限公司\",\n    brand: \"高驰\",\n    barcode: r.code,\n    cateCode: \"B03\",\n    retailPrice: r.retailPrice,\n    region: \"44\",\n    isAiProduct: \"0\",\n    snCode: r.sn,\n    saleStatus: \"0\",\n    mfgTime: r.createTime,\n    specModel: r.model || '',    \n  };\n});\n\n\n// 根据需求返回或进一步处理 transformedData\nreturn transformedData;\n"
