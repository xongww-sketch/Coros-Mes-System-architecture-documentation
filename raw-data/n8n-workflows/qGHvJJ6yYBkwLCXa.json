    {
      "parameters": {
        "jsCode": "function constructOutput() {\n  // 获取所有输入数据\n  const allInput = $input.all();\n  \n  // 确保有输入，并且输入是一个数组并有内容\n  if (!allInput || !Array.isArray(allInput) || allInput.length === 0) {\n    throw new Error(\"无效的输入数据\");\n  }\n  \n  // 假设allInput是一个数组并取第一个对象来处理\n  const input = allInput[0];\n\n  // 根据调试信息检查json字段\n  if (!input.json || !input.json.sn || !input.json.cplc) {\n    throw new Error(\"输入中缺少'sn'或'cplc'字段\");\n  }\n\n  // 提取输入中的sn和cplc值\n  const sn = input.json.sn;\n  const cplc = input.json.cplc;\n  \n  // 根据sn确定对应的module值\n  let module = \"\";\n  if (sn.startsWith(\"W92\")) {\n    module = \"W942\";\n  } else if (sn.startsWith(\"W51\")) {\n    module = \"W541\";\n  } else if (sn.startsWith(\"W52\")) {\n    module = \"W542\";\n  }\n  \n  // 构建输出对象\n  const output = {\n    \"Content-Type\": \"application/json\",\n    \"x-snbps-vendor\": \"COROS\",\n    \"x-snbps-module\": module,\n    \"x-snbps-platformId\": \"2002\",\n    \"x-snbps-timestamp\": Date.now().toString(),\n    \"cplc\": cplc  // 添加cplc字段\n  };\n\n  // 返回输出对象\n  return output;\n}\n\n// 调用函数并输出结果\nreturn constructOutput();\n"
      },
