      "id": "855939a8-931f-4d99-a6a4-a7b5f8874c7d",
      "name": "判断存在工单的sn是否有料号"
    },
    {
      "parameters": {
        "jsCode": "let result = [];\nlet code2Item = { code: 2, snList: [] };\nlet code1Item = { code: 1, noFindMsnList: [] };\n\nfor (const item of $input.all()) {\n  if (item.json.code === 2) {\n    code2Item.snList.push(...item.json.snList);\n  } else if (item.json.code === 1) {\n    code1Item.noFindMsnList.push(...item.json.noFindMsnList);\n  }\n}\n\n// 优先检查code2Item，如果它的snList有内容，就只添加code2Item\nif (code2Item.snList.length > 0) {\n  result.push(code2Item);\n} else if (code1Item.noFindMsnList.length > 0) { \n  // 只有当code2Item的snList为空时才考虑code1Item\n  result.push(code1Item);\n}\n\nreturn result;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2464,
        736
      ],
      "id": "b79f8d47-616a-4caa-a3a9-7341310850c3",
      "name": "Code2"
    },
    {
      "parameters": {
        "jsCode": "const inputList = $input.all();\nlet code2Item = { \n  code: 2, \n  snList: [] \n};\n\n// 遍历输入列表并构建code2Item.snList\nfor (const item of inputList) {\n  code2Item.snList.push(item.json);\n}\n\n// 返回结果\nreturn [code2Item];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        768
      ],
      "id": "833b46a2-0d8a-42ed-921b-1a549c573ff2",
      "name": "Code3"
    },
    {
      "parameters": {
        "jsCode": "const inputList = $(\"移除空对象\").all();\nconst additionalInfoList = $input.all();\n\n// 初始化code2Item对象\nlet code2Item = {\n  code: 2,\n  snList: []\n};\n\n// 创建一个map映射job_number到additionalInfo\nconst additionalInfoMap = new Map(\n  additionalInfoList.map(item => [item.json.job_number, item])\n);\n\n// 填充snList, 根据job_number匹配additionalInfo\nfor (const inputItem of inputList) {\n  const jobNumber = inputItem.json.jobnumber;\n  const retroid = inputItem.json.retroid;\n  const additionalInfo = additionalInfoMap.get(jobNumber);\n\n  if (additionalInfo) {\n    code2Item.snList.push({\n      retroid: retroid,\n      job_number: jobNumber,\n      material_code: additionalInfo.json.material_code\n    });\n  } else {\n    const defaultJobNumber = \"default job number\"; // 这里可用适合的默认值\n    const defaultMaterialCode = \"default material code\"; // 同上\n\n    // 添加默认项\n    code2Item.snList.push({\n      retroid: retroid,\n      job_number: defaultJobNumber,\n      material_code: defaultMaterialCode\n    });\n  }\n}\n\nreturn [code2Item];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1776,
        608
      ],
      "id": "4be1c97b-5b14-4778-98bd-0a2db23cbdf4",
      "name": "将料号和sn进行组合"
    },
    {
      "parameters": {
        "jsCode": "// 获取如果节点的数据列表\nconst ifNodeData = $(\"If\").all(); // 假设这是从 if 节点获取数据的方式\nlet result = {\n  code: 1,\n  noFindMsnList: []\n};\n\n// 从数据中提取 snNoFindList\nfor (const item of ifNodeData) {\n  if (item.json.snNoFindList) {\n    // 将每个snNoFindList的元素作为retroid封装进noFindMsnList\n    item.json.snNoFindList.forEach(sn => {\n      result.noFindMsnList.push({ retroid: sn });\n    });\n  }\n}\n\n// 返回结果\nreturn [result];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1744,
        832
      ],
      "id": "187523a9-f6a9-4245-8cbb-57685d5d7b12",
      "name": "Code4"
    }
