    {
      "parameters": {
        "jsCode": "// 必选字符串\nlet str = function (v, l) {\n    if ((!v && typeof (v) != \"string\") || (l && v.length > l)) {\n        return true;\n    }\n}\n\n// 可选字符串\nlet strOpt = function (v, l) {\n    if (v !== undefined && (typeof (v) !== \"string\" || (l && v.length > l))) {\n        return true;\n    }\n}\n\n// 必选数字\nlet num = function (v, l) {\n    if (typeof (v) !== \"number\" || (l && String(v).length > l)) {\n        return true;\n    }\n}\n\n// 可选数字\nlet numOpt = function (v, l) {\n    if (v && (typeof (v) !== \"number\" || (l && String(v).length > l))) {\n        return true;\n    }\n}\n\n// 是否空值\nlet isEmpty = function (v) {\n    return v === undefined || v === null;\n}\n\nlet func = function (body, data) {\n    // ---校验列表\n    if (!body.snList || !Array.isArray(body.snList)) {\n        return { \"err\": \"error\", \"snList\": [] }; // 不符合规则时返回空数组\n    }\n    \n    if (body.snList.length < 1) {\n        return { \"err\": \"error\", \"msg\": \"snList error\", \"data\": body.snList };\n    }\n    \n    let snObj = {};\n    for (let i = 0; i < body.snList.length; i++) {\n        let sn = body.snList[i];\n        \n        if (typeof sn !== 'string') {\n            return { \"err\": \"error\", \"snList\": [] }; // 非字符串元素时返回空数组\n        }\n\n        sn = sn.replace(/\\r\\n/g, \"\").replace(/\\n/g, \"\").replace(/\\r/g, \"\");\n        \n        if (str(sn) || sn.length < 1) { // 合并空字符串校验\n            return { \"err\": \"error\", \"msg\": \"sn error\" };\n        }\n        if (!snObj[sn]) {\n            snObj[sn] = true;\n            data.snList = data.snList ? `${data.snList},'${sn}'` : `'${sn}'`; // 优化字符串拼接\n        }\n    }\n    return null; // 只有在没有错误的情况下才返回null，以便于后续处理\n}\n\nlet data = { snList: \"\" };\nlet err = func($input.all()[0].json.body, data);\nreturn err ? err : { \"err\": \"ok\", \"snList\": data.snList };\n"
      },
