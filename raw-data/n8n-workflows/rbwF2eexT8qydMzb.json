        "jsCode": "//必选字符串\nlet str = function (v, l) {\n    if ((!v && typeof (v) != \"string\") || (l && v.length > l)) {\n        return true;\n    }\n}\n//可选字符串\nlet strOpt = function (v, l) {\n    if (v != undefined && (typeof (v) != \"string\" || (l && v.length > l))) {\n        return true;\n    }\n}\n//必选数字\nlet num = function (v, l) {\n    if (typeof (v) != \"number\" || (l && String(v).length > l)) {\n        return true;\n    }\n}\n//可选数字\nlet numOpt = function (v, l) {\n    if (v && (typeof (v) != \"number\" || (l && String(v).length > l))) {\n        return true;\n    }\n}\n//是否空值\nlet isEmpty = function (v) {\n    return v === undefined || v === null;\n}\nlet func = function (body, data) {\n    //---校验列表\n    if (!body.snNoFindList || !Array.isArray(body.snNoFindList) || body.snNoFindList.length < 1) {\n        return { \"err\": \"error\", \"msg\": \"snNoFindList error\", \"data\": body.snNoFindList };\n    }\n    let snObj = {};\n    for (let i = 0; i < body.snNoFindList.length; i++) {\n        let sn = body.snNoFindList[i].replace(/\\r\\n/g, \"\").replace(/\\n/g, \"\").replace(/\\r/g, \"\");\n        if (str(sn) || sn.length < 1) { // 合并空字符串校验\n            return { \"err\": \"error\", \"msg\": \"sn error\" };\n        }\n        if (!snObj[sn]) {\n            snObj[sn] = true;\n            data.snNoFindList = data.snNoFindList ? `${data.snNoFindList},'${sn}'` : `'${sn}'`; // 优化字符串拼接\n        }\n    }\n}\nlet data = {snNoFindList:\"\"}\nlet err = func($input.all()[0].json, data);\nreturn err ? err : { \"err\": \"ok\", \"snList\": data.snNoFindList };\n"
