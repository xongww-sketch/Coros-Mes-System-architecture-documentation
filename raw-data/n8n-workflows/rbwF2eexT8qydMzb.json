    {
      "parameters": {
        "jsCode": "// 从输入数据中提取所有有效sn值\nconst inputData = $input.all().filter(item => item.json?.sn);\nconst snSet = new Set(inputData.map(item => item.json.sn));\n\nfunction isEmpty(obj) {\n  return !obj || Object.keys(obj).length === 0;\n}\n\nfunction shouldExcludeFromSnList(item) {\n  if (!item || isEmpty(item.json)) return true;\n  \n  const materialCode = item.json.material_code || '';\n  return materialCode.startsWith(\"TPVT\") || \n         materialCode.startsWith(\"HSW\");\n}\n\n// 获取Webhook请求中的snList\nconst webhookData = $(\"Webhook\").all();\nconst reqList = webhookData[0]?.json?.body?.snList || [];\n\nif (!reqList.length) return [];\n\nconst snNoFindList = [];\nconst snList = [];\nconst processedSNs = new Set();\n\nreqList.forEach(sn => {\n  if (!sn || processedSNs.has(sn)) return;\n  processedSNs.add(sn);\n  \n  const inputItem = inputData.find(item => item.json.sn === sn);\n  \n  if (!inputItem || shouldExcludeFromSnList(inputItem)) {\n    snNoFindList.push(sn);\n  } else {\n    snList.push(inputItem.json);\n  }\n});\n\nconst res = [];\n\nif (snNoFindList.length) {\n  res.push({ \n    snNoFindList, \n    type: \"1\" \n  });\n}\n\nif (snList.length) {\n  res.push({ \n    snList,\n    type: \"2\"\n  });\n}\n\nreturn res;"
      },
