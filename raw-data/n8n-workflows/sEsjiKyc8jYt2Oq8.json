    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DO $$\nBEGIN\n    -- 查询 status 值\n    IF EXISTS (SELECT 1 FROM mes.product_info WHERE product_id = {{ $json.product_id }} AND status = 1) THEN\n        -- 如果满足条件，则更新 status 为 2\n        UPDATE mes.product_info\n        SET status = 2 \n        WHERE product_id = {{ $json.product_id }};\n    END IF;\nEND $$;\n-- 再查询更新后的状态\nSELECT product_id, status\nFROM mes.product_info\nWHERE product_id = {{ $json.product_id }};",
        "options": {}
      },
