    {
      "parameters": {
        "jsCode": "const webhookData = $(\"判断所有必填项是否已填写\").all();\nconst material = webhookData[0].json.body.material;\nconst  procedure_detail_id=$input.first().json.procedure_detail_id\n\n\n  // 返回结果\n  return [\n    {\n      json: {\n        procedure_detail_id: procedure_detail_id,\n        material: material\n      }\n    }\n  ];\n\n"
