    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet result=[];\n\nfor (const item of $input.all()) {\n  let res={};\n  console.log(typeof item.json.data.form)\n  JSON.parse(item.json.data.form).forEach(el=>{\n    if(el.name===\"合作方名称\"){\n      res.name=el.value;\n    }\n  })\n  res.approval_name=item.json.data.approval_name;\n  res.instance_code=item.json.data.instance_code;\n  res.user_id=item.json.data.user_id;\n  result.push(res);\n}\n\nreturn result;"
      },
