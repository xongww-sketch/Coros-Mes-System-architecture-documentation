      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT  p.* \nFROM delivery_order_details d\nJOIN public.prototype_trial p\n    ON d.order_number = ANY(p.order_number)  -- 如果 order_number 是数组\nWHERE p.trial_expiration_date < CURRENT_DATE\n  AND p.is_remind = 1 AND d.watch_status=1;",
        "options": {}
