    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n\n//修改飞书获取到的token属性名\nfunction renameProperty(obj, oldProp, newProp) {\n    if (obj.hasOwnProperty(oldProp)) {\n        obj[newProp] = obj[oldProp];\n        delete obj[oldProp];\n    }\n}\n//获取到过期审批实例id\nlet res;\nlet result=[];\n//获取token\nif(!$input.all()[0].json.config){\n  //token过期重新获取token\n  const jsonObject=$('获取飞书token').all()[0].json;\n  renameProperty(jsonObject, 'tenant_access_token', 'token');\n  res=$('获取飞书token').all()[0];\n}else{\n  //token未过期则使用当前数据库中的token\n  $('获取到当前时间戳').all()[0].json.token=$('获取到当前时间戳').all()[0].json.config.token;\n  res=$('获取到当前时间戳').all()[0];\n}\n//循环便利过期列表生成对象包含token，和 instanceCode\n$('查询试用过期列表').all().forEach(item=>{\n  console.log(item)\n  result.push({\n    instanceCode:item.json.id,\n    token:res.json.token,\n    \n  })\n})\n\nreturn result;\n"
      },
