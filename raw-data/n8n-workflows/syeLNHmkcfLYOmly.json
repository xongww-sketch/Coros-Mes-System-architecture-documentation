    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst token=$('获取token并生成试用过期审批实例列表').all()[0].json.token;\nlet timeline=$input.all()[0].json.data.timeline;\n//去除重复的userId 使用mapObject 判断当前数组中是否有对应的userID，来进行去重\nconst messageObj=timeline.reduce((accumulator,currentValue)=>{\n  if(!accumulator.mapObject.hasOwnProperty(currentValue.user_id)){\n    accumulator.mapObject[currentValue.user_id] = true;  \n    accumulator.unique.push(currentValue);   \n  }\n  return accumulator;\n},{ unique: [], mapObject: {} }).unique;\nfor(let i=0;i<messageObj.length;i++){\n  messageObj[i].approval_name=$input.all()[0].json.data.approval_name;\n  messageObj[i].approval_code=$input.all()[0].json.data.approval_code;\n  messageObj[i].instance_code=$input.all()[0].json.data.instance_code;\n}\nreturn messageObj;"
      },
