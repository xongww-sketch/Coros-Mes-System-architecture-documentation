    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT *\nFROM (\n  SELECT *, ROW_NUMBER() OVER (PARTITION BY md.procedure_detail_id ORDER BY md.createtime DESC) AS rn\n  FROM mes.machine_data md\n  WHERE md.retroid_id = '{{ $json.retroidId }}'\n\n    AND md.procedure_detail_id IN ({{ $json.procedure_detail_ids ? $json.procedure_detail_ids : -1 }})\n) t\nWHERE t.rn = 1",
