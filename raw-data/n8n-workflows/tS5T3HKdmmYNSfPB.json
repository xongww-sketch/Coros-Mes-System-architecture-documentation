        "jsCode": "const arr = $input.all().map(item => ({\n  procedure_detail_id: item.json.procedure_detail_id,\n  machine_data_id: item.json.machine_data_id,\n  retroid_id: item.json.retroid_id\n}));\nreturn [{ json: { items: arr } }];"
