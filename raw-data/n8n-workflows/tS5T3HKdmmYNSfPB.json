    {
      "parameters": {
        "jsCode": "let webhookData = [];\ntry {\n  // 尝试获取 When Executed by Another Workflow 节点的数据\n  webhookData = $(\"When Executed by Another Workflow\").all();\n} catch(e) {\n  // 如果没这个节点，报错则用 Webhook 节点数据\n  webhookData = [];\n}\n\nif (!webhookData || webhookData.length === 0) {\n  try {\n    webhookData = $(\"Webhook\").all();\n  } catch(e) {\n    webhookData = [];\n  }\n}\n\nconst procedureNameFromWebhook = webhookData?.[0]?.json?.body?.procedure_name;\n\n// 从 input 获取所有过程数据\nconst inputData = $input.all();\n\n// 从 Edit Fields 节点获取 retroid_id 数据\nlet editFieldsData = [];\ntry {\n  editFieldsData = $(\"Edit Fields\").all();\n} catch (e) {\n  editFieldsData = [];\n}\nconst retroidId = editFieldsData.length > 0 ? editFieldsData[0].json.retroid_id : null;\n\n// 查找当前工序的数据\nconst currentProcedureIndex = inputData.findIndex(item => item.json.procedure_name === procedureNameFromWebhook);\n\nif (currentProcedureIndex !== -1) {\n  const currentProcedure = inputData[currentProcedureIndex].json;\n  const previousProcedure = currentProcedureIndex > 0 ? inputData[currentProcedureIndex - 1].json : null;\n\n  return [\n    {\n      json: {\n        currentProcedure: {\n          procedure_name: currentProcedure.procedure_name,\n          history_procedure_id: currentProcedure.history_procedure_id,\n          procedure_detail_id: currentProcedure.procedure_detail_id,\n          checkrule:currentProcedure.checkrule,\n        },\n        previousProcedure: previousProcedure ? {\n          procedure_name: previousProcedure.procedure_name,\n          history_procedure_id: previousProcedure.history_procedure_id,\n          procedure_detail_id: previousProcedure.procedure_detail_id,\n        } : null,\n        retroidId: retroidId\n      }\n    }\n  ];\n} else {\n  // 没找到匹配时也要 return array，避免 n8n 报错\n  return [];\n}"
      },
