        "jsCode": "let hasAnotherWorkflow = false;\nlet hasWebhook = false;\n\n// 假设集成数据节点名为“整合数据”，请替换成你的实际节点名\nconst integrationData = $(\"整合数据\").first();\nconst previousProcedureName = integrationData?.json?.previousProcedure?.procedure_name || \"\";\n\n// 检查 When Executed by Another Workflow 节点\ntry {\n  const anotherWorkflowData = $(\"When Executed by Another Workflow\").all();\n  if (anotherWorkflowData && anotherWorkflowData.length > 0) {\n    hasAnotherWorkflow = true;\n  }\n} catch (e) {}\n\n// 检查 Webhook 节点\nif (!hasAnotherWorkflow) {\n  try {\n    const webhookData = $(\"Webhook\").all();\n    if (webhookData && webhookData.length > 0) {\n      hasWebhook = true;\n    }\n  } catch (e) {}\n}\n\nif (hasAnotherWorkflow) {\n  return [{ json: { value: 0, previous_procedure_name: previousProcedureName } }];\n} else if (hasWebhook) {\n  return [{ json: { value: 1, previous_procedure_name: previousProcedureName } }];\n} else {\n  return [];\n}"
