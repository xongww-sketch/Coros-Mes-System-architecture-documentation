        "jsCode": "// ====== 判断入口类型部分(和你之前保持一致) ======\nlet hasAnotherWorkflow = false;\nlet hasWebhook = false;\n\ntry {\n  const anotherWorkflowData = $(\"When Executed by Another Workflow\").all();\n  if (anotherWorkflowData && anotherWorkflowData.length > 0) {\n    hasAnotherWorkflow = true;\n  }\n} catch (e) {}\n\nif (!hasAnotherWorkflow) {\n  try {\n    const webhookData = $(\"Webhook\").all();\n    if (webhookData && webhookData.length > 0) {\n      hasWebhook = true;\n    }\n  } catch (e) {}\n}\n\n// === 根据 lack_procedure_detail_ids 查询工序名称 ===\nconst lackIds = $input.item.json.lack_procedure_detail_ids || [];\n\nconst procedures = $(\"查询对应工序表\").all()\n  .filter(x => typeof x.json === 'object')\n  .map(x => x.json);\n\nconst lackNames = procedures\n  .filter(proc => lackIds.includes(Number(proc.procedure_detail_id)))\n  .map(proc => proc.procedure_name);\n\nconst previousProcedureName = lackNames.join(', ');\n\n// ======= 输出逻辑 =======\nif (hasAnotherWorkflow) {\n  return [{\n    json: {\n      value: 0,\n      previous_procedure_name: previousProcedureName\n    }\n  }];\n} else if (hasWebhook) {\n  return [{\n    json: {\n      value: 1,\n      previous_procedure_name: previousProcedureName\n    }\n  }];\n} else {\n  return [];\n}"
