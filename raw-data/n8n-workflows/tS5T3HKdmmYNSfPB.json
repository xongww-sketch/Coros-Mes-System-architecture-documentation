    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH latest_history AS (\n    SELECT json_array_elements_text((history_procedure_detail_id->>'history_procedure_detail_id')::json) AS detail_id\n    FROM mes.history_procedure_list\n    WHERE history_procedure_list_id = '{{ $json.history_procedure_list_id }}'\n),\nhistory_ids AS (\n    SELECT ARRAY_AGG(detail_id::int) AS ids\n    FROM latest_history\n),\nresult_data AS (\n    SELECT DISTINCT ON (hpd.procedure_detail_id)\n        hpd.*,\n        (SELECT array_position(ids, hpd.history_procedure_id) FROM history_ids) AS sort_order\n    FROM \n        mes.history_procedure_detail hpd\n    WHERE \n        hpd.history_procedure_id IN (\n            SELECT detail_id::int FROM latest_history\n        )\n    AND \n        hpd.procedure_dataupload = 2\n)\nSELECT *\nFROM result_data\nORDER BY sort_order;\n",
        "options": {}
      },
