    {
      "parameters": {
        "jsCode": "const datas = $(\"查询对应工序表\").all();\nconst retroidId = $input.first().json.retroidId;\n\n// 找到当前工序（通过 procedure_name 与 procedure_detail_id 最安全，或者取其一，根据情况）\nconst currentProcedure = $input.first().json.currentProcedure;\nconst currentItem = datas.find(\n  item => \n    item.json.procedure_name === currentProcedure.procedure_name && \n    item.json.procedure_detail_id === currentProcedure.procedure_detail_id\n);\n\nif (!currentItem) {\n  return [];\n}\nconst currentSortOrder = currentItem.json.sort_order;\n\n// 过滤出currentProcedure前的工序，排除特定名字\nconst result = datas.filter(item => \n  item.json.sort_order < currentSortOrder &&\n  item.json.procedure_name !== \"FPC ID与MIC ID绑定\" &&\n  item.json.procedure_name !== \"LCD与TP绑定\" &&\n  item.json.procedure_name !== \"PPG点胶-保压起始\"\n);\n\nconst procedure_detail_ids = result\n  .map(item => item.json.procedure_detail_id)\n  .join(',');\n\nreturn [\n  {\n    json: {\n      procedure_detail_ids,\n      retroidId\n    }\n  }\n];"
      },
