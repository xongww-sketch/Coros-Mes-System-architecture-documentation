      "id": "fd928b1c-d572-49b5-b39a-ffe4d5567785",
      "name": "整合查询解绑数据"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  md.*,\n  t.machine_data_id AS input_machine_data_id,\n  t.retroid_id AS input_retroid_id\nFROM\n  jsonb_to_recordset('{{ JSON.stringify($json.items) }}'::jsonb)\n      AS t(procedure_detail_id int, machine_data_id int, retroid_id int)\nJOIN LATERAL (\n  SELECT *\n  FROM mes.machine_data md\n  WHERE \n     md.retroid_id = t.retroid_id\n    AND md.data ->> 'machine_data_id_old' = t.machine_data_id::text\n  ORDER BY md.createtime DESC\n  LIMIT 1\n) md ON TRUE",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1856,
        0
      ],
      "id": "85061e51-8835-4534-8d01-535ac1466ffe",
      "name": "确认所有数据没有解绑",
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "Br2ubPbG6ZoVjCkh",
          "name": "mes"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 1. 获取所有工序节点数据\nconst allProcedureNodes = $('查询对应工序表').all();\n\n// 2. 要排除的工序名称\nconst excludeNames = [\n  'FPC ID与MIC ID绑定',\n  'LCD与TP绑定',\n  'PPG点胶-保压起始'\n];\n\n// 3. 找到要排除的procedure_detail_id们\nconst excludeIdsSet = new Set(\n  allProcedureNodes\n    .filter(node => excludeNames.includes(node.json.procedure_name))\n    .map(node => Number(node.json.procedure_detail_id))\n);\n\n// 4. 获取并过滤needIds\nconst needIdsStr = $('整合查询数据').first().json.procedure_detail_ids || '';\nconst needIds = needIdsStr\n  .split(',')\n  .map(id => Number(id))\n  .filter(id => !isNaN(id) && !excludeIdsSet.has(id));\n\n// ====== 核心修改区域 Start ======\n\n// A. 获取“物理上做过”的记录 (历史记录)\nconst finishedItems = $('查询所有前置工序是否完成').all();\nconst finishedIds = new Set(finishedItems.map(item => Number(item.json.procedure_detail_id)));\n\n// B. 获取“发生过解绑”的记录 (作废记录)\nconst unbindItems = $('确认所有数据没有解绑').all();\nconst unboundIds = new Set(unbindItems.map(item => {\n    const json = item.json;\n    \n    // 【修复点】：根据你的JSON结构，old_id在data对象下，与data_old平级\n    // 路径尝试1：如果字段在根目录（SQL直接查出）\n    if (json.procedure_detail_id_old) {\n        return Number(json.procedure_detail_id_old);\n    }\n    \n    // 路径尝试2：字段在 data 对象里\n    if (json.data && json.data.procedure_detail_id_old) {\n        return Number(json.data.procedure_detail_id_old);\n    }\n    \n    return 0; // 没找到则返回0，不影响逻辑\n}));\n\n// ====== 核心修改区域 End ======\n\nconst lackIds = [];\n\nfor (const id of needIds) {\n  // 判定逻辑：\n  // 1. 历史记录里有 (finishedIds) \n  // 2. 且不能在解绑名单里 (unboundIds)\n  \n  const hasHistory = finishedIds.has(id);\n  const isUnbound = unboundIds.has(id); \n\n  // 如果没做过，或者做过但被解绑了，都算未完成\n  if (!hasHistory || isUnbound) {\n    lackIds.push(id);\n  }\n}\n\nif (lackIds.length === 0) {\n  return [{\n    status: '0'\n  }];\n} else {\n  return [{\n    status: '1',\n    lack_procedure_detail_ids: lackIds\n  }];\n}"
      },
