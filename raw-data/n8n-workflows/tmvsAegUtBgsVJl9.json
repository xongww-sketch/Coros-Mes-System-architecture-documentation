    {
      "parameters": {
        "jsCode": "let res = [];\nfor (const item of $input.all()) {\n    let itemJson = item.json;\n   \n    res.push(itemJson);\n}\n\nreturn {\n    result: res\n};\n\n"
      },
      "id": "8a20e799-c584-45b0-9396-3885075e8adb",
      "name": "Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        384
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT    \n    p.procedure_list_id,\n    p.procedure_list_name,\n    p.createtime,\n    p.product_model_id,\n    u.user_name,\n    m.product_model_name,\n    p.current_version\nFROM \n    mes.procedure_list p\nJOIN \n    mes.sys_user u ON p.user_id = u.user_id\nJOIN \n    mes.product_model m ON p.product_model_id = m.product_model_id \nWHERE \n    p.status::integer = 1\n\n",
        "options": {}
      },
      "id": "113be89a-501e-40f1-a642-d6f2daca0b83",
      "name": "Postgres",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        704,
        272
      ],
      "credentials": {
        "postgres": {
          "id": "Br2ubPbG6ZoVjCkh",
          "name": "mes"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 获取所有输入数据\nconst inputData = $input.all();\n\n// 处理数据\ninputData.forEach(item => {\n  // 解析每个数据项\n  const json = item.json;\n  \n  // 将createtime解析为Date对象\n  let dateObject = new Date(json.createtime);\n  \n  // 增加8小时\n  dateObject.setHours(dateObject.getHours() + 8);\n  \n  // 将更新后的时间格式回填\n  json.createtime = dateObject.toISOString();\n});\n\n// 返回处理后的数据\nreturn inputData;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
