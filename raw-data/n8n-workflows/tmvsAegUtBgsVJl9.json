    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select    \n    p.procedure_list_id,\n    p.procedure_list_name,\n    p.createtime,\n    p.product_model_id,\n    u.user_name,\n    m.product_model_name\nFROM \n    mes.procedure_list p\nJOIN \n    mes.sys_user u ON p.user_id = u.user_id\nJOIN \n    mes.product_model m ON p.product_model_id = m.product_model_id \n\n    WHERE \n        p.procedure_list_id = {{ $json.body.procedure_list_id }} \n        AND p.status = '1'",
