  { key: \"105\", value: \"端子划伤\" },\n  { key: \"106\", value: \"端子缺口\" },\n  { key: \"107\", value: \"面圈与中框间隙大\" },\n  { key: \"108\", value: \"面圈与中框段差大\" },\n  { key: \"109\", value: \"面圈与中框溢胶\" },\n  { key: \"110\", value: \"PPG镜片与中框间隙大\" },\n  { key: \"111\", value: \"PPG镜片与中框段差大\" },\n  { key: \"112\", value: \"漏装耳通\" },\n  { key: \"113\", value: \"表圈装反\" },\n  { key: \"114\", value: \"表圈装错\" },\n  { key: \"115\", value: \"漏装生耳\" },\n  { key: \"116\", value: \"生耳装错\" },\n  { key: \"117\", value: \"表扣装反\" },\n  { key: \"118\", value: \"表舌装反\" },\n  { key: \"119\", value: \"长短表带装错\" },\n  { key: \"120\", value: \"漏放卡片\" },\n  { key: \"121\", value: \"附件盒方向放反\" },\n  { key: \"122\", value: \"封套印刷不良\" }\n];\n\n// 创建一个 value 到 key 的映射对象\nconst valueToKeyMap = {};\nbad_list.forEach(item => {\n  valueToKeyMap[item.value] = item.key;\n});\n\n// 获取输入数据\nconst inputData = $input.all();\n\n// 处理每个 item\nconst output = inputData.map(item => {\n  if (item.json.body && item.json.body.sn_list) {\n    const processedSnList = item.json.body.sn_list.map(snItem => {\n      if (snItem.bad_problem && Array.isArray(snItem.bad_problem)) {\n        // 转换 bad_problem 数组中的值为 key\n        snItem.bad_problem = snItem.bad_problem.map(problem => {\n          return valueToKeyMap[problem] || problem; // 如果找不到对应的 key，保留原值\n        });\n      }\n      return snItem;\n    });\n    \n    return {\n      ...item.json,\n      sn_list: processedSnList\n    };\n  }\n  return item.json;\n});\n\n// 返回处理后的数据\nreturn output;\n"
