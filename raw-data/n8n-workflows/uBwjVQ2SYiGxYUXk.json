    {
      "parameters": {
        "jsCode": "// 获取原始UUID值\nconst originalSn = $('Webhook').first().json.body.sn_list[0].SN\n\n\n// 删除第17和18位字符（索引16和17，因为JavaScript从0开始计数）\nconst snCut = originalSn.slice(0, 3) \n\nreturn{\n  json:{\n    body:{\n      sn:snCut\n    }\n  }\n}\n"
