    {
      "parameters": {
        "jsCode": "const queries = $input.all()[0].json.query || {};\nlet whereConditions = [];\n\n// 定义一个简单的转义函数，防止输入包含单引号导致SQL报错（例如: O'Neal）\nconst safeStr = (str) => String(str).replace(/'/g, \"''\");\n\nfor (const [key, value] of Object.entries(queries)) {\n  // 过滤空值 (null, undefined, \"\")\n  if (!value) continue;\n\n  const safeValue = safeStr(value);\n\n  switch (key) {\n    case 'create_time':\n      // 优化：通常建议使用 >= 和 <= 来包含边界\n      whereConditions.push(`${key} >= '${safeValue} 00:00:00' AND ${key} <= '${safeValue} 23:59:59'`);\n      break;\n\n    case 'begin_time':\n      // 注意：这里假设数据库确实有一个列叫 begin_time (如果本意是筛选 create_time，请看方案二)\n      whereConditions.push(`create_time >= '${safeValue}'`);\n      break;\n\n    case 'end_time':\n      whereConditions.push(`create_time <= '${safeValue}'`);\n      break;\n\n    case 'express_no':\n    case 'channel':\n    case 'retroid':\n    case 'order_number':\n    case 'sku_code': // 既然 select 里有这个，查询可能也需要\n    case 'box_id':\n      whereConditions.push(`${key} = '${safeValue}'`);\n      break;\n\n    default:\n      // 如果允许查询 JSON 中传入的任意字段作为过滤条件，保留此逻辑\n      // 否则建议删除 default 分支以防止非法列名注入\n      whereConditions.push(`${key} = '${safeValue}'`);\n      break;\n  }\n}\n\n// 组合 SQL\nconst whereClause = whereConditions.length > 0 ? `WHERE ${whereConditions.join(' AND ')}` : '';\nconst sqlQuery = `SELECT retroid, order_number, create_time, express_no, channel, sku_code, box_id FROM public.mes_delivery_order_details ${whereClause};`;\n\nreturn { sqlQuery };"
      },
