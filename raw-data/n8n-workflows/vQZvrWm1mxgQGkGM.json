    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH procedure_ids AS (\n    SELECT \n        pd.procedure_detail_id,\n        pd.procedure_name\n    FROM mes.procedure_detail pd \n    WHERE pd.procedure_name IN ('物料解除绑定', 'SN与UUID绑定')\n)\nSELECT * \nFROM mes.machine_data md\nWHERE EXISTS (\n    SELECT 1\n    FROM procedure_ids p\n    WHERE p.procedure_detail_id = md.procedure_detail_id\n    AND (\n        (p.procedure_name = 'SN与UUID绑定' \n         AND LOWER(md.data ->> 'uuid_unique') = LOWER('{{ $json.uuid_unique }}')\n        )\n        OR\n        (p.procedure_name = '物料解除绑定' \n         AND LOWER((md.data -> 'data_old')::json ->> 'uuid_unique') = LOWER('{{ $json.uuid_unique }}')\n        )\n    )\n)\nORDER BY md.createtime DESC  \nLIMIT 1;",
        "options": {}
      },
