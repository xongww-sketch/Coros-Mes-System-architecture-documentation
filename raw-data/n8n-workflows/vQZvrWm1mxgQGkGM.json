        "query": "WITH procedure_ids AS (\n    SELECT pd.procedure_detail_id \n    FROM mes.procedure_detail pd \n    WHERE pd.procedure_name IN ('物料解除绑定', 'SN与UUID绑定')\n)\nSELECT * FROM mes.machine_data\nWHERE (\n    (LOWER(data ->> 'uuid_unique') = LOWER('{{ $json.uuid_unique }}') \n     AND procedure_detail_id IN (\n         SELECT procedure_detail_id FROM procedure_ids WHERE procedure_detail_id IN (\n             SELECT procedure_detail_id FROM mes.procedure_detail WHERE procedure_name = 'SN与UUID绑定'\n         )\n     )\n    )\n    OR\n    (LOWER((data -> 'data_old')::json ->> 'uuid_unique') = LOWER('{{ $json.uuid_unique }}') \n     AND procedure_detail_id IN (\n         SELECT procedure_detail_id FROM procedure_ids WHERE procedure_detail_id IN (\n             SELECT procedure_detail_id FROM mes.procedure_detail WHERE procedure_name = '物料解除绑定'\n         )\n     )\n    )\n)\nORDER BY createtime DESC  limit 1;\n\n",
