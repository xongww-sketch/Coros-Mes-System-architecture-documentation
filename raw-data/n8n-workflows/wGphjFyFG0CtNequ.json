        "postgres": {
          "id": "Br2ubPbG6ZoVjCkh",
          "name": "mes"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "let res = [];\nfor (const item of $input.all()) {\n    let itemJson = item.json;\n    switch (itemJson.product_type) {\n        case 1:\n            itemJson.product_type = \"整机\";\n            break;\n        case 2:\n            itemJson.product_type = \"机头\";\n            break;\n        case 3:\n            itemJson.product_type = \"表带\";\n            break;\n        default:\n            itemJson.product_type = \"未知\";\n    }\n    res.push(itemJson);\n}\n\nreturn {\n    result: res\n};\n"
      },
