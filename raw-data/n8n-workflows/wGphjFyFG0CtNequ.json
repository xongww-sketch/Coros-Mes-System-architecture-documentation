    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    p.product_id,\n    p.product_code,\n    p.product_color,\n    p.createtime,\n    p.product_type,\n    u.user_name,\n    m.product_model_name,\n    p.product_type\nFROM \n    mes.product_info p\nJOIN \n    mes.user u ON p.user_id = u.user_id\nJOIN \n    mes.product_model m ON p.product_model_id = m.product_model_id\nWHERE \n    p.product_code= '{{ $('Webhook').item.json.body.product_code }}'\nAND \n    p.status = 1;",
        "options": {}
      },
      "id": "a2ddb7e9-1c33-415b-bbe2-35acc6f37c2b",
      "name": "查询模板明细行",
      "type": "n8n-nodes-base.postgres",
