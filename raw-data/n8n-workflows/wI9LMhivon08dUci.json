      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet result=[];\nlet res={};\nfunction toDatabaseDateTimeString(date) {\n  const pad = (number) => number.toString().padStart(2, '0');\n\n  const year = date.getFullYear();\n  const month = pad(date.getMonth() + 1); // 月份从0开始，所以+1\n  const day = pad(date.getDate());\n  const hours = pad(date.getHours());\n  const minutes = pad(date.getMinutes());\n  const seconds = pad(date.getSeconds());\n\n  return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;\n}\n\n// 获取当前时间\nconst now = new Date();\n const utcOffset = now.getTimezoneOffset() * 60000; // 获取UTC偏移量并转成毫秒\n  const chinaOffset = 8 * 60 * 60 * 1000;\n  const chinaTime=new Date(now.getTime() + utcOffset + chinaOffset);\nconsole.log(chinaTime);\n// 获取当前时间之前的半小时的数据\nconst oneHourAfter = new Date(chinaTime.getTime() - 60 * 60 * 500);\nlet json={\n  \"appkey\":\"176397\",\n  \"sessionkey\":\"1f9fd48ad3d14304a40c4a52df91646a\",\n  \"method\":\"gy.erp.trade.deliverys.get\",\n  \"start_create\":toDatabaseDateTimeString(oneHourAfter),\n  \"end_create\":toDatabaseDateTimeString(chinaTime),\n  \"page_no\":$input.all()[0].json.page+1\n}\nlet secret="REDACTED";\nlet str=secret+JSON.stringify(json)+secret;\nres.str=str;\nres.page=$input.all()[0].json.page+1,\nres.now=toDatabaseDateTimeString(chinaTime);\nres.oneHourAfter=toDatabaseDateTimeString(oneHourAfter);\nresult.push(res);\nreturn result;"
