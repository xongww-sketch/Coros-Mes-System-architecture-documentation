    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n//检查参数是否为空\nlet result=null;\nfor (const item of $input.all()) {\n  const applicationId=item.json.body.applicationId;\n  const applicationName=item.json.body.applicationName;\n  const appVersion=item.json.body.applicationVersion;\n  const packageId=item.json.body.packageId;\n  const deviceIds=item.json.body.deviceIds;\n  if((applicationName||appVersion||packageId||deviceIds)&&applicationId){\n    result=$input.all();\n  }else{\n    result={\n      code:201,\n      message:\"请求参数不能为空！\"\n    }\n  }\n}\n\nreturn result;"
      },
