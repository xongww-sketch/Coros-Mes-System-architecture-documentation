        "query": "SELECT \n    *\nFROM \n    mes.application \nWHERE \n    application_name = '{{ $json.body.applicationName }}' \n    AND application_version = '{{ $json.body.applicationVersion }}' \n    AND installation_package_id = {{ $json.body.packageId }} \n    AND device_ids @> ARRAY[{{ $json.body.deviceIds }}]\n    AND ARRAY[{{ $json.body.deviceIds }}] @> device_ids;",
