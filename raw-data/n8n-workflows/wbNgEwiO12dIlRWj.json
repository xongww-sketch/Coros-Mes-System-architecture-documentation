      "id": "5e9e1e6c-1eb0-4a11-b114-d2e63d7681b6",
      "name": "请选择对应工序和填写绑定信息"
    },
    {
      "parameters": {
        "jsCode": "// 1. 获取用户输入的模糊查询值并转为小写\nconst blindData = ($('Webhook').first().json.body.blind_data || '')\n  .toString()\n  .trim()\n  .toLowerCase(); \n\nconst matchedItems = [];\n\n$input.all().forEach((item) => {\n  // 确保能拿到 item.json，防止某些节点输出结构不同\n  const row = item.json ? item.json : item; \n  // 获取内部 data 对象，防空处理\n  const itemData = row.data || {}; \n\n  const finalSn = itemData.sn || itemData.SN || row.retroid || row.sn ||itemData.retroid || '未知设备';\n\n  // 4. 获取 createtime\n  // 优先取外层的时间戳，没有的话取 data 里面的字符串时间\n  const finalCreateTime = row.createtime || itemData.createtime;\n\n  // --- 核心修改结束 ---\n\n  // 5. 获取用于搜索的 id (bind_id)\n  // 兼容 itemData.bind_id 和 itemData.Detail\n  const rawBindId = itemData.bind_id || itemData.Detail || '';\n  const bindIdForSearch = rawBindId.toString().trim().toLowerCase();\n  \n  // 6. 模糊匹配逻辑\n  // 判断 bind_id 是否包含搜索词\n  if (bindIdForSearch.includes(blindData)) {\n    \n    // 7. 构造新的数据结构\n    const newData = {\n      ...itemData,              // 保留 data 里的 uuid, procedure_name 等原字段\n      createtime: finalCreateTime, // 统一时间字段\n      sn: finalSn               // 强制赋值为我们找到的 SN，确保结果里一定有 sn\n    };\n\n    matchedItems.push({ data: newData });\n  }\n});\n\nreturn matchedItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        192,
        -336
      ],
      "id": "4f1b3271-59d7-4908-ac9e-fc9ba6f694ea",
      "name": "查询对应信息"
    },
    {
      "parameters": {
        "jsCode": "function generateResponse(inputData) {\n  const bindingdata = inputData.map((item) => {\n    // 1. 锁定数据源行对象（兼容 n8n 不同节点输出）\n    const row = item.json ? item.json : item;\n\n    // 2. 获取 data 对象（你的 jsonb data）\n    const jsonData = row.data || {};\n\n    // 3. 获取 SN（兼容多种字段位置）\n    const serialNo =\n      jsonData.sn ||\n      jsonData.SN ||\n      row.retroid ||\n      jsonData.retroid;\n\n    // 4. 获取 binding_data（你要优先取 unbind_id）\n    // 兼容：unbind_id / bind_id / Detail / data_old.bind_id\n    const bindId =\n      jsonData.unbind_id ??\n      jsonData.bind_id ??\n      jsonData.Detail ??\n      jsonData.data_old?.bind_id;\n\n    // 5. 获取 createtime（外层优先，其次 data 内）\n    const createTime = row.createtime || jsonData.createtime;\n\n    return {\n      // 注意：unbind_id/bind_id 可能是数字（例如 1/58/59），trim 前要转字符串\n      binding_data: (bindId !== undefined && bindId !== null)\n        ? String(bindId).trim()\n        : JSON.stringify(jsonData),\n\n      // 注意：同样做字符串兜底，避免非字符串时报错\n      sn: serialNo\n        ? String(serialNo).trim()\n        : '未知设备',\n\n      createtime: createTime,\n    };\n  });\n\n  return {\n    code: \"200\",\n    binding_data: bindingdata,\n  };\n}\n\n// 执行（n8n）\nconst inputData = $input.all();\nreturn generateResponse(inputData);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        384,
        -336
      ],
      "id": "fb5a85ba-6703-41e5-a402-aeedbedd8a6b",
      "name": "整合数据结构"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "select \n  md.data,\n  md.createtime,\n  r.retroid\n  from mes.machine_data md \njoin mes.retroid r on r.retroid_id = md.retroid_id::INTEGER \nwhere r.joborder_id ='{{ $json.body.joborder_id }}' and md.procedure_detail_id ='{{ $json.body.procedure_detail_id }}'\norder by md.createtime desc",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
