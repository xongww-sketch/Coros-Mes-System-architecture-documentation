      ],
      "id": "f195e7ae-4ae9-4bc1-b8af-3d63325bd0bd",
      "name": "Respond to Webhook1"
    },
    {
      "parameters": {
        "jsCode": "// 获取用户输入的模糊查询值并转为小写\nconst blindData = ($('Webhook').item.json.body.blind_data || '')\n  .toString()\n  .trim()\n  .toLowerCase(); // 新增 toLowerCase()\n\nconst matchedItems = [];\n\n$input.all().forEach((item) => {\n  const itemData = item.json.data;\n  const createTime = item.json.createtime;\n  const sn = item.json.retroid\n\n  // 构造新的数据结构（保持不变）\n  const newData = {\n    ...itemData,\n    createtime: createTime,\n    sn:sn\n  };\n\n  // 获取小写的 bind_id 并保持核心逻辑\n  const bindId = ((itemData.bind_id || '').toString().trim()).toLowerCase(); // 新增 toLowerCase()\n  \n  // 现在比较时会忽略大小写\n  if (bindId.includes(blindData)) {\n    matchedItems.push({ data: newData });\n  }\n});\n\nreturn matchedItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        176
      ],
      "id": "b52ef8da-3beb-46a4-b874-d24454710038",
      "name": "查询对应信息1"
    },
    {
      "parameters": {
        "jsCode": "function generateResponse(inputData) {\n  const bindingdata = inputData.map(item => {\n    // 1. 锁定数据源行对象\n    // n8n 中，如果你是从 SQL 节点出来的，数据通常在 item.json 下\n    const row = item.json ? item.json : item;\n\n    // 2. 获取 jsonb \"data\" 字段的内容 (即你的入参结构)\n    const jsonData = row.data || {};\n\n    // 3. 获取 SN 的逻辑 (修改点)\n    // 优先级 1: jsonData.sn (小写) -> 你提到的入参中最下面的 sn\n    // 优先级 2: jsonData.SN (大写) -> 入参中可能为空的 SN\n    // 优先级 3: row.retroid -> SQL 联表查询出来的 retroid 字段 (通常在 data 外面)\n    // 优先级 4: jsonData.retroid -> 兼容旧数据，防止 retroid 记在 jsonb 里面\n    const serialNo = jsonData.sn || jsonData.SN || row.retroid || jsonData.retroid;\n\n    // 4. 获取 bind_id\n    const bindId = jsonData.bind_id || jsonData.Detail;\n\n    return {\n      // 如果 bind_id 为空或不存在，返回 N/A\n      binding_data: bindId ? bindId.trim() : 'N/A', \n      \n      // 如果找不到任何 SN 或 Retroid，返回 未知设备\n      sn: serialNo ? serialNo.trim() : '未知设备', \n      \n      // 时间优先取 SQL 查询出的主字段时间，其次取 jsonb 里的记录时间\n      createtime: row.createtime || jsonData.createtime\n    };\n  });\n\n  return {\n    code: \"200\",\n    binding_data: bindingdata\n  };\n}\n\n// 执行\nconst inputData = $input.all();\nreturn generateResponse(inputData);"
      },
