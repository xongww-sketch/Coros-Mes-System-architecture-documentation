    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * \nFROM mes.machine_data md \nWHERE\n    md.data ->>'material' = '{{ $json.bind_id }}'\n  ORDER BY createtime DESC\n  LIMIT 1",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        720,
        -208
      ],
      "id": "19f8ca82-2511-48e7-95f5-690616ae5561",
      "name": "查询对应时间阈值",
      "credentials": {
        "postgres": {
          "id": "Br2ubPbG6ZoVjCkh",
          "name": "mes"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// 针对 Code 节点\nconst inputItems = $input.all(); \nconst row = inputItems[0].json;\n\nconst createTime = new Date(row.createtime);\n\n// --- 修改开始 ---\n// 1. 先尝试转为数字，如果转换失败(NaN)则默认为 0\nlet tempLimit = Number(row.data.timelimit) || 0;\n\n// 2. 如果小于 1，则强制归零，否则保留原值\nconst timeLimit = tempLimit < 1 ? 0 : tempLimit;\n// --- 修改结束 ---\n\nconst createTimestamp = createTime.getTime();\n\n// 计算过期时间\nconst addTimestamp = createTime.getTime() + timeLimit * 60 * 60 * 1000;\nconst nowTimestamp = Date.now();\n\n// 输出新数据\nreturn [\n  {\n    json: {\n      createTimestamp,        \n      timeLimitHours: timeLimit, // 这里输出的就会是 0 (如果原始值是 0.5 或 0.1)\n      afterAddTimestamp: addTimestamp,   \n      nowTimestamp           \n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
