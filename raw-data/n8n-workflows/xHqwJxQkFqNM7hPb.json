      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet watchList=[];\nlet helmetList=[];\nfor (const item of $input.all()) {\n  if(item.json.productcode=='watch'){\n    watchList.push(item.json)\n  }else{\n    helmetList.push(item.json)\n  }\n}\n\nreturn {\n  watchList:watchList,\n  helmetList:helmetList\n};"
      },
