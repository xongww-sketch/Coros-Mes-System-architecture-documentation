  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet isVaild=false;\nlet queryParam={};\nfor (const item of $input.all()) {\n  const regex = /^\\d{4}-\\d{2}-\\d{2}$/;\nif(regex.test(item.json.query.begintime)&&regex.test(item.json.query.endtime)){\n    isVaild=true;\n  queryParam.begintime=item.json.query.begintime+\" 00:00:00\";\n  queryParam.endtime=item.json.query.endtime+\" 23:59:59\"\n  }\n}\n\nif(isVaild){\n  return queryParam;\n  \n}else{\n  return {\n    errorMsg:\"请求参数格式不正确！\"\n  }\n}"
      },
      "id": "f79fa636-7504-4634-9fa5-def443200da3",
      "name": "Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        760,
        260
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  a.jobnumber,\n  a.ordernumber,\n  a.productcode,\n  a.clientcode,\n  a.retroid,\n  a.uuid,\n  a.baseline,\n  a.BaseLinebatch as BaseLineBatch,\n  a.BatteryBatch,\n  a.createtime,\n  a.modifytime,\n  a.Channel,\n  b.MachineType,\n  b.phase\nFROM\n  YFConsumer.dbo.consm_barcodebindinfo a\nLEFT JOIN (\n  SELECT\n    retrospectorder,\n    phase,\n    MachineType,\n    createtime AS latest_createtime,\n    ROW_NUMBER() OVER (PARTITION BY retrospectorder ORDER BY createtime DESC) AS rn\n  FROM\n    YFConsumer.dbo.consm_jobinfo\n) b\nON a.ordernumber = b.retrospectorder AND b.rn = 1\nWHERE\n  a.createtime >= '{{ $json.begintime }}'\n  AND a.createtime <= '{{ $json.endtime }}';\n"
      },
