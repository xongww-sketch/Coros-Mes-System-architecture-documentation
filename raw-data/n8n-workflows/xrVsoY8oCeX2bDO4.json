      "parameters": {
        "jsCode": "const reqList = $(\"组装参数请求\").all();\nconst inputItems = $input.all();\n\n// 创建输入项的映射表 \nconst inputMap = new Map(inputItems.map(item => [item.json.retroid, item]));\n\n// 使用map处理请求列表\nreturn reqList.map(reqItem => {\n  const inputItem = inputMap.get(reqItem.json.retroid);\n  \n  if (inputItem) {\n    // 创建请求数据的深拷贝\n    const reqDataCopy = JSON.parse(JSON.stringify(reqItem.json));\n    const {procedure_details_id,...rest}=reqDataCopy\n    const jobNumber=inputItem.json.jobnumber\n    // 返回新对象\n    return {\n      ...reqItem,\n      json: {\n        retroid_id: inputItem.json.retroid_id,\n        procedure_details_id:procedure_details_id,\n        data: {...rest,jobNumber}  // 保存原始数据的拷贝\n      }\n    };\n  }\n  \n  // 未匹配项保持原样\n  return reqItem;\n});"
      },
