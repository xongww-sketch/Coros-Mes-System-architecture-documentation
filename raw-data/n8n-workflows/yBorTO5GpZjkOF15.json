    {
      "parameters": {
        "jsCode": "const snData = $(\"查询该工单生成的sn\").all().map(item => item.json);\nconst bindingData = $(\"统计拥有绑定数据的sn\").all().map(item => item.json);\n\n// 打印拿到的工单SN数据\nconsole.log(\"snData:\", snData);\n\n// 打印拿到的绑定SN数据\nconsole.log(\"bindingData:\", bindingData);\n\n// 处理出已绑定id集合（注意类型都做字符串保证一致）\nconst bindingIdSet = new Set(bindingData.map(x => String(x.retroid_id)));\n\n// 打印已绑定id集合\nconsole.log(\"bindingIdSet:\", [...bindingIdSet]);\n\n// 做差集过滤\nconst resultData = snData\n    .filter(sn => !bindingIdSet.has(String(sn.retroid_id)))\n    .map(sn => ({\n        retroid_id: sn.retroid_id,\n        retroid: sn.retroid\n    }));\n\n// 打印最后未绑定的retroid_id\nconsole.log(\"未绑定retroid_id:\", resultData.map(d=>d.retroid_id));\n\nconst result = [{\n    json: {\n        code: 200,\n        msg: \"查询未绑定数据sn成功\",\n        data: resultData\n    }\n}];\n\nreturn result;"
      },
