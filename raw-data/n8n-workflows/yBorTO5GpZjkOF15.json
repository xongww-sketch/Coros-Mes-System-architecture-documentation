    {
      "parameters": {
        "jsCode": "const fqcData = $('查询fqcid').first().json;\nconst fqcId = fqcData ? fqcData.procedure_detail_id : null; // 获取到 58\n\nconst items = $input.all()\n    .map(item => item.json)\n    .filter(item => {\n        // 原有逻辑：剔除 13\n        if (item.procedure_detail_id === 13) {\n            return false;\n        }\n        \n        // 新增逻辑：剔除 FQC 的 ID (即 58)\n        // 只有当 fqcId 存在，且当前条目的 id 等于 fqcId 时才剔除\n        if (fqcId !== null && item.procedure_detail_id === fqcId) {\n            return false;\n        }\n\n        return true;\n    });\n\n// --- 下列逻辑保持不变 ---\n\n// createtime升序\nitems.sort((a, b) => new Date(a.createtime) - new Date(b.createtime));\n\n// Map按retroid_id分组\nconst retroidMap = new Map();\nfor (const item of items) {\n    const id = item.retroid_id;\n    if (!retroidMap.has(id)) {\n        retroidMap.set(id, []);\n    }\n    retroidMap.get(id).push(item);\n}\n\nconst activeBindings = new Set();\n\nretroidMap.forEach((list, retroidId) => {\n    const boundItemIds = new Set();\n    const unboundItemIds = new Set();\n\n    for (const obj of list) {\n        if (obj.procedure_detail_id === 62 || obj.procedure_detail_id === 91) {\n            // 解绑：记录machine_data_id_old\n            let oldId = obj.data.machine_data_id_old;\n            if (oldId !== undefined && oldId !== null) {\n                unboundItemIds.add(Number(oldId));\n                unboundItemIds.add(String(oldId));\n            }\n        } else {\n            // === 关键逻辑 ===\n            // 只统计有bind_id的才算绑定\n            // procedure_detail_id=42&无bind_id跳过\n            if (obj.procedure_detail_id === 42 && !obj.data?.bind_id) {\n                continue;\n            }\n            // 其它没有bind_id的也跳过\n            if (!obj.data?.bind_id) continue;\n            boundItemIds.add(Number(obj.machine_data_id));\n            boundItemIds.add(String(obj.machine_data_id));\n        }\n    }\n\n    // debug打印\n    // console.log(`retroid_id: ${retroidId}\\n绑定:${[...boundItemIds]}\\n解绑:${[...unboundItemIds]}\\nstillActive: ${[...boundItemIds].some(id => !unboundItemIds.has(id))}`);\n\n    // 判断还有没被解绑的绑定\n    if ([...boundItemIds].some(id => !unboundItemIds.has(id))) {\n        activeBindings.add(retroidId);\n    }\n});\n\n// 输出\nreturn [...activeBindings].map(id => ({ json: { retroid_id: id } }));"
      },
