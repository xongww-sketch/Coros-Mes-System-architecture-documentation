    {
      "parameters": {
        "jsCode": "// 工单信息：保持原来\nconst orderInfo = $(\"查询工单信息\").first().json;\nconst productQuantity = Number(orderInfo.product_quantity) || 0;\nconst joborderNumber = orderInfo.joborder_number;\nconst joborder_id = orderInfo.joborder_id;\n\n// 从“统计拥有绑定数据的sn”节点获取数据并统计 retroid_id 数量\nconst snItems = $(\"统计拥有绑定数据的sn\").all();  // 拿到该节点全部 items\n\nconst boundCount = snItems.filter(item => {\n  const v = item.json?.retroid_id;\n  return v !== undefined && v !== null && v !== \"\";\n}).length;\n\n// totalRetroidCount = productQuantity - 统计数量\nconst totalRetroidCount = boundCount;\n\nreturn [\n  {\n    json: {\n      code: 200,\n      msg: \"查询成功\",\n      data: [\n        {\n          joborder_id,\n          totalRetroidCount,\n          productQuantity,\n          joborder_number: joborderNumber,\n        },\n      ],\n    },\n  },\n];"
      },
