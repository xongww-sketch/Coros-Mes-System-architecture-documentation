      "parameters": {
        "jsCode": "const mergedArray = items.map(item => {\n  // 创建新对象，避免直接修改原始 item\n  const newItem = { ...item.json };\n  \n  // 如果存在 uuid 字段，则转换为大写\n  if (newItem.uuid !== undefined) {\n    newItem.uuid = newItem.uuid.toUpperCase();\n  }\n  \n  return newItem;\n});\n\nreturn { json: { data: mergedArray } };\n"
      },
      "type": "n8n-nodes-base.code",
