        "query": "select md.procedure_detail_id, md.data ->>'sn' as sn,md.data->>'bind_id' as uuid,md.createtime from mes.machine_data md \nwhere (LOWER(md.data ->>'bind_id')=LOWER('{{ $json.data.uuid }}') or LOWER(md.data ->>'unbind_id')=LOWER('{{ $json.data.uuid }}'))\nand md.retroid_id ='{{ $json.retroid_id }}'\nand procedure_detail_id in(39,62)\norder by md.createtime desc\nlimit 1",
