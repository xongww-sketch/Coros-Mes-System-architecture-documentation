    {
      "parameters": {
        "jsCode": "// 提取输入数据\nconst input = $input.all();\n\n// 手动解析日期字符串\nconst parseDate = (dateString) => {\n  const [date, time] = dateString.split(' ');\n  const [year, month, day] = date.split('-').map(Number);\n  const [hours, minutes, seconds] = time.split(':').map((v, i) => i === 2 ? parseFloat(v) : Number(v));\n  return new Date(Date.UTC(year, month - 1, day, hours, minutes, seconds));\n};\n\nconst startdate = parseDate(input[0].json.startdate);\nconst enddate = parseDate(input[0].json.enddate);\n\n// 使用 ISOString 方法直接格式化\nconst formattedStartDate = startdate.toISOString(); // 保持原始的 ISO 格式带 Z\nconst formattedEndDate = enddate.toISOString(); // 保持原始的 ISO 格式带 Z\n\nreturn [\n  {\n    json: {\n      startdate: formattedStartDate,\n      enddate: formattedEndDate\n    }\n  }\n];\n"
      },
