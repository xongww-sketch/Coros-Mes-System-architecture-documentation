    {
      "parameters": {
        "jsCode": "const productionData = $input.all();\nconst deliveryData = $('插入到每日出库表中').all();\n\nconst combinedData = [];\n\nproductionData.forEach(prodItem => {\n  const matchingDelivery = deliveryData.find(deliveryItem => deliveryItem.json.retroid === prodItem.json.retroid);\n  if (matchingDelivery) {\n    combinedData.push({\n      production_id: prodItem.json.id,\n      delivery_id: matchingDelivery.json.id,\n      retroid: prodItem.json.retroid,\n      machine_type: prodItem.json.machine_type,\n      job_number: prodItem.json.job_number,\n      uuid: prodItem.json.uuid,\n      phase: prodItem.json.phase,\n      wifi_mac: prodItem.json.wifi_mac,\n      battery: prodItem.json.battery,\n      screen: prodItem.json.screen,\n      remark: prodItem.json.remark,\n      channel:matchingDelivery.json.channel\n    });\n  }\n});\n\nreturn combinedData;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
