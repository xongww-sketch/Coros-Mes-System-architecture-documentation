    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT *\nFROM mes.machine_data\nWHERE\n  (\n    -- 绑定记录：顶层 bind_id\n    LOWER(data ->> 'bind_id') = LOWER('{{ $json.data.uuid }}')\n    OR\n    -- 解绑记录：data_old 里的 bind_id\n    LOWER(data #>> '{data_old,bind_id}') = LOWER('{{ $json.data.uuid }}')\n\n    OR\n    -- 解绑记录：顶层 unbind_id\n    LOWER(data ->> 'unbind_id') = LOWER('{{ $json.data.uuid }}')\n\n    OR\n    -- 绑定记录：顶层 uuid_unique\n    LOWER(data ->> 'uuid_unique') = LOWER('{{ $json.data.uuid_unique }}')\n    OR\n    -- 解绑记录：data_old 里的 uuid_unique\n    LOWER(data #>> '{data_old,uuid_unique}') = LOWER('{{ $json.data.uuid_unique }}')\n  )\n  AND procedure_detail_id IN (\n    SELECT pd.procedure_detail_id\n    FROM mes.procedure_detail pd\n    WHERE pd.procedure_name IN ('物料解除绑定','SN与UUID绑定')\n  )\n  AND retroid_id = '{{ $json.retroid_id }}'\nORDER BY createtime DESC\nLIMIT 1;",
        "options": {}
      },
