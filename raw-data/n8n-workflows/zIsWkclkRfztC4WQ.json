    {
      "parameters": {
        "jsCode": "let inputArray = $input.all();\nlet result = null;\n\nif (Array.isArray(inputArray) && inputArray.length > 0) {\n  const firstItem = inputArray[0];\n\n  if (firstItem?.json?.body) {\n    const body = firstItem.json.body;\n\n    // 永远保证有 uuid_unique\n    body.uuid_unique = body.uuid_unique ?? '';\n\n    if (body.uuid) {\n      const uuid_original = String(body.uuid).trim();\n      const uuid_original2 = String(body.uuid);\n\n      // 先判断是否为纯hex\n      const hexOnly = uuid_original.replace(/\\s+/g, '');\n      const isHex = /^[A-Fa-f0-9]+$/.test(hexOnly);\n\n      if (isHex && hexOnly.length === 30) {\n        // 30位：先得到uuid，再切割生成uuid_unique\n        body.uuid = hexOnly.toLowerCase();\n        body.uuid_original = uuid_original;\n        body.uuid_unique = body.uuid.slice(0, 16) + body.uuid.slice(18);\n      } else if (isHex && hexOnly.length === 28) {\n        // 28位：直接当作 uuid_unique（不再切割）\n        body.uuid = hexOnly.toLowerCase();          // 可保留/不保留都行，这里保留\n        body.uuid_original = uuid_original;\n        body.uuid_unique = body.uuid;               // 关键：不切割\n      } else {\n        // URL格式\n        const regex = /a=[\\w\\s]+?([A-Fa-f\\d]+)&b=([A-Fa-f\\d]+)&c=([A-Fa-f\\d]+)/;\n        const match = uuid_original2.match(regex);\n\n        if (match && match.length === 4) {\n          const parts = [match[1], match[2], match[3]].map(s => s.toLowerCase());\n          body.uuid = parts.join('');\n          body.uuid_original = uuid_original;\n\n          // URL拼出来的uuid：按原逻辑切割生成uuid_unique（如果长度够18）\n          body.uuid_unique = body.uuid.length >= 18\n            ? (body.uuid.slice(0, 16) + body.uuid.slice(18))\n            : body.uuid;\n        } else {\n          // 兜底：仍保证 uuid_unique 有值\n          body.uuid = uuid_original;\n          body.uuid_original = uuid_original;\n          body.uuid_unique = body.uuid_unique || '';\n        }\n      }\n\n      console.log(\"Processed UUID:\", { uuid: body.uuid, uuid_unique: body.uuid_unique });\n    } else {\n      body.uuid_unique = '';\n      console.log(\"UUID not found in body.\");\n    }\n\n    result = body;\n  } else {\n    result = { uuid_unique: '' };\n    console.log(\"Body not found in first item.\");\n  }\n} else {\n  result = { uuid_unique: '' };\n  console.log(\"Input array is empty or not an array.\");\n}\n\nreturn result;"
      },
