        "jsCode": "// 假设 items 是您的输入数据\nconst items = $input.all();\n\n// 检查输入数据是否为空或包含空对象\nif (items.length === 0 || (items.length === 1 && Object.keys(items[0]).length === 0)) {\n  // 返回格式化为空值的输出\n  return { json: { data: [{}] } };\n} else {\n  // 正常处理输入数据\n  const mergedArray = items.map(item => {\n    return {\n      joborder_number: item.json.joborder_number || \"\",\n      retroid_id: item.json.retroid_id || \"\",\n      bind_id: item.json.bind_id || \"\",\n      retroid: item.json.retroid || \"\",\n      createtime: item.json.createtime || \"\"\n    };\n  });\n\n  return { json: { data: mergedArray } };\n}\n"
