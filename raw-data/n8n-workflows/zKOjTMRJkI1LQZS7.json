    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    -- 1. 修改展示字段：优先取 jobNumber，如果没有则取 ticketNo\n    COALESCE(md.data->>'jobNumber', md.data->>'ticketNo') AS jobNumber, \n    r.retroid_id, \n    r.retroid\nFROM \n    mes.machine_data md\nJOIN \n    mes.retroid r ON md.retroid_id = r.retroid_id\nJOIN \n    mes.joborder jo ON \n    -- 2. 修改关联条件：使用 COALESCE 来匹配工单表，无论 JSON 里存的是哪个 key\n    COALESCE(md.data->>'jobNumber', md.data->>'ticketNo') = jo.joborder_number\nWHERE\n    jo.joborder_number = '{{ $json.joborder_number }}' \n    AND r.status < 3\n    AND md.procedure_detail_id = '79';",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1392,
        -320
      ],
      "id": "0a1a769b-82df-4c55-84d6-c0febdbd3a44",
      "name": "oqc查询",
