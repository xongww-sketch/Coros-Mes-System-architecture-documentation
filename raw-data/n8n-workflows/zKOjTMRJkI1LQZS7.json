          "name": "mes"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT DISTINCT ON (md.retroid_id)\n    jo.joborder_number,\n    md.retroid_id as retroid_id,\n    md.data ->>'bind_id' as bind_id,\n    md.data ->>'retroid' as retroid,\n    md.createtime \nFROM \n    mes.machine_data md \nJOIN \n    mes.retroid r ON r.retroid_id = md.retroid_id::INTEGER \nJOIN\n    mes.joborder jo ON r.joborder_id =\n  jo.joborder_id ::INTEGER \nWHERE \n    md.procedure_detail_id = 58 \n    AND r.joborder_id = '{{ $json.joborder_id }}'\n    and r.status<3\nORDER BY \n    md.retroid_id,\n    md.createtime DESC",
        "options": {}
      },
