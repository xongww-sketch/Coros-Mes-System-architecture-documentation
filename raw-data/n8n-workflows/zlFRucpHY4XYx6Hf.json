    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE mes.resources\nSET resource_info = jsonb_set(resource_info, '{deviceTypeList}','{{ JSON.stringify($json.newDeviceTypeList) }}'),\n    update_status = 4\nWHERE resource_mac = '{{ $('Webhook').all()[0].json.body.mac }}';\n",
        "options": {}
      },
      "id": "c0baa4b3-cb3e-4159-a893-be0760b3c3b5",
      "name": "update resource deviceTypeList",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1880,
        140
      ],
      "credentials": {
        "postgres": {
          "id": "Br2ubPbG6ZoVjCkh",
          "name": "mes"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nlet res={};\nfor (const item of $input.all()) {\n  const deviceTypeList= item.json.resource_info.deviceTypeList||[];\n  const newDeviceTypeList=$('Webhook').all()[0].json.body.deviceTypeList||[];\n  const isNewDevice=arraysEqual(deviceTypeList,newDeviceTypeList);\n  res.isNewDevice=isNewDevice;\n  res.newDeviceTypeList=newDeviceTypeList;\n  \n}\nfunction arraysEqual(arr1, arr2) {\n    // 如果长度不同，直接返回false\n    if (arr1.length !== arr2.length) {\n        return false;\n    }\n\n    // 判断每个元素是否相同\n    for (let i = 0; i < arr1.length; i++) {\n        if (arr1[i] !== arr2[i]) {\n            return false;\n        }\n    }\n\n    return true;\n}\n\nreturn res;"
      },
